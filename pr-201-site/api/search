lockup#keyboard","content":"Key"},"467":{"id":"/docs/components/metrics-lockup-16","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#keyboard","content":"Description"},"468":{"id":"/docs/components/metrics-lockup-17","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#keyboard","content":"Tab"},"469":{"id":"/docs/components/metrics-lockup-18","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#keyboard","content":"Moves focus to the info trigger button and shows the tooltip"},"470":{"id":"/docs/components/metrics-lockup-19","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#keyboard","content":"Escape"},"471":{"id":"/docs/components/metrics-lockup-20","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#keyboard","content":"Closes the tooltip"},"472":{"id":"/docs/components/metrics-lockup-21","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#aria","content":"The info trigger button uses `aria-label=\"More information\"` to describe its purpose."},"473":{"id":"/docs/components/metrics-lockup-22","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#aria","content":"The tooltip uses `role=\"tooltip\"` and is associated with the info trigger via `aria-describedby`."},"474":{"id":"/docs/components/metrics-lockup-23","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#aria","content":"The info trigger has a minimum touch target of 44×44px, achieved via a CSS pseudo-element, to meet WCAG 2.5.5."},"475":{"id":"/docs/components/metrics-lockup-24","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#best-practices","content":"Keep tooltip content concise and informative."},"476":{"id":"/docs/components/metrics-lockup-25","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#best-practices","content":"The `data` prop accepts strings or numbers — format currency and percentages before passing them in."},"477":{"id":"/docs/components/metrics-lockup-26","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#best-practices","content":"`titleInfo` requires `title` to be set — the info icon is contextually tied to the title label. If `title` is absent, `titleInfo` has no effect."},"478":{"id":"/docs/components/metrics-lockup-27","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#best-practices","content":"`trend` is intended to accompany `description` to provide temporal context (e.g. \"↑ +3% vs. last month\"). A trend icon alone, with no description, leaves the direction unanchored (\"up since *when*?\"). If `description` is not provided, `trend` has no effect."},"479":{"id":"/docs/components/modal","page_id":"/docs/components/modal","type":"page","content":"Modal","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/modal"},"480":{"id":"/docs/components/modal-0","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal","content":"The Modal component presents a dialog window over the page that focuses the user's attention on a single task or piece of information."},"481":{"id":"/docs/components/modal-1","page_id":"/docs/components/modal","type":"heading","tags":[],"url":"/docs/components/modal#installation","content":"Installation"},"482":{"id":"/docs/components/modal-2","page_id":"/docs/components/modal","type":"heading","tags":[],"url":"/docs/components/modal#props","content":"Props"},"483":{"id":"/docs/components/modal-3","page_id":"/docs/compone