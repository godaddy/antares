up#aria","content":"The info trigger button uses `aria-label=\"More information\"` to describe its purpose."},"468":{"id":"/docs/components/metrics-lockup-22","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#aria","content":"The tooltip uses `role=\"tooltip\"` and is associated with the info trigger via `aria-describedby`."},"469":{"id":"/docs/components/metrics-lockup-23","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#aria","content":"The info trigger has a minimum touch target of 44×44px, achieved via a CSS pseudo-element, to meet WCAG 2.5.5."},"470":{"id":"/docs/components/metrics-lockup-24","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#best-practices","content":"Keep tooltip content concise and informative."},"471":{"id":"/docs/components/metrics-lockup-25","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#best-practices","content":"The `data` prop accepts strings or numbers — format currency and percentages before passing them in."},"472":{"id":"/docs/components/metrics-lockup-26","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#best-practices","content":"`titleInfo` requires `title` to be set — the info icon is contextually tied to the title label. If `title` is absent, `titleInfo` has no effect."},"473":{"id":"/docs/components/metrics-lockup-27","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#best-practices","content":"`trend` is intended to accompany `description` to provide temporal context (e.g. \"↑ +3% vs. last month\"). A trend icon alone, with no description, leaves the direction unanchored (\"up since *when*?\"). If `description` is not provided, `trend` has no effect."},"474":{"id":"/docs/components/modal