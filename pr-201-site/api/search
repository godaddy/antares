799":{"id":"/docs/components/toggle-button-24","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#when-to-use","content":"When to Use"},"800":{"id":"/docs/components/toggle-button-25","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#keep-variants-consistent","content":"Keep Variants Consistent"},"801":{"id":"/docs/components/toggle-button-26","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#balance-label-lengths","content":"Balance Label Lengths"},"802":{"id":"/docs/components/toggle-button-27","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#alignment","content":"Alignment"},"803":{"id":"/docs/components/toggle-button-28","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#label-guidelines","content":"Label Guidelines"},"804":{"id":"/docs/components/toggle-button-29","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#icon-only-items","content":"Icon-Only Items"},"805":{"id":"/docs/components/toggle-button-30","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#default-single-selection","content":"A `ToggleButton` toggles between selected and unselected. Wrap multiple inside a `ToggleButtonGroup` to link them with shared selection and keyboard navigation — `defaultSelectedKeys` sets the initial selection."},"806":{"id":"/docs/components/toggle-button-31","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#multiple-selection","content":"Use `selectionMode=\"multiple\"` to allow more than one item to be active at a time."},"807":{"id":"/docs/components/toggle-button-32","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#controlled","content":"Use `selectedKeys` and `onSelectionChange` to control selection from parent state — `onSelectionChange` receives a `Set<string>` of the selected item `id` values."},"808":{"id":"/docs/components/toggle-button-33","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#disabled-states","content":"Disable the entire group with `isDisabled` on the container, or disable individual items with `isDisabled` on specific `ToggleButton` elements."},"809":{"id":"/docs/components/toggle-button-34","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#sizes","content":"Two sizes are available: `sm` and `md` (default)."},"810":{"id":"/docs/components/toggle-button-35","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#icon--text","content":"Items can include an `Icon` alongside text for added visual context."},"811":{"id":"/docs/components/toggle-button-36","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#icon-only","content":"For compact layouts, items can contain only icons. Padding adjusts automatically to keep the button square — no extra prop required. Always provide an `aria-label` on each icon-only item so screen readers can identify the action."},"812":{"id":"/docs/components/toggle-button-37","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#with-dropdown","content":"Wrap a `ToggleButton` in a `MenuTrigger` to add sub-options to a group item."},"813":{"id":"/docs/components/toggle-button-38","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#rtl-direction","content":"The group follows the document's layout direction, detected automatically from the browser locale."},"814":{"id":"/docs/components/toggle-button-39","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#data-attributes","content":"Components automatically add data attributes for styling different states:"},"815":{"id":"/docs/components/toggle-button-40","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#data-attributes","content":"**ToggleButtonGroup Container:** `data-size`"},"816":{"id":"/docs/components/toggle-button-41","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#data-attributes","content":"**ToggleButton Item:** `data-selected`, `data-hovered`, `data-pressed`, `data-focus-visible`, `data-disabled`"},"817":{"id":"/docs/components/toggle-button-42","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#component-customization","content":"Individual components can be styled by passing `className` props:"},"818":{"id":"/docs/components/toggle-button-43","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Key"},"819":{"id":"/docs/components/toggle-button-44","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Action"},"820":{"id":"/docs/components/toggle-button-45","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Tab**"},"821":{"id":"/docs/components/toggle-button-46","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Moves focus to/from the button group (single tab stop)"},"822":{"id":"/docs/components/toggle-button-47","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Arrow Left / Right**"},"823":{"id":"/docs/components/toggle-button-48","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Move focus between items (RAC automatically reverses in RTL)"},"824":{"id":"/docs/components/toggle-button-49","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Space / Enter**"},"825":{"id":"/docs/components/toggle-button-50","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Toggle the focused item"},"826":{"id":"/docs/components/toggle-button-51","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Home**"},"827":{"id":"/docs/components/toggle-button-52","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Move focus to the first item"},"828":{"id":"/docs/components/toggle-button-53","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**End**"},"829":{"id":"/docs/components/toggle-button-54","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Move focus to the last item"},"830":{"id":"/docs/components/toggle-button-55","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"`selectionMode=\"single\"` → `role=\"radiogroup\"` on container, `role=\"radio\"` + `aria-checked` per item"},"831":{"id":"/docs/components/toggle-button-56","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"`selectionMode=\"multiple\"` → `role=\"toolbar\"` on container, `role=\"button\"` + `aria-pressed` per item"},"832":{"id":"/docs/components/toggle-button-57","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"`aria-label` (or `aria-labelledby`) is required on the group container"},"833":{"id":"/docs/components/toggle-button-58","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"Icon-only items require `aria-label` on each `ToggleButton`"},"834":{"id":"/docs/components/toggle-button-59","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"✅ For grouped contextual actions — two or more closely related actions that belong together (e.g. Bold / Italic / Underline, Align Left / Center / Right)"},"835":{"id":"/docs/components/toggle-button-60","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"✅ For compact action grouping — related actions in space-constrained layouts (e.g. Undo / Redo, Zoom In / Out / Reset)"},"836":{"id":"/docs/components/toggle-button-61","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"✅ For multi-select scenarios — when users need to select multiple options simultaneously"},"837":{"id":"/docs/components/toggle-button-62","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ For unrelated actions that perform disconnected tasks without shared context"},"838":{"id":"/docs/components/toggle-button-63","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ For more than 5 choices — cognitive overload; consider a **Select** instead"},"839":{"id":"/docs/components/toggle-button-64","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ When actions require strong visual distinction (e.g. Save vs. Delete)"},"840":{"id":"/docs/components/toggle-button-65","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ When selecting an option leads to a different page or workflow — use navigation instead"},"841":{"id":"/docs/components/toggle-button-66","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ For mutually exclusive content views (e.g. Monthly / Yearly) — use **SegmentedController** instead"},"842":{"id":"/docs/components/toggle-button-67","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keep-variants-consistent","content":"Avoid mixing different content types (text-only, icon-only, icon+text) within the same group. Mixing styles creates visual noise and makes the set feel fragmented rather than unified."},"843":{"id":"/docs/components/toggle-button-68","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#balance-label-lengths","content":"Keep button labels of similar length. Large differences in text length cause irregular button widths and make the group appear uneven. Prefer short, concise wording."},"844":{"id":"/docs/components/toggle-button-69","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"Align the group to reflect its relationship to surrounding content:"},"845":{"id":"/docs/components/toggle-button-70","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Left** — when the group controls content directly below or within the same column (dashboards, tables)."},"846":{"id":"/docs/components/toggle-button-71","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Center** — when the group acts as a prominent toggle affecting an entire section or page."},"847":{"id":"/docs/components/toggle-button-72","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Right** — when the group represents utility or contextual controls (e.g. grid/list view toggle)."},"848":{"id":"/docs/components/toggle-button-73","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#label-guidelines","content":"Use **title case**: capitalize the first letter of each word, except short prepositions."},"849":{"id":"/docs/components/toggle-button-74","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#label-guidelines","content":"Keep labels to one or two words. Omit articles (a, an, the) and filler words."},"850":{"id":"/docs/components/toggle-button-75","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#label-guidelines","content":"Prefer action-focused or descriptive language that communicates the option instantly."},"851":{"id":"/docs/components/toggle-button-76","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#icon-only-items","content":"Use icon-only items only when the icon's meaning is universally recognized. Always provide an `aria-label` on each icon-only `ToggleButton`:"},"852":{"id":"/docs/components/tooltip","page_id":"/docs/components/tooltip","type":"page","content":"Tooltip","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/tooltip"},"853":{"id":"/docs/components/tooltip-0","page_id":"/docs/com