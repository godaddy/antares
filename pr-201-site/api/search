)"},"503":{"id":"/docs/components/modal-28","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#aria","content":"`role=\"dialog\"` is applied automatically by the underlying React Aria `Dialog`"},"504":{"id":"/docs/components/modal-29","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#aria","content":"The `title` is rendered as an `<h2>` and linked to the dialog via `aria-labelledby`"},"505":{"id":"/docs/components/modal-30","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#aria","content":"The close button is rendered with `aria-label=\"Close\"`"},"506":{"id":"/docs/components/modal-31","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#aria","content":"Focus is trapped within the modal while open and returned to the trigger on close"},"507":{"id":"/docs/components/modal-32","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#best-practices","content":"Always provide a `title` so the dialog has an accessible name"},"508":{"id":"/docs/components/modal-33","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#best-practices","content":"Pair every footer action with `slot=\"close\"` when it should dismiss the modal"},"509":{"id":"/docs/components/modal-34","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#best-practices","content":"Set `isDismissable={false}` for required confirmations the user must explicitly answer"},"510":{"id":"/docs/components/modal-35","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#best-practices","content":"Provide meaningful `alt` text for image media, or `alt=\"\"` if it's purely decorative"},"511":{"id":"/docs/components/modal-36","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#best-practices","conten