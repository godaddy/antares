ntent."},"494":{"id":"/docs/components/modal-14","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#props","content":"The `Modal` component accepts the following props:"},"495":{"id":"/docs/components/modal-15","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#basic-usage","content":"The default modal exposes a `title`, `description`, and `children` content area. Open and close state is managed automatically by `ModalTrigger`."},"496":{"id":"/docs/components/modal-16","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#controlled","content":"Pass `isOpen` and `onOpenChange` to `ModalTrigger` to control the open state externally."},"497":{"id":"/docs/components/modal-17","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#with-actions","content":"Render footer buttons via the `actions` prop. Use `slot=\"close\"` on a button to close the modal automatically when pressed."},"498":{"id":"/docs/components/modal-18","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#alignment","content":"Use `centered` to center the title and description, and `actionProps` to control the alignment and direction of the action buttons."},"499":{"id":"/docs/components/modal-19","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#with-media","content":"Pass a `media` element to display imagery alongside the content. Configure its layout with `mediaVariant` (`full` or `inset`), `mediaDirection` (`column` or `row`), and `mediaPosition` (`start` or `end`)."},"500":{"id":"/docs/components/modal-20","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#keyboard-interaction","content":"Key"},"501":{"id":"/docs/components/modal-21","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#keyboard-interaction","content":"Action"},"502":{"id":"/docs/components/modal-22","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#keyboard-interaction","content":"`Tab`"},"503":{"id":"/docs/components/modal-23","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#keyboard-interaction","content":"Moves focus to the next focusable element inside the modal"},"504":{"id":"/docs/components/modal-24","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#keyboard-interaction","content":"`Shift + Tab`"},"505":{"id":"/docs/components/modal-25","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#keyboard-interaction","content":"Moves focus to the previous focusable element inside the modal"},"506":{"id":"/docs/components/modal-26","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#keyboard-interaction","content":"`Escape`"},"507":{"id":"/docs/components/modal-27","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#keyboard-interaction","content":"Closes the modal (when dismissable)"},"508":{"id":"/docs/components/modal-28","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#aria","content":"`role=\"dialog\"` is applied automatically by the underlying React Aria `Dialog`"},"509":{"id":"/docs/components/modal-29","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#aria","content":"The `title` is rendered as an `<h2>` and linked to the dialog via `aria-labelledby`"},"510":{"id":"/docs/components/modal-30","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#aria","content":"The close button is rendered with `aria-label=\"Close\"`"},"511":{"id":"/docs/components/modal-31","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#aria","content":