onents/number-field-8","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#hide-stepper","content":"Hide stepper"},"522":{"id":"/docs/components/number-field-9","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#value-scale","content":"Value scale"},"523":{"id":"/docs/components/number-field-10","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#format-options-numbering-system","content":"Format options (numbering system)"},"524":{"id":"/docs/components/number-field-11","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#accessibility","content":"Accessibility"},"525":{"id":"/docs/components/number-field-12","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#keyboard","content":"Keyboard"},"526":{"id":"/docs/components/number-field-13","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#aria-and-labeling","content":"ARIA and labeling"},"527":{"id":"/docs/components/number-field-14","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#best-practices","content":"Best practices"},"528":{"id":"/docs/components/number-field-15","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#props","content":"The NumberField component accepts the following props:"},"529":{"id":"/docs/components/number-field-16","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#basic","content":"Minimal usage with label, placeholder, and min/max."},"530":{"id":"/docs/components/number-field-17","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#controlled","content":"Use `value` and `onChange` for controlled state."},"531":{"id":"/docs/components/number-field-18","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#invalid","content":"Use `isInvalid` with `errorMessage` for validation feedback."},"532":{"id":"/docs/components/number-field-19","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#disabled","content":"Use `isDisabled` to prevent input."},"533":{"id":"/docs/components/number-field-20","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#hide-stepper","content":"Use `hideStepper` to show only the input without +/- buttons."},"534":{"id":"/docs/components/number-field-21","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#value-scale","content":"Use `minValue`, `maxValue`, and `step` to set the allowed values. Steps are calculated from the minimum value."},"535":{"id":"/docs/components/number-field-22","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#format-options-numbering-system","content":"By default, NumberField displays the value using the numbering system for the user's locale. Use the `formatOptions` prop to override the numbering system by setting the Unicode numbering system locale extension."},"536":{"id":"/docs/components/number-field-23","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#keyboard","content":"When focus is in the input (and the field is not read-only), keyboard behavior follows common spinbutton-style conventions:"},"537":{"id":"/docs/components/number-field-24","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#keyboard","content":"**Arrow Up** / **Arrow Down** (or **Up** / **Down**): increase or decrease by `step`"},"538":{"id":"/docs/components/number-field-25","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#keyboard","content":"**Page Up** / **Page Down**: larger increase or decrease when supported"},"539":{"id":"/docs/components/number-field-26","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#keyboard","content":"**Home** / **End**: jump to `minValue` or `maxValue` when those props are set"},"540":{"id":"/docs/components/number-field-27","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#keyboard","content":"Stepper buttons are real buttons and follow standard button keyboard activation. Use &#x2A;*`incrementAriaLabel`*&#x2A; and &#x2A;*`decrementAriaLabel`** when the default labels are not enough in your locale or UI."},"541":{"id":"/docs/components/number-field-28","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#aria-and-labeling","content":"The input is associated with the visible label and optional description and error content for assistive technologies."},"542":{"id":"/docs/components/number-field-29","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#aria-and-labeling","content":"Invalid and required states are exposed to assistive technologies when you use `isInvalid`, `errorMessage`, and `isRequired`."},"543":{"id":"/docs/components/number-field-30","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#aria-and-labeling","content":"Set &#x2A;*`isWheelDisabled`** if the value should not change when the user scrolls with a pointer wheel while the field is focused."},"544":{"id":"/docs/components/number-field-31","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#best-practices","content":"Pair &#x2A;*`isInvalid`*&#x2A; with &#x2A;