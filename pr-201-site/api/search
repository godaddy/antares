","type":"heading","tags":[],"url":"/docs/components/modal#keyboard-interaction","content":"Keyboard interaction"},"486":{"id":"/docs/components/modal-11","page_id":"/docs/components/modal","type":"heading","tags":[],"url":"/docs/components/modal#aria","content":"ARIA"},"487":{"id":"/docs/components/modal-12","page_id":"/docs/components/modal","type":"heading","tags":[],"url":"/docs/components/modal#best-practices","content":"Best Practices"},"488":{"id":"/docs/components/modal-13","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal","content":"Use `ModalTrigger` to wire a trigger element (typically a `Button`) to a `Modal`. The `Modal` exposes high-level slots for `title`, `description`, `actions`, and `media`, while still accepting arbitrary `children` for custom content."},"489":{"id":"/docs/components/modal-14","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#props","content":"The `Modal` component accepts the following props:"},"490":{"id":"/docs/components/modal-15","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#basic-usage","content":"The default modal exposes a `title`, `description`, and `children` content area. Open and close state is managed automatically by `ModalTrigger`."},"491":{"id":"/docs/components/modal-16","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#controlled","content":"Pass `isOpen` and `onOpenChange` to `ModalTrigger` to control the open state externally."},"492":{"id":"/docs/components/modal-17","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#with-actions","content":"Render footer buttons via the `actions` prop. Use `slot=\"close\"` on a button to close the modal automatically when pressed."},"493":{"id":"/docs/components/modal-18","page_id":"/docs/components/modal","tags":[],"type":"text","url":"/docs/components/modal#alignment","content":