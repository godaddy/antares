uration to process CSS imports from `node_modules`."},"17":{"id":"/docs-15","page_id":"/docs","tags":[],"type":"text","url":"/docs#nextjs","content":"Add `@godaddy/antares` to `transpilePackages` so Next.js processes the package through its own CSS pipeline instead of treating it as a pre-built external:"},"18":{"id":"/docs-16","page_id":"/docs","tags":[],"type":"text","url":"/docs#nextjs","content":"Without this, Next.js will throw:"},"19":{"id":"/docs-17","page_id":"/docs","tags":[],"type":"text","url":"/docs#remix","content":"Remix with Vite handles CSS imports from `node_modules` in the client bundle automatically. However, during SSR, Vite treats `node_modules` as externals by default, which bypasses CSS processing. Add `@godaddy/antares` to `ssr.noExternal` to fix this:"},"20":{"id":"/docs-18","page_id":"/docs","tags":[],"type":"text","url":"/docs#vite","content":"Vite processes CSS imports from `node_modules` out of the box. No additional configuration is needed for client-side SPAs."},"21":{"id":"/docs-19","page_id":"/docs","tags":[],"type":"text","url":"/docs#vite","content":"If you are using Vite with SSR (e.g., custom SSR setup, not Remix), add `@godaddy/antares` to `ssr.noExternal` as shown in the Remix section."},"22":{"id":"/docs-20","page_id":"/docs","tags":[],"type":"text","url":"/docs#other-bundlers","content":"Any bundler that supports CSS imports will work with Antares. If your bundler does not process CSS imports from `node_modules` by default, ensure it is configured to do so. For example, with raw webpack you may need `css-loader` configured to handle `.css` files from `node_modules`."},"23":{"id":"/docs/components/alert","page_id":"/docs/components/alert","type":"page","content":"Alert","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/alert"},"24":{"id":"/docs/components/alert-0","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert","content":"In-page alerts are non-intrusive notifications within a webpage, providing users with timely information or feedback without disrupting their experience."},"25":{"id":"/docs/components/alert-1","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#installation","content":"Installation"},"26":{"id":"/docs/components/alert-2","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#props","content":"Props"},"27":{"id":"/docs/components/alert-3","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#examples","content":"Examples"},"28":{"id":"/docs/components/alert-4","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#basic-usage","content":"Basic Usage"},"29":{"id":"/docs/components/alert-5","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#emphasis-variants","content":"Emphasis Variants"},"30":{"id":"/docs/components/alert-6","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#dismissible","content":"Dismissible"},"31":{"id":"/docs/components/alert-7","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#with-action","content":"With Action"},"32":{"id":"/docs/components/alert-8","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#accessibility","content":"Accessibility"},"33":{"id":"/docs/components/alert-9","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#keyboard","content":"Keyboard"},"34":{"id":"/docs/components/alert-10","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#screen-readers","content":"Screen readers"},"35":{"id":"/docs/components/alert-11","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#dismiss-button-label","content":"Dismiss button label"},"36":{"id":"/docs/co