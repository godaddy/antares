/components/layout/box-16","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xs` - Extra small spacing"},"1098":{"id":"/docs/components/layout/box-17","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`sm` - Small spacing"},"1099":{"id":"/docs/components/layout/box-18","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`md` - Medium spacing"},"1100":{"id":"/docs/components/layout/box-19","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`lg` - Large spacing"},"1101":{"id":"/docs/components/layout/box-20","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xl` - Extra large spacing"},"1102":{"id":"/docs/components/layout/box-21","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`2xl` - 2x extra large spacing"},"1103":{"id":"/docs/components/layout/box-22","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"Custom CSS values are also supported for edge cases."},"1104":{"id":"/docs/components/layout/box-23","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#padding","content":"The padding props support t-shirt sizes and CSS logical properties for RTL support."},"1105":{"id":"/docs/components/layout/box-24","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#elevation","content":"The elevation prop adds visual depth using box-shadow."},"1106":{"id":"/docs/components/layout/box-25","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#