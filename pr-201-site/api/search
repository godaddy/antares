"type":"text","url":"/docs/components/text-field#features","content":"**Multiline**: Set `multiline` to render a textarea instead of a single-line input"},"831":{"id":"/docs/components/text-field-15","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Validation states**: Use `isInvalid` with `errorMessage` and `isDisabled` for validation and disabled state"},"832":{"id":"/docs/components/text-field-16","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**React Aria integration**: Built on React Aria TextField for accessibility and behavior"},"833":{"id":"/docs/components/text-field-17","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#props","content":"The TextField component accepts the following props:"},"834":{"id":"/docs/components/text-field-18","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#basic","content":"Minimal usage with label and placeholder."},"835":{"id":"/docs/components/text-field-19","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#controlled","content":"Use `value` and `onChange` for controlled state."},"836":{"id":"/docs/components/text-field-20","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#invalid","content":"Use `isInvalid` with `errorMessage` for validation feedback."},"837":{"id":"/docs/components/text-field-21","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#disabled","content":"Use `isDisabled` to prevent input."},"838":{"id":"/docs/components/text-field-22","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#adornments","content":"Use `leadingText` and `trailingText` for fixed text before and after the input (e.g. currency)."},"839":{"id":"/docs/components/text-field-23","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#multiline","content":"Use `multiline` to render a textarea."},"840":{"id":"/docs/components/toggle-button","page_id":"/docs/components/toggle-button","type":"page","content":"ToggleButton","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/toggle-button"},"841":{"id":"/docs/components/toggle-button-0","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button","content":"Accessible toggle button component for grouped contextual actions with single or multiple selection, keyboard navigation, and RTL-aware layouts."},"842":{"id":"/docs/components/toggle-button-1","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#installation","content":"Installation"},"843":{"id":"/docs/components/toggle-button-2","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#props","content":"Props"},"844":{"id":"/docs/components/toggle-button-3","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#examples","content":"Examples"},"845":{"id":"/docs/components/toggle-button-4","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#default-single-selection","content":"Default (Single Selection)"},"846":{"id":"/docs/components/toggle-button-5","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#multiple-selection","content":"Multiple Selection"},"847":{"id":"/docs/components/toggle-button-6","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#controlled","content":"Controlled"},"848":{"id":"/docs/components/toggle-button-7","page_id":"/docs/c