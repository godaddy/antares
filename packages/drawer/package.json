{
  "name": "@bento/drawer",
  "version": "0.0.0",
  "description": "Drawer component for expandable panels, sidebars, and bottom sheets",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "scripts": {
    "build": "tsup-node",
    "lint": "biome lint && tsc --noEmit",
    "posttest": "npm run lint",
    "prepublishOnly": "node ../../scripts/compile-readme.ts",
    "pretest": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/bento.git"
  },
  "keywords": [
    "a11y",
    "accessibility",
    "bento",
    "component",
    "drawer",
    "library",
    "overlay",
    "panel",
    "react",
    "sidebar"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/godaddy/bento/issues"
  },
  "homepage": "https://github.com/godaddy/bento#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "dependencies": {
    "@bento/container": "^0.1.1",
    "@bento/slots": "^0.1.3",
    "@bento/use-data-attributes": "^0.1.1",
    "@bento/use-props": "^0.1.1"
  },
  "devDependencies": {
    "motion": "^11.15.0",
    "react-aria": "^3.44.0"
  },
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
