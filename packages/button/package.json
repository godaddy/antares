{
  "name": "@bento/button",
  "version": "0.0.0",
  "description": "Button component built on top of the Pressable primitive",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "scripts": {
    "build": "tsup-node",
    "lint": "biome lint && tsc",
    "posttest": "npm run lint",
    "pretest": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/bento.git"
  },
  "keywords": [
    "accessibility",
    "aria",
    "bento",
    "button",
    "component",
    "interactive",
    "library",
    "pressable",
    "react"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/godaddy/bento/issues"
  },
  "homepage": "https://github.com/godaddy/bento#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "dependencies": {
    "@bento/pressable": "^0.0.0",
    "@bento/slots": "^0.0.0",
    "@bento/use-props": "^0.0.0",
    "react-aria": "^3.43.2"
  },
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
