{
  "name": "@bento/illustration",
  "version": "1.0.0",
  "description": "Illustration component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "scripts": {
    "build": "tsup-node",
    "dev": "tsup-node src/index.ts --watch",
    "lint": "biome lint && tsc --noEmit",
    "posttest": "npm run lint",
    "pretest": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/bento.git"
  },
  "keywords": [
    "bento",
    "react",
    "component",
    "library",
    "illustration",
    "svg",
    "vector",
    "graphic",
    "asset",
    "image",
    "picture",
    "icon"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/godaddy/bento/issues"
  },
  "homepage": "https://github.com/godaddy/bento#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "dependencies": {
    "@bento/slots": "file:../slots",
    "@bento/to-attribute-value": "file:../to-attribute-value",
    "@bento/use-render-props": "file:../use-render-props"
  },
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@react-types/shared": "^3.28.0"
  }
}
