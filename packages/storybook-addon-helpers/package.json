{
  "name": "@bento/storybook-addon-helpers",
  "private": true,
  "version": "0.1.0",
  "description": "Storybook preset addon helpers for Bento",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "scripts": {
    "build": "tsup-node",
    "lint": "biome lint && tsc",
    "posttest": "npm run lint",
    "pretest": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/bento.git"
  },
  "keywords": [
    "accessibility",
    "aria",
    "bento",
    "button",
    "component",
    "interactive",
    "library",
    "pressable",
    "react"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/godaddy/bento/issues"
  },
  "homepage": "https://github.com/godaddy/bento#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "dependencies": {
    "camelcase": "^8.0.0",
    "react-docgen-typescript": "^2.4.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "vite": "^7.1.12"
  },
  "peerDependencies": {
    "storybook": "^9.1.6"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  }
}
