{
  "name": "@bento/environment",
  "private": true,
  "version": "0.1.4",
  "description": "Setup a custom environment for your Bento application",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "biome lint && tsgo --noEmit",
    "prepublishOnly": "node ../../../scripts/compile-readme.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/antares.git"
  },
  "keywords": [
    "application",
    "bento",
    "component",
    "configure",
    "environment",
    "library",
    "react"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/godaddy/antares/issues"
  },
  "homepage": "https://github.com/godaddy/antares#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "dependencies": {
    "@bento/box": "^0.2.0",
    "@bento/slots": "^0.3.0",
    "ts-deepmerge": "^8.0.0",
    "use-deep-compare": "^1.3.0"
  },
  "devDependencies": {
    "vitest-browser-react": "^2.2.0"
  },
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  }
}
