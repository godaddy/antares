{
  "name": "@bento/storybook-addon-helpers",
  "private": true,
  "version": "0.1.1",
  "description": "Storybook preset addon helpers for the Antares design system",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "lint": "biome lint && tsgo --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "keywords": [
    "accessibility",
    "aria",
    "component",
    "library",
    "react",
    "storybook",
    "antares"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "dependencies": {
    "camelcase": "^9.0.0",
    "react-docgen-typescript": "^2.4.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "assume": "^2.3.0",
    "react": "^19.2.6",
    "tsdown": "^0.22.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@storybook/react-vite": "^10.4.4",
    "storybook": "^10.4.1"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  }
}
