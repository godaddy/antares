{
  "name": "@bento/storybook-addon-helpers",
  "private": true,
  "version": "0.2.0",
  "description": "Build-time Storybook preset that generates CSF and prop docs from TypeScript types",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "accessibility",
    "aria",
    "component",
    "library",
    "react",
    "storybook",
    "antares"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "dependencies": {
    "camelcase": "^9.0.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "react": "^19.2.6",
    "tsdown": "^0.22.1",
    "vite": "^8.1.4",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@storybook/react-vite": "^10.5.0",
    "storybook": "^10.4.1"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./docs": {
      "import": {
        "types": "./dist/docs.d.mts",
        "default": "./dist/docs.mjs"
      },
      "require": {
        "types": "./dist/docs.d.cts",
        "default": "./dist/docs.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.mts",
        "default": "./dist/runtime.mjs"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    },
    "./package.json": "./package.json"
  }
}
