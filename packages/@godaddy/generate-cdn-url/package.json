{
  "name": "@godaddy/generate-cdn-url",
  "version": "0.0.0",
  "description": "Generates CDN URLs for GoDaddy assets hosted at https://img6.wsimg.com/",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "biome lint && tsc --noEmit",
    "posttest": "npm run lint",
    "prepublishOnly": "node ../../../scripts/compile-readme.ts",
    "pretest": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/uxcore.git",
    "directory": "packages/@godaddy/generate-cdn-url"
  },
  "keywords": [
    "godaddy",
    "cdn",
    "url",
    "generator",
    "assets"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/godaddy/uxcore/issues"
  },
  "homepage": "https://github.com/godaddy/uxcore#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
