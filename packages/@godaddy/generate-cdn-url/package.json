{
  "name": "@godaddy/generate-cdn-url",
  "version": "0.0.0",
  "description": "Generates CDN URLs for GoDaddy assets hosted at https://img6.wsimg.com/",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "keywords": [
    "godaddy",
    "cdn",
    "url",
    "generator",
    "assets"
  ],
  "homepage": "https://github.com/godaddy/bento/packages/",
  "bugs": {
    "url": "https://github.com/godaddy/bento/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/bento.git",
    "directory": "packages/dev/generate-cdn-url"
  },
  "license": "MIT",
  "author": "GoDaddy Operating Company, LLC",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "biome lint && tsc --noEmit",
    "posttest": "npm run lint",
    "pretest": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsdown": "^0.20.3"
  }
}
