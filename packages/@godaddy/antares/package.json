{
  "name": "@godaddy/antares",
  "version": "0.1.1",
  "description": "The GoDaddy design component library",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "test": "vitest run --project=SSR --project=Browser --coverage",
    "test:node": "vitest run --project=SSR",
    "test:node:update": "vitest run --project=SSR --update",
    "test:browser": "vitest run --project=Browser",
    "test:browser:update": "vitest run --project=Browser --update",
    "test:browser:ui": "vitest --project=Browser --browser.headless=false",
    "test:visual": "vitest run --project=Visual --passWithNoTests --coverage.enabled=false",
    "test:visual:update": "vitest run --project=Visual --update",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "storybook": "storybook dev -p 6006  --no-open",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/antares.git",
    "directory": "packages/@godaddy/antares"
  },
  "keywords": [
    "component",
    "design",
    "library",
    "godaddy"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "UNLICENSED",
  "homepage": "https://github.com/godaddy/antares",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@bento/icon": "^0.2.0",
    "@bento/svg-parser": "^0.1.1",
    "@bento/use-data-attributes": "^0.1.1",
    "@react-aria/focus": "^3.22.0",
    "@react-aria/utils": "^3.34.0",
    "@react-stately/utils": "^3.12.0",
    "@visx/axis": "^4.0.1-alpha.0",
    "@visx/grid": "^4.0.1-alpha.0",
    "@visx/group": "^4.0.1-alpha.0",
    "@visx/mock-data": "^4.0.1-alpha.0",
    "@visx/responsive": "^4.0.1-alpha.0",
    "@visx/scale": "^4.0.1-alpha.0",
    "@visx/shape": "^4.0.1-alpha.0",
    "@visx/tooltip": "^4.0.1-alpha.0",
    "@visx/xychart": "^4.0.1-alpha.0",
    "cva": "npm:class-variance-authority@^0.7.1",
    "embla-carousel": "^9.0.0-rc01",
    "embla-carousel-accessibility": "^9.0.0-rc01",
    "embla-carousel-react": "^9.0.0-rc01",
    "motion": "^12.38.0",
    "react-aria-components": "^1.17.0"
  },
  "devDependencies": {
    "@bento/storybook-addon-helpers": "^0.1.1",
    "@godaddy/generate-cdn-url": "*",
    "@tsdown/css": "^0.21.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "assume": "^2.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rolldown": "^1.0.0-rc.3",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.1.0"
  },
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/exports/*.d.mts",
        "default": "./dist/exports/*.mjs"
      },
      "require": {
        "types": "./dist/exports/*.d.cts",
        "default": "./dist/exports/*.cjs"
      }
    }
  },
  "imports": {
    "#components/*": "./components/*/src/index.tsx"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ]
}
