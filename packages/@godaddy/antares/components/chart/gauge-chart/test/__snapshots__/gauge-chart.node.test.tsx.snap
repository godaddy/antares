filled="true" role="meter" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100" aria-valuetext="50% - Critical" aria-label="Critical variant gauge" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:0.5"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">50%</span></div><span class="text subLabel" style="--align:center">Critical</span></div></div>"`;

exports[`@godaddy/antares > #GaugeChart > renders with-range-labels example 1`] = `"<div class="box" style="display:grid;grid-template-columns:repeat(2, 1fr);justify-content:center;gap:var(--sp-lg, 12px)"><div data-variant="default" data-label-type="value" data-filled="true" role="meter" aria-valuenow="65" aria-valuemin="0" aria-valuemax="100" aria-valuetext="65% - CPU Usage" aria-label="CPU usage gauge" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:0.65"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">65%</span></div><span class="text rangeLabel" data-range-label="min">0</span><span class="text subLabel" style="--align:center">CPU Usage</span><span class="text rangeLabel" data-range-label="max">100</span></div><div data-variant="warning" data-label-type="value" data-segmented="true" data-filled="true" role="meter" aria-valuenow="3" aria-valuemin="0" aria-valuemax="5" aria-valuetext="3/5 - Risk Level" aria-label="Risk level gauge" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:0.6;--_segments:5"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">3/5</span></div><span class="text rangeLabel" data-range-label="min">Low</span><span class="text subLabel" style="--align:center">Risk Level</span><span class="text rangeLabel" data-range-label="max">High</span></div></div>"`;
