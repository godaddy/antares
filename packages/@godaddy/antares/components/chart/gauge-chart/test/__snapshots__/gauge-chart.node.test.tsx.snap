exports[`@godaddy/antares > #GaugeChart > renders continuous example 1`] = `"<div class="box" style="display:grid;grid-template-columns:repeat(auto-fit, minmax(180px, 1fr));justify-content:center;align-content:center;row-gap:var(--sp-md, 8px)"><div data-variant="default" data-label-type="value" role="meter" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-valuetext="0% - Progress" aria-label="Gauge at 0%" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:0"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">0%</span></div><span class="text subLabel" style="--align:center">Progress</span></div><div data-variant="default" data-label-type="value" data-filled="true" role="meter" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100" aria-valuetext="25% - Progress" aria-label="Gauge at 25%" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:0.25"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">25%</span></div><span class="text subLabel" style="--align:center">Progress</span></div><div data-variant="default" data-label-type="value" data-filled="true" role="meter" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100" aria-valuetext="50% - Progress" aria-label="Gauge at 50%" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:0.5"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">50%</span></div><span class="text subLabel" style="--align:center">Progress</span></div><div data-variant="default" data-label-type="value" data-filled="true" role="meter" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100" aria-valuetext="75% - Progress" aria-label="Gauge at 75%" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:0.75"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">75%</span></div><span class="text subLabel" style="--align:center">Progress</span></div><div data-variant="default" data-label-type="value" data-filled="true" data-full="true" role="meter" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100" aria-valuetext="100% - Progress" aria-label="Gauge at 100%" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:1"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">100%</span></div><span class="text subLabel" style="--align:center">Progress</span></div></div>"`;

exports[`@godaddy/antares > #GaugeChart > renders default example 1`] = `"<div data-variant="default" data-label-type="value" data-filled="true" role="meter" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100" aria-valuetext="50%" aria-label="Default gauge" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:0.5"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">50%</span></div><span class="text rangeLabel" data-range-label="min">0</span><span class="text rangeLabel" data-range-label="max">100</span></div>"`;

exports[`@godaddy/antares > #GaugeChart > renders playground example 1`] = `"<div data-variant="warning" data-label-type="text" data-segmented="true" data-filled="true" role="meter" aria-valuenow="3" aria-valuemin="0" aria-valuemax="5" aria-valuetext="3/5 - Risk" aria-label="Playground gauge" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;max-width:118px;margin:auto;--_value:0.6;--_segments:5"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">3/5</span></div><span class="text rangeLabel" data-range-label="min">Low</span><span class="text subLabel" style="--align:center">Risk</span><span class="text rangeLabel" data-range-label="max">High</span></div>"`;

exports[`@godaddy/antares > #GaugeChart > renders segmented example 1`] = `"<div class="box" style="display:grid;grid-template-columns:repeat(2, 200px);justify-content:center;row-gap:var(--sp-lg, 12px)"><div data-variant="default" data-label-type="value" data-segmented="true" role="meter" aria-valuenow="0" aria-valuemin="0" aria-valuemax="5" aria-valuetext="0/5 - Empty" aria-label="Gauge with 0 of 5 filled" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:0;--_segments:5"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">0/5</span></div><span class="text subLabel" style="--align:center">Empty</span></div><div data-variant="default" data-label-type="value" data-segmented="true" data-filled="true" role="meter" aria-valuenow="2" aria-valuemin="0" aria-valuemax="5" aria-valuetext="2/5 - Partial" aria-label="Gauge with 2 of 5 filled" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:0.4;--_segments:5"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">2/5</span></div><span class="text subLabel" style="--align:center">Partial</span></div><div data-variant="default" data-label-type="value" data-segmented="true" data-filled="true" data-full="true" role="meter" aria-valuenow="5" aria-valuemin="0" aria-valuemax="5" aria-valuetext="5/5 - Full" aria-label="Gauge with 5 of 5 filled" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:1;--_segments:5"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">5/5</span></div><span class="text subLabel" style="--align:center">Full</span></div><div data-variant="default" data-label-type="value" data-segmented="true" data-filled="true" role="meter" aria-valuenow="1" aria-valuemin="0" aria-valuemax="3" aria-valuetext="1/3 - Three segments" aria-label="Gauge with 1 of 3 filled" class="box root" style="display:grid;grid-template-columns:auto 1fr auto;justify-content:center;justify-items:center;--_value:0.3333333333333333;--_segments:3"><div class="box gauge" style="display:grid"><span class="text box content" style="display:flex;flex-direction:column;justify-content:end;align-items:center">1/3</span></div><span class="text subLabel" style="--align:center">Three segments</span></div></div>"`;

