// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@godaddy/uxcore > #TooltipDismissStrip > #basic > omits strip when width is zero 1`] = `"<div class="box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><div class="box" style="display:flex;flex-direction:row;align-items:center;flex-wrap:wrap;gap:var(--sp-sm, 4px)"><button type="button">Open tooltip</button><span data-open-state="false" role="status">Visx tooltip context: <!-- -->closed</span></div><div class="box" style="position:relative;width:0;height:200px"></div></div>"`;

exports[`@godaddy/uxcore > #TooltipDismissStrip > #basic > renders basic example 1`] = `"<div class="box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><div class="box" style="display:flex;flex-direction:row;align-items:center;flex-wrap:wrap;gap:var(--sp-sm, 4px)"><button type="button">Open tooltip</button><span data-open-state="false" role="status">Visx tooltip context: <!-- -->closed</span></div><div class="box" style="position:relative;width:200px;height:200px"><div aria-hidden="true" data-tooltip-dismiss-strip="true" class="box strip" style="width:200px;height:200px" data-elevation="card"><span class="text">Hover this region to update the visx tooltip (pointer enter closes it).</span></div></div></div>"`;
