exports[`@godaddy/antares > #Legend > #multi-series > renders multi-series example 1`] = `"<div data-size="md" class="box root" style="display:inline-flex;flex-direction:column;align-items:flex-start;gap:var(--legend-gap-root)"><div role="list" aria-label="Chart legend" class="box" style="flex-shrink:0;display:flex;flex-direction:row;justify-content:center;align-items:flex-start;flex-wrap:wrap;gap:var(--legend-gap-items)"><div role="listitem" class="box item" style="display:flex;flex-direction:row;align-items:center;gap:var(--legend-gap-item-inline)"><div class="box swatch" style="border-radius:9999px;background-color:var(--ux-k4t5bc)"></div><span class="text">Product A</span></div><div role="listitem" class="box item" style="display:flex;flex-direction:row;align-items:center;gap:var(--legend-gap-item-inline)"><div class="box swatch" style="border-radius:9999px;background-color:var(--ux-k4t5bc)"></div><span class="text">Product B</span></div><div role="listitem" class="box item" style="display:flex;flex-direction:row;align-items:center;gap:var(--legend-gap-item-inline)"><div class="box swatch" style="border-radius:9999px;background-color:var(--ux-k4t5bc)"></div><span class="text">Product C</span></div></div></div>"`;

