exports[`@godaddy/uxcore > #Legend > #multi-series > renders multi-series example 1`] = `"<div role="list" aria-label="Chart legend" class="box" style="display:flex;flex-direction:row;justify-content:center;gap:var(--sp-lg, 12px)"><div role="listitem" class="box item" style="display:flex;flex-direction:row;align-items:center;gap:var(--sp-sm, 4px)"><div class="box swatch" style="border-radius:9999px"></div><span class="text">Product A</span></div><div role="listitem" class="box item" style="display:flex;flex-direction:row;align-items:center;gap:var(--sp-sm, 4px)"><div class="box swatch" style="border-radius:9999px"></div><span class="text">Product B</span></div><div role="listitem" class="box item" style="display:flex;flex-direction:row;align-items:center;gap:var(--sp-sm, 4px)"><div class="box swatch" style="border-radius:9999px"></div><span class="text">Product C</span></div></div>"`;

exports[`@godaddy/uxcore > #Legend > #single-series > renders single-series example 1`] = `"<div role="list" aria-label="Chart legend" class="box" style="display:flex;flex-direction:row;justify-content:center;gap:var(--sp-lg, 12px)"><div role="listitem" class="box item" style="display:flex;flex-direction:row;align-items:center;gap:var(--sp-sm, 4px)"><div class="box swatch" style="border-radius:9999px"></div><span class="text">Sales</span></div></div>"`;
