// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@godaddy/antares > #arrow > renders arrow example 1`] = `"<div class="box tooltip" style="padding:var(--sp-md, 8px);border-radius:var(--rounding-2xl, 20px)" data-elevation="raised"><div role="list" aria-label="Tooltip data" class="box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><div role="listitem" class="box item" style="display:inline-flex;flex-direction:row;justify-content:space-between;gap:var(--sp-md, 8px)"><div class="box" style="display:flex;flex-direction:row;align-items:center;gap:var(--sp-sm, 4px)"><div class="box swatch" style="border-radius:9999px"></div><span class="text">Sales</span></div><span class="text value">100</span></div></div><div class="tooltipArrow"></div></div>"`;

