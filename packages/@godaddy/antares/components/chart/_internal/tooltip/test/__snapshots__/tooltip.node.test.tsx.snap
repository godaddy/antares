// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@godaddy/antares > #arrow > renders arrow example 1`] = `"<div class="box tooltip" style="padding:var(--sp-md);border-radius:var(--rounding-2xl)" data-elevation="raised"><div role="list" aria-label="Tooltip data" class="box flex column" style="gap:var(--sp-sm)"><div role="listitem" class="box inlineFlex item" style="justify-content:space-between;gap:var(--sp-2xl)"><div class="box flex" style="align-items:center;gap:var(--sp-sm)"><div class="box swatch" style="border-radius:var(--rounding-full)"></div><span class="text">Sales</span></div><span class="text value">100</span></div></div><div class="tooltipArrow"></div></div>"`;

