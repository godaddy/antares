// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@godaddy/antares > #AxisTitle > #rtl-direction > renders rtl direction example 1`] = `"<div role="group" aria-label="y axis title" dir="rtl" class="box flex axis yAxis" style="justify-content:center;align-items:center">Temperature (°F)</div>"`;

exports[`@godaddy/antares > #AxisTitle > #x-axis > renders x-axis example 1`] = `"<div role="group" aria-label="x axis title" dir="ltr" class="box flex axis xAxis" style="justify-content:center;align-items:center">Month</div>"`;

exports[`@godaddy/antares > #AxisTitle > #y-axis > renders y-axis example 1`] = `"<div role="group" aria-label="y axis title" dir="ltr" class="box flex axis yAxis" style="justify-content:center;align-items:center">Temperature (°F)</div>"`;
