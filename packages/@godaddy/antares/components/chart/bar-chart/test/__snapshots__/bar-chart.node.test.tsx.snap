exports[`@godaddy/antares > #BarChart > renders custom-domain example 1`] = `"<div data-x-labels-vertical="true" class="box chart" style="display:flex;flex-direction:row;width:600px;height:400px"><div role="group" aria-label="y axis title" dir="ltr" class="box yAxis" style="display:flex;flex-direction:row;justify-content:center;align-items:center">Value</div><div class="box" style="flex:1;display:flex;flex-direction:column;overflow:hidden"><div dir="ltr" class="box area"></div><div role="group" aria-label="x axis title" dir="ltr" class="box xAxis" style="display:flex;flex-direction:row;justify-content:center;align-items:center">Category</div></div></div>"`;

exports[`@godaddy/antares > #BarChart > renders formatted-tick-marks example 1`] = `"<div data-x-labels-vertical="true" class="box chart" style="display:flex;flex-direction:row;width:600px;height:400px"><div role="group" aria-label="y axis title" dir="ltr" class="box yAxis" style="display:flex;flex-direction:row;justify-content:center;align-items:center">Sales Amount</div><div class="box" style="flex:1;display:flex;flex-direction:column;overflow:hidden"><div dir="ltr" class="box area"></div><div role="group" aria-label="x axis title" dir="ltr" class="box xAxis" style="display:flex;flex-direction:row;justify-content:center;align-items:center">Date</div></div></div>"`;

exports[`@godaddy/antares > #BarChart > renders horizontal-multi-series example 1`] = `"<div data-x-labels-vertical="true" class="box chart" style="display:flex;flex-direction:row;width:100%;height:700px"><div role="group" aria-label="y axis title" dir="ltr" class="box yAxis" style="display:flex;flex-direction:row;justify-content:center;align-items:center">Exoplanet</div><div class="box" style="flex:1;display:flex;flex-direction:column;overflow:hidden"><div dir="ltr" class="box area"></div><div role="group" aria-label="x axis title" dir="ltr" class="box xAxis" style="display:flex;flex-direction:row;justify-content:center;align-items:center">Radius (Rj)</div><div data-size="md" class="box root" style="align-self:center;display:inline-flex;flex-direction:column;align-items:flex-start;gap:var(--sp-sm, 4px)"><div role="list" aria-label="Chart legend" class="box" style="display:flex;flex-direction:row;align-items:flex-start;gap:var(--sp-lg, 12px)"><div role="listitem" class="box item" style="display:flex;flex-direction:row;align-items:center;gap:var(--sp-sm, 4px)"><div class="box swatch" style="border-radius:9999px"></div><span class="text">Survey A</span></div><div role="listitem" class="box item" style="display:flex;flex-direction:row;align-items:center;gap:var(--sp-sm, 4px)"><div class="box swatch" style="border-radius:9999px"></div><span class="text">Survey B</span></div><div role="listitem" class="box item" style="display:flex;flex-direction:row;align-items:center;gap:var(--sp-sm, 4px)"><div class="box swatch" style="border-radius:9999px"></div><span class="text">Survey C</span></div><div role="listitem" class="box item" style="display:flex;flex-direction:row;align-items:center;gap:var(--sp-sm, 4px)"><div class="box swatch" style="border-radius:9999px"></div><span class="text">Survey D</span></div></div></div></div></div>"`;

