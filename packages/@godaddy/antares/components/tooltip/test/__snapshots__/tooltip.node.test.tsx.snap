exports[`@godaddy/antares > #Tooltip > renders CustomAnchorExample 1`] = `"<div class="box flex" style="align-items:center;gap:var(--sp-sm)"><button class="button primary md" data-rac="" type="button" tabindex="0" data-react-aria-pressable="true" id="react-aria-_R_d_"><span class="react-aria-Text">Hover me</span></button><div class="box" style="padding:var(--sp-sm)" data-elevation="card">Tooltip appears here</div></div>"`;

