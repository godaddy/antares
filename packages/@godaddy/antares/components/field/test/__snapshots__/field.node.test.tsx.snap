// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@godaddy/antares > #FieldGroup > #IconAccessories > renders 1`] = `"<div class="box field" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><label class="label">Email</label><div class="box group" style="align-self:stretch;display:flex;flex-direction:row;align-items:stretch;flex-wrap:nowrap" data-elevation="card" data-rac="" role="group"><span class="box" style="padding-inline-start:var(--sp-sm, 4px);display:flex;flex-direction:row;align-items:center"><svg data-placeholder="true" role="presentation" viewBox="0 0 24 24" focusable="false" fill="currentColor" class="icon" data-override="className" data-loading="true" data-icon="star" data-slot="content"></svg></span><input data-field-edge="middle" placeholder="Email" class="box input" style="flex:1" data-rac=""/><button data-field-edge="end" class="box fieldButton" style="display:flex;flex-direction:row;justify-content:center;align-items:center" data-rac="" type="button" tabindex="0" data-react-aria-pressable="true" aria-label="Verify email address" id="react-aria-_R_e_">Verify</button></div><span class="text description" slot="description">Enter your email address</span></div>"`;

exports[`@godaddy/antares > #FieldGroup > #LeadingControl > renders 1`] = `"<div class="box field" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><label class="label">Phone</label><div class="box group" style="align-self:stretch;display:flex;flex-direction:row;align-items:stretch;flex-wrap:nowrap;gap:var(--sp-sm, 4px)" data-elevation="card" data-rac="" role="group"><button data-field-edge="start" class="box fieldButton" style="display:flex;flex-direction:row;justify-content:center;align-items:center" data-rac="" type="button" tabindex="0" data-react-aria-pressable="true" aria-label="Country code" id="react-aria-_R_6_">Click Me</button><span class="box" style="padding:var(--sp-md, 8px);flex:1;display:flex;flex-direction:row;align-items:center">Placeholder content</span></div><span class="text description" slot="description">Enter your phone number</span></div>"`;

exports[`@godaddy/antares > #FieldGroup > #TrailingControl > renders 1`] = `"<div class="box field" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><label class="label">Search</label><div class="box group" style="align-self:stretch;display:flex;flex-direction:row;align-items:stretch;flex-wrap:nowrap;gap:var(--sp-sm, 4px)" data-elevation="card" data-rac="" role="group"><input data-field-edge="start" placeholder="Type..." class="box input" style="flex:1" data-rac=""/><button data-field-edge="end" class="box fieldButton" style="display:flex;flex-direction:row;justify-content:center;align-items:center" data-rac="" type="button" tabindex="0" data-react-aria-pressable="true" aria-label="Search" id="react-aria-_R_a_">Search</button></div><span class="text description" slot="description">Search by keyword</span></div>"`;
