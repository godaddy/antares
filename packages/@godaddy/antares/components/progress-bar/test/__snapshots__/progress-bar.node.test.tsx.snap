exports[`@godaddy/antares > #ProgressBar > renders progress bars in different sizes 1`] = `"<div class="box flex column" style="gap:var(--sp-md)"><div data-size="xs" data-status="default" class="box flex column progressBar" style="gap:var(--sp-xs)" data-rac="" id="react-aria-_R_5_" aria-labelledby="react-aria-_R_5H1_" aria-valuenow="40" aria-valuemin="0" aria-valuemax="100" aria-valuetext="40%" role="progressbar"><div class="box flex" style="justify-content:space-between;align-items:baseline"><span class="label" id="react-aria-_R_5H1_">Extra Small</span><span class="text valueLabel">40%</span></div><div class="track" style="--progress-bar-progress:40%"></div></div><div data-size="sm" data-status="default" class="box flex column progressBar" style="gap:var(--sp-xs)" data-rac="" id="react-aria-_R_6_" aria-labelledby="react-aria-_R_6H1_" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100" aria-valuetext="60%" role="progressbar"><div class="box flex" style="justify-content:space-between;align-items:baseline"><span class="label" id="react-aria-_R_6H1_">Small</span><span class="text valueLabel">60%</span></div><div class="track" style="--progress-bar-progress:60%"></div></div><div data-size="md" data-status="default" class="box flex column progressBar" style="gap:var(--sp-xs)" data-rac="" id="react-aria-_R_7_" aria-labelledby="react-aria-_R_7H1_" aria-valuenow="80" aria-valuemin="0" aria-valuemax="100" aria-valuetext="80%" role="progressbar"><div class="box flex" style="justify-content:space-between;align-items:baseline"><span class="label" id="react-aria-_R_7H1_">Medium</span><span class="text valueLabel">80%</span></div><div class="track" style="--progress-bar-progress:80%"></div></div></div>"`;

exports[`@godaddy/antares > #ProgressBar > renders progress bars with different statuses 1`] = `"<div class="box flex column" style="gap:var(--sp-md)"><div data-size="md" data-status="default" class="box flex column progressBar" style="gap:var(--sp-xs)" data-rac="" aria-describedby="_R_1_" id="react-aria-_R_9_" aria-labelledby="react-aria-_R_9H1_" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100" aria-valuetext="50%" role="progressbar"><div class="box flex" style="justify-content:space-between;align-items:baseline"><span class="label" id="react-aria-_R_9H1_">Default</span><span class="text valueLabel">50%</span></div><div class="track" style="--progress-bar-progress:50%"></div><span class="text helperText" id="_R_1_">In progress</span></div><div data-size="md" data-status="success" class="box flex column progressBar" style="gap:var(--sp-xs)" data-rac="" aria-describedby="_R_2_" id="react-aria-_R_a_" aria-labelledby="react-aria-_R_aH1_" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100" aria-valuetext="100%" role="progressbar"><div class="box flex" style="justify-content:space-between;align-items:baseline"><span class="label" id="react-aria-_R_aH1_">Success</span><span class="text valueLabel">100%</span></div><div class="track" style="--progress-bar-progress:100%"></div><span class="text helperText" id="_R_2_">Complete</span></div><div data-size="md" data-status="warning" class="box flex column progressBar" style="gap:var(--sp-xs)" data-rac="" aria-describedby="_R_3_" id="react-aria-_R_b_" aria-labelledby="react-aria-_R_bH1_" aria-valuenow="70" aria-valuemin="0" aria-valuemax="100" aria-valuetext="70%" role="progressbar"><div class="box flex" style="justify-content:space-between;align-items:baseline"><span class="label" id="react-aria-_R_bH1_">Warning</span><span class="text valueLabel">70%</span></div><div class="track" style="--progress-bar-progress:70%"></div><span class="text helperText" id="_R_3_">Storage almost full</span></div><div data-size="md" data-status="critical" class="box flex column progressBar" style="gap:var(--sp-xs)" data-rac="" aria-describedby="_R_4_" id="react-aria-_R_c_" aria-labelledby="react-aria-_R_cH1_" aria-valuenow="30" aria-valuemin="0" aria-valuemax="100" aria-valuetext="30%" role="progressbar"><div class="box flex" style="justify-content:space-between;align-items:baseline"><span class="label" id="react-aria-_R_cH1_">Critical</span><span class="text valueLabel">30%</span></div><div class="track" style="--progress-bar-progress:30%"></div><span class="text helperText" id="_R_4_">Action required</span></div></div>"`;

exports[`@godaddy/antares > #ProgressBar > renders the default progress bar 1`] = `"<div data-size="md" data-status="default" class="box flex column progressBar" style="gap:var(--sp-xs)" data-rac="" aria-describedby="_R_0_" id="react-aria-_R_1_" aria-labelledby="react-aria-_R_1H1_" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100" aria-valuetext="60%" role="progressbar"><div class="box flex" style="justify-content:space-between;align-items:baseline"><span class="label" id="react-aria-_R_1H1_">Loading…</span><span class="text valueLabel">60%</span></div><div class="track" style="--progress-bar-progress:60%"></div><span class="text helperText" id="_R_0_">Please wait while we process your request</span></div>"`;
