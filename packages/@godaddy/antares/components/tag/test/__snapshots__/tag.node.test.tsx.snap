// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@godaddy/antares > #Tag > renders all emphasis variants 1`] = `"<div class="box" style="display:flex;flex-direction:row;align-items:center;flex-wrap:wrap;gap:var(--sp-xs, 2px)"><span class="tag" data-emphasis="passive" data-size="md" data-design="filled">passive</span><span class="tag" data-emphasis="critical" data-size="md" data-design="filled">critical</span><span class="tag" data-emphasis="warning" data-size="md" data-design="filled">warning</span><span class="tag" data-emphasis="success" data-size="md" data-design="filled">success</span><span class="tag" data-emphasis="info" data-size="md" data-design="filled">info</span><span class="tag" data-emphasis="highlight" data-size="md" data-design="filled">highlight</span><span class="tag" data-emphasis="premium" data-size="md" data-design="filled">premium</span><span class="tag" data-emphasis="internal" data-size="md" data-design="filled">internal</span><span class="tag" data-emphasis="neutral" data-size="md" data-design="filled">neutral</span></div>"`;

exports[`@godaddy/antares > #Tag > renders all sizes 1`] = `"<div class="box" style="display:flex;flex-direction:row;align-items:center;flex-wrap:wrap;gap:var(--sp-xs, 2px)"><span class="tag" data-emphasis="info" data-size="sm" data-design="filled">Small</span><span class="tag" data-emphasis="info" data-size="md" data-design="filled">Medium</span><span class="tag" data-emphasis="info" data-size="lg" data-design="filled">Large</span></div>"`;

exports[`@godaddy/antares > #Tag > renders tags with leading icons 1`] = `"<div class="box" style="display:flex;flex-direction:row;align-items:center;flex-wrap:wrap;gap:var(--sp-xs, 2px)"><span class="tag" data-emphasis="critical" data-size="md" data-design="filled"><svg data-placeholder="true" role="presentation" viewBox="0 0 24 24" focusable="false" fill="currentColor" aria-hidden="true" data-override="className" data-loading="true" data-icon="alert" data-slot="content"></svg>Critical</span><span class="tag" data-emphasis="success" data-size="md" data-design="filled"><svg data-placeholder="true" role="presentation" viewBox="0 0 24 24" focusable="false" fill="currentColor" aria-hidden="true" data-override="className" data-loading="true" data-icon="checkmark" data-slot="content"></svg>Success</span><span class="tag" data-emphasis="warning" data-size="md" data-design="filled"><svg data-placeholder="true" role="presentation" viewBox="0 0 24 24" focusable="false" fill="currentColor" aria-hidden="true" data-override="className" data-loading="true" data-icon="alert" data-slot="content"></svg>Warning</span><span class="tag" data-emphasis="info" data-size="md" data-design="filled"><svg data-placeholder="true" role="presentation" viewBox="0 0 24 24" focusable="false" fill="currentColor" aria-hidden="true" data-override="className" data-loading="true" data-icon="information" data-slot="content"></svg>Info</span><span class="tag" data-emphasis="highlight" data-size="md" data-design="filled"><svg data-placeholder="true" role="presentation" viewBox="0 0 24 24" focusable="false" fill="currentColor" aria-hidden="true" data-override="className" data-loading="true" data-icon="star" data-slot="content"></svg>Highlight</span><span class="tag" data-emphasis="premium" data-size="md" data-design="filled"><svg data-placeholder="true" role="presentation" viewBox="0 0 24 24" focusable="false" fill="currentColor" aria-hidden="true" data-override="className" data-loading="true" data-icon="diamond" data-slot="content"></svg>Premium</span></div>"`;

exports[`@godaddy/antares > #Tag > renders the default tag 1`] = `"<span class="tag" data-emphasis="passive" data-size="md" data-design="filled">Tag</span>"`;

exports[`@godaddy/antares > #Tag > renders the high-contrast variant 1`] = `"<div class="box" style="display:flex;flex-direction:row;align-items:center;flex-wrap:wrap;gap:var(--sp-xs, 2px)"><span class="tag" data-emphasis="passive" data-size="md" data-design="filled" data-high-contrast="">passive</span><span class="tag" data-emphasis="critical" data-size="md" data-design="filled" data-high-contrast="">critical</span><span class="tag" data-emphasis="warning" data-size="md" data-design="filled" data-high-contrast="">warning</span><span class="tag" data-emphasis="success" data-size="md" data-design="filled" data-high-contrast="">success</span><span class="tag" data-emphasis="info" data-size="md" data-design="filled" data-high-contrast="">info</span><span class="tag" data-emphasis="highlight" data-size="md" data-design="filled" data-high-contrast="">highlight</span><span class="tag" data-emphasis="premium" data-size="md" data-design="filled" data-high-contrast="">premium</span><span class="tag" data-emphasis="internal" data-size="md" data-design="filled" data-high-contrast="">internal</span><span class="tag" data-emphasis="neutral" data-size="md" data-design="filled" data-high-contrast="">neutral</span></div>"`;

exports[`@godaddy/antares > #Tag > renders the indicator variant 1`] = `"<div class="box" style="display:flex;flex-direction:row;align-items:center;flex-wrap:wrap;gap:var(--sp-xs, 2px)"><span class="tag" data-emphasis="passive" data-size="md" data-design="filled" data-high-contrast="" data-indicator="">passive</span><span class="tag" data-emphasis="critical" data-size="md" data-design="filled" data-high-contrast="" data-indicator="">critical</span><span class="tag" data-emphasis="warning" data-size="md" data-design="filled" data-high-contrast="" data-indicator="">warning</span><span class="tag" data-emphasis="success" data-size="md" data-design="filled" data-high-contrast="" data-indicator="">success</span><span class="tag" data-emphasis="info" data-size="md" data-design="filled" data-high-contrast="" data-indicator="">info</span><span class="tag" data-emphasis="highlight" data-size="md" data-design="filled" data-high-contrast="" data-indicator="">highlight</span><span class="tag" data-emphasis="premium" data-size="md" data-design="filled" data-high-contrast="" data-indicator="">premium</span><span class="tag" data-emphasis="internal" data-size="md" data-design="filled" data-high-contrast="" data-indicator="">internal</span><span class="tag" data-emphasis="neutral" data-size="md" data-design="filled" data-high-contrast="" data-indicator="">neutral</span></div>"`;

exports[`@godaddy/antares > #Tag > renders the inline design 1`] = `"<span class="tag" data-emphasis="passive" data-size="md" data-design="inline" data-high-contrast="">Tag</span>"`;

