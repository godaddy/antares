exports[`@godaddy/antares > #DatePicker > renders basic example 1`] = `"<div class="box field" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)" data-rac=""><span class="fieldLabel" id="react-aria-_R_0H4_">Event date</span><div data-react-aria-pressable="true" id="react-aria-_R_0H3_" aria-labelledby="react-aria-_R_0H4_" aria-describedby="react-aria-_R_0H6_ react-aria-_R_0H7_" role="group" class="box fieldGroup" style="align-self:stretch;display:flex;flex-direction:row;align-items:center;flex-wrap:nowrap" data-elevation="card" data-rac=""><button id="react-aria-_R_0_" class="box trigger" style="flex:1;display:flex;flex-direction:row;justify-content:space-between;align-items:center;gap:var(--sp-sm, 4px)" data-rac="" type="button" tabindex="0" data-react-aria-pressable="true" aria-describedby="react-aria-_R_0H6_ react-aria-_R_0H7_" aria-label="Calendar" aria-labelledby="react-aria-_R_0_ react-aria-_R_0H4_" aria-haspopup="dialog" aria-expanded="false"><span class="placeholder">Select a date</span><svg data-placeholder="true" role="presentation" viewBox="0 0 24 24" focusable="false" fill="currentColor" class="icon" data-override="className" data-loading="true" data-icon="calendar" data-slot="content"></svg></button></div></div><div style="border:0;clip:rect(0 0 0 0);clip-path:inset(50%);height:1px;margin:-1px;overflow:hidden;padding:0;position:fixed;width:1px;white-space:nowrap;top:0;left:0" aria-hidden="true" data-react-aria-prevent-focus="true" data-a11y-ignore="aria-hidden-focus" data-testid="hidden-dateinput-container"><input tabindex="-1" type="date" form="" step="60" value=""/></div>"`;

