exports[`@godaddy/antares > #DropZone > renders the file upload drop zone 1`] = `"<div class="box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><div class="box dropZone" style="padding:var(--sp-lg, 12px);display:flex;flex-direction:column;justify-content:center;align-items:center;gap:var(--sp-sm, 4px)" data-rac=""><div style="border:0;clip:rect(0 0 0 0);clip-path:inset(50%);height:1px;margin:-1px;overflow:hidden;padding:0;position:absolute;width:1px;white-space:nowrap"><button type="button" tabindex="0" data-react-aria-pressable="true" id="react-aria-_R_1H1_" aria-label="Add files or drag them here" aria-labelledby="react-aria-_R_1H1_ react-aria-_R_1_"></button></div><button class="button inline md" style="font-size:0.984rem;font-weight:700" data-rac="" type="button" tabindex="0" data-react-aria-pressable="true" id="react-aria-_R_5l_"><svg data-placeholder="true" role="presentation" viewBox="0 0 24 24" focusable="false" fill="currentColor" class="icon" aria-hidden="true" data-override="className" data-loading="true" data-icon="add" data-slot="content"></svg>Add files</button><input class="" type="file" style="display:none" accept="image/jpeg,image/png,image/gif,application/pdf" multiple="" data-rac=""/><span class="text" id="react-aria-_R_1_" slot="label" style="font-size:0.778rem">The file must be less than 256MB</span></div><div class="box" style="display:flex;flex-direction:row;justify-content:center;gap:var(--sp-xs, 2px)"><span class="text" style="font-size:0.778rem">Supported formats:</span><strong class="text" style="font-size:0.778rem">.pdf, .jpg, .gif, .png</strong></div></div>"`;

exports[`@godaddy/antares > #DropZone > renders the playground drop zone 1`] = `"<div class="box dropZone" style="padding:var(--sp-lg, 12px);display:flex;flex-direction:column;justify-content:center;align-items:center" data-rac=""><div style="border:0;clip:rect(0 0 0 0);clip-path:inset(50%);height:1px;margin:-1px;overflow:hidden;padding:0;position:absolute;width:1px;white-space:nowrap"><button type="button" tabindex="0" data-react-aria-pressable="true" id="react-aria-_R_0H1_" aria-label="DropZone" aria-labelledby="react-aria-_R_0H1_ react-aria-_R_0_"></button></div><span class="text" id="react-aria-_R_0_" slot="label">Drop files to upload.</span></div>"`;

exports[`@godaddy/antares > #DropZone > renders the replace file drop zone 1`] = `"<div style="width:200px"><div class="box dropZone" style="padding:var(--sp-lg, 12px);display:flex;flex-direction:column;justify-content:center;align-items:center;gap:var(--sp-sm, 4px);min-height:200px" data-rac=""><div style="border:0;clip:rect(0 0 0 0);clip-path:inset(50%);height:1px;margin:-1px;overflow:hidden;padding:0;position:absolute;width:1px;white-space:nowrap"><button type="button" tabindex="0" data-react-aria-pressable="true" id="react-aria-_R_0H1_" aria-label="Add a file" aria-labelledby="react-aria-_R_0H1_ react-aria-_R_0_"></button></div><button class="button inline md" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.5rem;font-size:0.984rem;font-weight:700" data-rac="" type="button" tabindex="0" data-react-aria-pressable="true" id="react-aria-_R_d_"><svg data-placeholder="true" role="presentation" viewBox="0 0 24 24" focusable="false" fill="currentColor" class="icon" aria-hidden="true" data-override="className" data-loading="true" data-icon="add" data-slot="content"></svg>Add files</button><input class="" type="file" style="display:none" accept="image/jpeg,image/png,image/gif,application/pdf" data-rac=""/></div></div>"`;
