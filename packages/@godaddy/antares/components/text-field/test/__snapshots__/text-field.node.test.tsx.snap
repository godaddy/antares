exports[`@godaddy/antares > #TextField > #examples > renders adornments example 1`] = `"<div class="box flex column field" style="gap:var(--sp-sm)" data-rac=""><label class="fieldLabel" id="react-aria-_R_0H1_" for="react-aria-_R_0_">Amount</label><div role="presentation" class="box flex fieldGroup" style="align-self:stretch;align-items:stretch;flex-wrap:nowrap;gap:var(--sp-sm)" data-elevation="card" data-rac=""><span class="box flex" style="padding-inline-start:var(--sp-md);align-items:center">$</span><input type="text" placeholder="0.00" tabindex="0" id="react-aria-_R_0_" aria-labelledby="react-aria-_R_0H1_" aria-describedby="react-aria-_R_0H3_ react-aria-_R_0H4_" class="box fieldInput" style="flex:1" data-rac="" value=""/><span class="box flex" style="padding-inline-end:var(--sp-md);align-items:center">.00</span></div><span class="text fieldDescription" id="react-aria-_R_0H3_" slot="description">Use leadingText and trailingText to show fixed text before and after the input (e.g. currency).</span></div>"`;

