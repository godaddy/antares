exports[`@godaddy/antares > #TextField > #examples > renders adornments example 1`] = `"<div class="react-aria-TextField" data-rac=""><div class="box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><label class="label" id="react-aria-_R_0H1_" for="react-aria-_R_0_">Amount</label><div role="presentation" class="box frame" style="display:flex;flex-direction:row;align-items:stretch;flex-wrap:nowrap;gap:var(--sp-sm, 4px)" data-rac=""><span class="text box" style="padding-inline-start:var(--sp-md, 8px);display:flex;flex-direction:row;align-items:center">$</span><input type="text" placeholder="0.00" tabindex="0" id="react-aria-_R_0_" aria-labelledby="react-aria-_R_0H1_" aria-describedby="react-aria-_R_0H3_ react-aria-_R_0H4_" class="input" data-rac="" value=""/><span class="text box" style="padding-inline-end:var(--sp-md, 8px);display:flex;flex-direction:row;align-items:center">.00</span></div><div class="text description" id="react-aria-_R_0H3_" slot="description">Use leadingText and trailingText to show fixed text before and after the input (e.g. currency).</div></div></div>"`;

