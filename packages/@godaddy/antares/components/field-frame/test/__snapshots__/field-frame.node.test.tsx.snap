// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@godaddy/uxcore > #FieldFrame > #IconAccessories > renders 1`] = `"<div class="box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><label class="label">Email</label><div class="box frame" style="display:flex;flex-direction:row;align-items:stretch;flex-wrap:nowrap" data-rac="" role="group"><svg data-placeholder="true" role="presentation" viewBox="0 0 24 24" focusable="false" class="icon" fill="currentColor" aria-hidden="true" data-override="className" data-loading="true" data-icon="star" data-slot="content"></svg><div class="box" style="flex:1;display:flex;flex-direction:row"></div><button class="button button minimal sm" data-rac="" type="button" tabindex="0" data-react-aria-pressable="true" aria-label="Verify email address" id="react-aria-_R_q_"><span class="react-aria-Text">Verify</span></button></div><div class="text description" slot="description">Enter your email address</div></div>"`;

exports[`@godaddy/uxcore > #FieldFrame > #LeadingControl > renders 1`] = `"<div class="box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><label class="label">Phone</label><div class="box frame" style="display:flex;flex-direction:row;align-items:stretch;flex-wrap:nowrap" data-rac="" role="group" data-disabled="true"><button class="button button minimal sm" data-rac="" type="button" disabled="" data-react-aria-pressable="true" aria-label="Country code" id="react-aria-_R_a_" data-disabled="true"><span class="react-aria-Text">Click Me</span></button><div class="box"></div></div><div class="text description" slot="description">Enter your phone number</div></div>"`;

exports[`@godaddy/uxcore > #FieldFrame > #TrailingControl > renders 1`] = `"<div class="box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><label class="label">Search<span class="label-required"> *</span></label><div class="box frame" style="display:flex;flex-direction:row;align-items:stretch;flex-wrap:nowrap" data-rac="" role="group"><div class="box" style="flex:1;display:flex;flex-direction:row"></div><button class="button button tertiary md" data-rac="" type="button" tabindex="0" data-react-aria-pressable="true" aria-label="Search" id="react-aria-_R_i_"><span class="react-aria-Text">Search</span></button></div><div class="text description" slot="description">Search by keyword</div></div>"`;
