exports[`@godaddy/antares > #Flex > renders flex with alignment variations 1`] = `"<div class="box flex column" style="gap:var(--sp-lg)"><div class="box flex column" style="gap:var(--sp-sm)"><strong class="box flex">justifyContent: space-between</strong><div class="box flex" style="justify-content:space-between"><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Start</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Middle</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">End</div></div></div><div class="box flex column" style="gap:var(--sp-sm)"><strong class="box flex">justifyContent: center</strong><div class="box flex" style="justify-content:center;gap:var(--sp-sm)"><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Item 1</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Item 2</div></div></div><div class="box flex column" style="gap:var(--sp-sm)"><strong class="box flex">justifyContent: end</strong><div class="box flex" style="justify-content:end;gap:var(--sp-sm)"><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Item 1</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Item 2</div></div></div><div class="box flex column" style="gap:var(--sp-sm)"><strong class="box flex">alignItems: center (with varying heights)</strong><div class="box flex" style="align-items:center;gap:var(--sp-sm);height:100px"><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Short</div><div class="box flex" style="padding:var(--sp-lg);background:#e0e0e0">Tall</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Short</div></div></div><div class="box flex column" style="gap:var(--sp-sm)"><strong class="box flex">alignItems: stretch (default)</strong><div class="box flex" style="align-items:stretch;gap:var(--sp-sm);height:100px"><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e