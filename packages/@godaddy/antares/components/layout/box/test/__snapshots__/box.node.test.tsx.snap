exports[`@godaddy/antares > #Box > renders boxes with type tests 1`] = `"<button type="submit" disabled="" class="box">Valid</button><a href="/link" target="_blank" class="box">Valid</a><div class="box">Valid</div><button class="box">Valid</button><div class="box padSm">Valid</div><button href="/link" class="box">Invalid</button><div disabled="" class="box">Invalid</div><a href="/link" formAction="/submit" class="box">Invalid</a><div class="box">Invalid</div><button class="box">Invalid</button><div class="box">Invalid</div><div variant="invalid" class="box">Invalid</div><div class="box">Invalid</div>"`;
