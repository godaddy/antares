exports[`@godaddy/antares > #Box > renders box with custom className 1`] = `"<div class="gda_iwBeha_box" style="display:flex;flex-direction:column;gap:var(--sp-md, 8px)"><div data-testid="custom-data-prop" aria-label="custom-label" class="gda_iwBeha_box custom-class" style="padding:var(--sp-md, 8px)" data-elevation="card">Padding: md</div><div class="gda_iwBeha_box" style="padding-block:var(--sp-lg, 12px)" data-elevation="card">Block Padding: lg</div><div class="gda_iwBeha_box" style="padding-inline:var(--sp-xl, 16px)" data-elevation="card">Inline Padding: xl</div><div class="gda_iwBeha_box" style="padding-block-start:var(--sp-sm, 4px);padding-block-end:var(--sp-lg, 12px)" data-elevation="card">Block Padding Start: sm, End: lg</div></div>"`;

exports[`@godaddy/antares > #Box > renders boxes with different element types 1`] = `"<div class="gda_iwBeha_box" style="display:flex;flex-direction:column;gap:var(--sp-md, 8px)"><div class="gda_iwBeha_box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><div class="gda_iwBeha_box" style="padding:var(--sp-sm, 4px)" data-elevation="base">Default (div)</div><section class="gda_iwBeha_box" style="padding:var(--sp-sm, 4px)" data-elevation="base">As section</section><article class="gda_iwBeha_box" style="padding:var(--sp-sm, 4px)" data-elevation="base">As article</article><span class="gda_iwBeha_box" style="padding:var(--sp-sm, 4px)" data-elevation="base">As span</span></div><div class="gda_iwBeha_box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><button type="button" class="gda_iwBeha_box" style="padding:var(--sp-sm, 4px)" data-elevation="base">As button (click me)</button><a href="https://example.com" target="_blank" rel="noopener noreferrer" class="gda_iwBeha_box" style="padding:var(--sp-sm, 4px)" data-elevation="base">As anchor (link)</a><input type="text" placeholder="As input element" class="gda_iwBeha_box" style="padding:var(--sp-sm, 4px)" data-elevation="base"/></div><div class="gda_iwBeha_box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><button class="gda_iwBeha_box" style="padding:var(--sp-sm, 4px)" data-elevation="base">Button with typed ref</button><a href="#" class="gda_iwBeha_box" style="padding:var(--sp-sm, 4px)" data-elevation="base">Anchor with typed ref</a><div class="gda_iwBeha_box" style="padding:var(--sp-sm, 4px)" data-elevation="base">Div with typed ref (default)</div></div><div class="gda_iwBeha_box" style="display:flex;flex-direction:column;gap:var(--sp-sm, 4px)"><div type="A" class="gda_iwBeha_box gda_iwBeha_box">type A! <!-- -->Custom Card</div><div type="B" class="gda_iwBeha_box gda_iwBeha_box">type B! <!-- -->Custom Card</div></div></div>"`;

