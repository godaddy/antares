exports[`@godaddy/antares > #Box > renders box with custom className 1`] = `"<div class="box flex column gapMd"><div data-testid="custom-data-prop" aria-label="custom-label" class="box padMd custom-class" data-elevation="card">Padding: md</div><div class="box padYLg" data-elevation="card">Block Padding: lg</div><div class="box padXXl" data-elevation="card">Inline Padding: xl</div><div class="box padBSSm padBELg" data-elevation="card">Block Padding Start: sm, End: lg</div></div>"`;

exports[`@godaddy/antares > #Box > renders boxes with different element types 1`] = `"<div class="box flex column gapMd"><div class="box flex column gapSm"><div class="box padSm" data-elevation="base">Default (div)</div><section class="box padSm" data-elevation="base">As section</section><article class="box padSm" data-elevation="base">As article</article><span class="box padSm" data-elevation="base">As span</span></div><div class="box flex column gapSm"><button type="button" class="box padSm" data-elevation="base">As button (click me)</button><a href="https://example.com" target="_blank" rel="noopener noreferrer" class="box padSm" data-elevation="base">As anchor (link)</a><input type="text" placeholder="As input element" class="box padSm" data-elevation="base"/></div><div class="box flex column gapSm"><button class="box padSm" data-elevation="base">Button with typed ref</button><a href="#" class="box padSm" data-elevation="base">Anchor with typed ref</a><div class="box padSm" data-elevation="base">Div with typed ref (default)</div></div><div class="box flex column gapSm"><div type="A" class="box box">type A! <!-- -->Custom Card</div><div type="B" class="box box">type B! <!-- -->Custom Card</div></div></div>"`;

