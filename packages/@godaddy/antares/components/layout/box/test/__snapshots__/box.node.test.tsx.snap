// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@godaddy/antares > #Box > renders box with custom className 1`] = `"<div class="box flex column" style="gap:var(--sp-md)"><div data-testid="custom-data-prop" aria-label="custom-label" class="box custom-class" style="padding:var(--sp-md)" data-elevation="card">Padding: md</div><div class="box" style="padding-block:var(--sp-lg)" data-elevation="card">Block Padding: lg</div><div class="box" style="padding-inline:var(--sp-xl)" data-elevation="card">Inline Padding: xl</div><div class="box" style="padding-block-start:var(--sp-sm);padding-block-end:var(--sp-lg)" data-elevation="card">Block Padding Start: sm, End: lg</div></div>"`;

exports[`@godaddy/antares > #Box > renders boxes with different element types 1`] = `"<div class="box flex column" style="gap:var(--sp-md)"><div class="box flex column" style="gap:var(--sp-sm)"><div class="box" style="padding:var(--sp-sm)" data-elevation="base">Default (div)</div><section class="box" style="padding:var(--sp-sm)" data-elevation="base">As section</section><article class="box" style="padding:var(--sp-sm)" data-elevation="base">As article</article><span class="box" style="padding:var(--sp-sm)" data-elevation="base">As span</span></div><div class="box flex column" style="gap:var(--sp-sm)"><button type="button" class="box" style="padding:var(--sp-sm)" data-elevation="base">As button (click me)</button><a href="https://example.com" target="_blank" rel="noopener noreferrer" class="box" style="padding:var(--sp-sm)" data-elevation="base">As anchor (link)</a><input type="text" placeholder="As input element" class="box" style="padding:var(--sp-sm)" data-elevation="base"/></div><div class="box flex column" style="gap:var(--sp-sm)"><button class="box" style="padding:var(--sp-sm)" data-elevation="base">Button with typed ref</button><a href="#" class="box" style="padding:var(--sp-sm)" data-elevation="base">Anchor with typed ref</a><div class="box" style="padding:var(--sp-sm)" data-elevation="base">Div with typed ref (default)</div></div><div class="box flex column" style="gap:var(--sp-sm)"><div type="A" class="box box">type A! <!-- -->Custom Card</div><div type="B" class="box box">type B! <!-- -->Custom Card</div></div></div>"`;

exports[`@godaddy/antares > #Box > renders boxes with elevation variations 1`] = `"<div class="box flex column" style="padding:var(--sp-md);gap:var(--sp-lg)"><div class="box" style="padding:var(--sp-md)" data-elevation="base">Elevation: base</div><div class="box" style="padding:var(--sp-md)" data-elevation="card">Elevation: card</div><div class="box" style="padding:var(--sp-md)" data-elevation="raised">Elevation: raised</div><div class="box" style="padding:var(--sp-md)" data-elevation="overlay">Elevation: overlay</div></div>"`;

exports[`@godaddy/antares > #Box > renders boxes with padding variations 1`] = `"<div class="box flex column" style="gap:var(--sp-md)"><div class="box" style="padding:var(--sp-md)" data-elevation="card">Padding: md</div><div class="box" style="padding-block:var(--sp-lg)" data-elevation="card">Block Padding: lg</div><div class="box" style="padding-inline:var(--sp-xl)" data-elevation="card">Inline Padding: xl</div><div class="box" style="padding-block-start:var(--sp-sm);padding-block-end:var(--sp-lg)" data-elevation="card">Block Padding Start: sm, End: lg</div></div>"`;

exports[`@godaddy/antares > #Box > renders boxes with rounding variations 1`] = `"<div class="box flex column" style="flex-wrap:wrap;gap:var(--sp-md)"><div class="box" style="padding:var(--sp-md);border-radius:var(--rounding-xs)" data-elevation="card">xs</div><div class="box" style="padding:var(--sp-md);border-radius:var(--rounding-sm)" data-elevation="card">sm</div><div class="box" style="padding:var(--sp-md);border-radius:var(--rounding-md)" data-elevation="card">md</div><div class="box" style="padding:var(--sp-md);border-radius:var(--rounding-lg)" data-elevation="card">lg</div><div class="box" style="padding:var(--sp-md);border-radius:var(--rounding-xl)" data-elevation="card">xl</div><div class="box" style="padding:var(--sp-md);border-radius:var(--rounding-2xl)" data-elevation="card">2xl</div><div class="box" style="padding:var(--sp-md);border-radius:var(--rounding-full);width:80px;height:80px" data-elevation="card">full</div><div class="box" style="padding:var(--sp-md);border-radius:var(--rounding-full);width:200px;height:80px" data-elevation="card">pill</div></div>"`;

exports[`@godaddy/antares > #Box > renders boxes with self-alignment props 1`] = `"<div class="box flex" style="gap:var(--sp-md);height:150px"><div class="box" style="padding:var(--sp-sm);align-self:start" data-elevation="card">align-self: start</div><div class="box" style="padding:var(--sp-sm);align-self:center" data-elevation="card">align-self: center</div><div class="box" style="padding:var(--sp-sm);align-self:end" data-elevation="card">align-self: end</div><div class="box" style="padding:var(--sp-sm);align-self:stretch" data-elevation="card">align-self: stretch</div></div>"`;
