exports[`@godaddy/antares > #Grid > renders form layout 1`] = `"<div class="box grid" style="grid-template-columns:auto 1fr;align-items:center;gap:var(--sp-md);width:400px"><label class="box flex">Name</label><div class="box flex" style="padding:var(--sp-sm);background:#f5f5f5">Input placeholder</div><label class="box flex">Email</label><div class="box flex" style="padding:var(--sp-sm);background:#f5f5f5">Input placeholder</div><label class="box flex">Message</label><div class="box flex" style="padding:var(--sp-sm);background:#f5f5f5">Textarea placeholder</div></div>"`;

exports[`@godaddy/antares > #Grid > renders grid with alignment 1`] = `"<div class="box flex column" style="gap:var(--sp-lg)"><div class="box flex column" style="gap:var(--sp-sm)"><strong class="box flex">justifyItems: center</strong><div class="box grid" style="grid-template-columns:repeat(3, 1fr);justify-items:center;gap:var(--sp-sm)" data-elevation="base"><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Centered</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Centered</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Centered</div></div></div><div class="box flex column" style="gap:var(--sp-sm)"><strong class="box flex">alignItems: center (with fixed row height)</strong><div class="box grid" style="grid-template-columns:repeat(3, 1fr);grid-template-rows:100px;align-items:center;gap:var(--sp-sm)" data-elevation="base"><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Centered</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Centered</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Centered</div></div></div><div class="box flex column" style="gap:var(--sp-sm)"><strong class="box flex">justifyItems: end, alignItems: end</strong><div class="box grid" style="grid-template-columns:repeat(3, 1fr);grid-template-rows:80px;justify-items:end;align-items:end;gap:var(--sp-sm)" data-elevation="base"><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">End</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">End</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">End</div></div></div></div>"`;

exports[`@godaddy/antares > #Grid > renders grid with column variations 1`] = `"<div class="box flex column" style="gap:var(--sp-lg)"><div class="box flex column" style="gap:var(--sp-sm)"><strong class="box flex">columns: repeat(2, 1fr)</strong><div class="box grid" style="grid-template-columns:repeat(2, 1fr);gap:var(--sp-sm)"><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Item 1</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Item 2</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Item 3</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Item 4</div></div></div><div class="box flex column" style="gap:var(--sp-sm)"><strong class="box flex">columns: 1fr 2fr 1fr</strong><div class="box grid" style="grid-template-columns:1fr 2fr 1fr;gap:var(--sp-sm)"><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Narrow</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Wide</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Narrow</div></div></div><div class="box flex column" style="gap:var(--sp-sm)"><strong class="box flex">columns: auto 1fr auto</strong><div class="box grid" style="grid-template-columns:auto 1fr auto;gap:var(--sp-sm)"><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Auto</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Flexible</div><div class="box flex" style="padding:var(--sp-sm);background:#e0e0e0">Auto</div></div></div></div>"`;

