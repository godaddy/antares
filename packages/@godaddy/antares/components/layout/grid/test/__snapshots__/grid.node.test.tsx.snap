exports[`@godaddy/antares > #Grid > renders form layout 1`] = `"<div class="box grid gapMd" style="grid-template-columns:auto 1fr;align-items:center;width:400px"><label class="box flex">Name</label><div class="box padSm flex" style="background:#f5f5f5">Input placeholder</div><label class="box flex">Email</label><div class="box padSm flex" style="background:#f5f5f5">Input placeholder</div><label class="box flex">Message</label><div class="box padSm flex" style="background:#f5f5f5">Textarea placeholder</div></div>"`;

exports[`@godaddy/antares > #Grid > renders grid with alignment 1`] = `"<div class="box flex column gapLg"><div class="box flex column gapSm"><strong class="box flex">justifyItems: center</strong><div class="box grid gapSm" style="grid-template-columns:repeat(3, 1fr);justify-items:center" data-elevation="base"><div class="box padSm flex" style="background:#e0e0e0">Centered</div><div class="box padSm flex" style="background:#e0e0e0">Centered</div><div class="box padSm flex" style="background:#e0e0e0">Centered</div></div></div><div class="box flex column gapSm"><strong class="box flex">alignItems: center (with fixed row height)</strong><div class="box grid gapSm" style="grid-template-columns:repeat(3, 1fr);grid-template-rows:100px;align-items:center" data-elevation="base"><div class="box padSm flex" style="background:#e0e0e0">Centered</div><div class="box padSm flex" style="background:#e0e0e0">Centered</div><div class="box padSm flex" style="background:#e0e0e0">Centered</div></div></div><div class="box flex column gapSm"><strong class="box flex">justifyItems: end, alignItems: end</strong><div class="box grid gapSm" style="grid-template-columns:repeat(3, 1fr);grid-template-rows:80px;justify-items:end;align-items:end" data-elevation="base"><div class="box padSm flex" style="background:#e0e0e0">End</div><div class="box padSm flex" style="background:#e0e0e0">End</div><div class="box padSm flex" style="background:#e0e0e0">End</div></div></div></div>"`;

exports[`@godaddy/antares > #Grid > renders grid with column variations 1`] = `"<div class="box flex column gapLg"><div class="box flex column gapSm"><strong class="box flex">columns: repeat(2, 1fr)</strong><div class="box grid gapSm" style="grid-template-columns:repeat(2, 1fr)"><div class="box padSm flex" style="background:#e0e0e0">Item 1</div><div class="box padSm flex" style="background:#e0e0e0">Item 2</div><div class="box padSm flex" style="background:#e0e0e0">Item 3</div><div class="box padSm flex" style="background:#e0e0e0">Item 4</div></div></div><div class="box flex column gapSm"><strong class="box flex">columns: 1fr 2fr 1fr</strong><div class="box grid gapSm" style="grid-template-columns:1fr 2fr 1fr"><div class="box padSm flex" style="background:#e0e0e0">Narrow</div><div class="box padSm flex" style="background:#e0e0e0">Wide</div><div class="box padSm flex" style="background:#e0e0e0">Narrow</div></div></div><div class="box flex column gapSm"><strong class="box flex">columns: auto 1fr auto</strong><div class="box grid gapSm" style="grid-template-columns:auto 1fr auto"><div class="box padSm flex" style="background:#e0e0e0">Auto</div><div class="box padSm flex" style="background:#e0e0e0">Flexible</div><div class="box padSm flex" style="background:#e0e0e0">Auto</div></div></div></div>"`;

exports[`@godaddy/antares > #Grid > renders grid with gap variations 1`] = `"<div class="box flex column gapLg"><div class="box flex column gapSm"><strong class="box flex">gap: xs</strong><div class="box grid gapXs" style="grid-template-columns:repeat(3, 1fr)"><div class="box padSm flex" style="background:#e0e0e0">Item</div><div class="box padSm flex" style="background:#e0e0e0">Item</div><div class="box padSm flex" style="background:#e0e0e0">Item</div></div></div><div class="box flex column gapSm"><strong class="box flex">gap: md</strong><div class="box grid gapMd" style="grid-template-columns:repeat(3, 1fr)"><div class="box padSm flex" style="background:#e0e0e0">Item</div><div class="box padSm flex" style="background:#e0e0e0">Item</div><div class="box padSm flex" style="background:#e0e0e0">Item</div></div></div><div class="box flex column gapSm"><strong class="box flex">gap: xl</strong><div class="box grid gapXl" style="grid-template-columns:repeat(3, 1fr)"><div class="box padSm flex" style="background:#e0e0e0">Item</div><div class="box padSm flex" style="background:#e0e0e0">Item</div><div class="box padSm flex" style="background:#e0e0e0">Item</div></div></div><div class="box flex column gapSm"><strong class="box flex">rowGap: lg, columnGap: xs</strong><div class="box grid gapXXs gapYLg" style="grid-template-columns:repeat(3, 1fr)"><div class="box padSm flex" style="background:#e0e0e0">Item 1</div><div class="box padSm flex" style="background:#e0e0e0">Item 2</div><div class="box padSm flex" style="background:#e0e0e0">Item 3</div><div class="box padSm flex" style="background:#e0e0e0">Item 4</div><div class="box padSm flex" style="background:#e0e0e0">Item 5</div><div class="box padSm flex" style="background:#e0e0e0">Item 6</div></div></div></div>"`;

