{
  "name": "@bento/icon",
  "version": "1.0.0",
  "description": "Icon component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "scripts": {
    "build": "tsup-node",
    "dev": "tsup-node --watch",
    "lint": "biome lint && tsc",
    "posttest": "npm run lint",
    "pretest": "npm run build",
    "test:node": "c8 --100 tsx --test test/**/*.node.test.tsx",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/bento.git"
  },
  "keywords": [
    "bento",
    "react",
    "component",
    "library",
    "illustration",
    "svg",
    "vector",
    "graphic",
    "asset",
    "image",
    "picture",
    "icon"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/godaddy/bento/issues"
  },
  "homepage": "https://github.com/godaddy/bento#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "dependencies": {
    "@bento/box": "file:../box",
    "@bento/error": "file:../error",
    "@bento/create-external-store": "file:../create-external-store",
    "@bento/illustration": "file:../illustration",
    "@bento/slots": "file:../slots",
    "@bento/use-render-props": "file:../use-render-props",
    "@bento/svg-parser": "file:../svg-parser",
    "@bento/use-svg-sprite": "file:../use-svg-sprite",
    "camelcase": "^8.0.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  }
}
