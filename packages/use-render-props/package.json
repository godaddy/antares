{
  "name": "@bento/use-render-props",
  "version": "1.0.0",
  "description": "Context aware render props for Bento",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "scripts": {
    "dev": "tsup src/index.ts --watch",
    "build": "tsup",
    "test": "npm run test:node",
    "pretest": "npm run build",
    "test:node": "c8 --100 tsx --test test/**/*.node.ts",
    "lint": "biome lint && tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/bento.git"
  },
  "keywords": [
    "bento",
    "react",
    "component",
    "library",
    "renderprops",
    "props",
    "render-props",
    "render"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/godaddy/bento/issues"
  },
  "homepage": "https://github.com/godaddy/bento#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "dependencies": {
    "@bento/slots": "file:../slots"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  }
}
