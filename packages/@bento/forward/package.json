{
  "name": "@bento/forward",
  "version": "0.1.0",
  "description": "React 19-compatible forwardRef utility for Bento",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "scripts": {
    "build": "tsup-node",
    "dev": "tsup-node --watch",
    "lint": "biome lint && tsc --noEmit",
    "prepublishOnly": "node ../../../scripts/compile-readme.ts",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/antares.git"
  },
  "keywords": [
    "bento",
    "component",
    "forward",
    "forwardRef",
    "react",
    "react19",
    "ref"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/godaddy/antares/issues"
  },
  "homepage": "https://github.com/godaddy/antares#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.1.0"
  },
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
