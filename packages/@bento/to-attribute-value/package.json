{
  "name": "@bento/to-attribute-value",
  "version": "0.1.1",
  "description": "Format a value as an HTML attribute value.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "biome lint && tsgo --noEmit",
    "prepublishOnly": "node ../../../scripts/compile-readme.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/antares.git"
  },
  "keywords": [
    "attribute",
    "bento",
    "component",
    "format",
    "library",
    "react",
    "stringify",
    "value"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/godaddy/antares/issues"
  },
  "homepage": "https://github.com/godaddy/antares#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "dependencies": {
    "dashify": "^2.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vitest-browser-react": "^2.2.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
