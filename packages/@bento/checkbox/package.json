{
  "name": "@bento/checkbox",
  "version": "0.2.1",
  "description": "Checkbox component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "scripts": {
    "build": "tsup-node",
    "lint": "biome lint && tsc",
    "prepublishOnly": "node ../../../scripts/compile-readme.ts",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/antares.git"
  },
  "keywords": [
    "accessibility",
    "aria",
    "bento",
    "checkbox",
    "component",
    "interactive",
    "library",
    "react"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/godaddy/antares/issues"
  },
  "homepage": "https://github.com/godaddy/antares#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "dependencies": {
    "@bento/container": "^0.2.1",
    "@bento/icon": "^0.1.4",
    "@bento/input": "^0.1.0",
    "@bento/slots": "^0.3.0",
    "@bento/use-data-attributes": "^0.1.1",
    "@bento/use-props": "^0.2.1",
    "@bento/visually-hidden": "^0.1.1",
    "@react-aria/utils": "^3.30.0",
    "react-aria": "^3.45.0",
    "react-stately": "^3.43.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.2.0"
  },
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
