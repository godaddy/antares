{
  "name": "@bento/icon",
  "version": "0.1.4",
  "description": "Icon component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "scripts": {
    "build": "tsup-node",
    "dev": "tsup-node --watch",
    "lint": "biome lint && tsc",
    "posttest": "npm run lint",
    "prepublishOnly": "node ../../../scripts/compile-readme.ts",
    "pretest": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/antares.git"
  },
  "keywords": [
    "asset",
    "bento",
    "component",
    "graphic",
    "icon",
    "illustration",
    "image",
    "library",
    "picture",
    "react",
    "svg",
    "vector"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/godaddy/uxcore/issues"
  },
  "homepage": "https://github.com/godaddy/uxcore#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "dependencies": {
    "@bento/create-external-store": "^0.1.1",
    "@bento/error": "^0.1.1",
    "@bento/illustration": "^0.1.4",
    "@bento/slots": "^0.3.0",
    "@bento/svg-parser": "^0.1.1",
    "@bento/use-data-attributes": "^0.1.1",
    "@bento/use-props": "^0.2.1",
    "@bento/use-svg-sprite": "^0.1.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
