exports[`@bento/use-props examples > Nested > renders the changes from a slot assignment 1`] = `"<div class="example" data-slot="example-container"><label for=":r0:" data-slot="label">Hello World</label><a class="xyz-hashed-class button" id=":r0:" data-slot="button" href="https://example.com">Click Me</a></div>"`;
