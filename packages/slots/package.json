{
  "name": "@bento/slots",
  "version": "1.0.0",
  "description": "The slots implementation of Bento",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "scripts": {
    "build": "tsup-node",
    "dev": "tsup-node src/index.ts --watch",
    "lint": "biome lint && tsc --noEmit",
    "posttest": "npm run lint",
    "pretest": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godaddy/bento.git"
  },
  "keywords": [
    "bento",
    "react",
    "component",
    "library",
    "slot",
    "slots",
    "primitives"
  ],
  "author": "GoDaddy Operating Company, LLC",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/godaddy/bento/issues"
  },
  "homepage": "https://github.com/godaddy/bento#readme",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "dependencies": {
    "@bento/error": "file:../error",
    "@bento/use-data-attributes": "file:../use-data-attributes",
    "use-deep-compare": "^1.3.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./context": {
      "types": "./src/context.ts",
      "import": "./dist/context.js",
      "require": "./dist/context.cjs"
    },
    "./modifiers/override": {
      "types": "./src/override.ts",
      "import": "./dist/override.js",
      "require": "./dist/override.cjs"
    },
    "./modifiers/replace": {
      "types": "./src/replace.ts",
      "import": "./dist/replace.js",
      "require": "./dist/replace.cjs"
    },
    "./package.json": "./package.json"
  }
}
