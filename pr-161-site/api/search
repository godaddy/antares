-frame-29","page_id":"/docs/components/field-frame","tags":[],"type":"text","url":"/docs/components/field-frame#states","content":"State"},"162":{"id":"/docs/components/field-frame-30","page_id":"/docs/components/field-frame","tags":[],"type":"text","url":"/docs/components/field-frame#states","content":"CSS Selector"},"163":{"id":"/docs/components/field-frame-31","page_id":"/docs/components/field-frame","tags":[],"type":"text","url":"/docs/components/field-frame#states","content":"disabled — Applied when the field wrapper is disabled."},"164":{"id":"/docs/components/field-frame-32","page_id":"/docs/components/field-frame","tags":[],"type":"text","url":"/docs/components/field-frame#states","content":"`[data-disabled]`"},"165":{"id":"/docs/components/field-frame-33","page_id":"/docs/components/field-frame","tags":[],"type":"text","url":"/docs/components/field-frame#states","content":"invalid — Applied when the field wrapper is invalid (e.g. validation failed)."},"166":{"id":"/docs/components/field-frame-34","page_id":"/docs/components/field-frame","tags":[],"type":"text","url":"/docs/components/field-frame#states","content":"`[data-invalid]`"},"167":{"id":"/docs/components/field-frame-35","page_id":"/docs/components/field-frame","tags":[],"type":"text","url":"/docs/components/field-frame#states","content":"readonly — Applied when the field wrapper is read only."},"168":{"id":"/docs/components/field-frame-36","page_id":"/docs/components/field-frame","tags":[],"type":"text","url":"/docs/components/field-frame#states","content":"`[data-readonly]`"},"169":{"id":"/docs/components/field-frame-37","page_id":"/docs/components/field-frame","tags":[],"type":"text","url":"/docs/components/field-frame#states","content":"focus — Whether an element within the frame has keyboard focus (for focus-ring styling)."},"170":{"id":"/docs/components/field-frame-38","page_id":"/docs/components/field-frame","tags":[],"type":"text","url":"/docs/components/field-frame#states","content":"`[data-