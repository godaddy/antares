tion a tooltip relative to a different focusable element, use the\n`triggerRef` prop. The `TooltipTrigger` still handles showing/hiding on hover/focus."},"613":{"id":"/docs/components/tooltip-13","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#keyboard","content":"Key"},"614":{"id":"/docs/components/tooltip-14","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#keyboard","content":"Description"},"615":{"id":"/docs/components/tooltip-15","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#keyboard","content":"Tab"},"616":{"id":"/docs/components/tooltip-16","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#keyboard","content":"Moves focus to the focusable element and shows the tooltip"},"617":{"id":"/docs/components/tooltip-17","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#keyboard","content":"Escape"},"618":{"id":"/docs/components/tooltip-18","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#keyboard","content":"Closes the tooltip"},"619":{"id":"/docs/components/tooltip-19","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#aria","content":"The tooltip uses `role=\"tooltip\"` and is associated with its focusable element via `aria-describedby`."},"620":{"id":"/docs/components/tooltip-20","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#best-practices","content":"Keep tooltip content short and informative."},"621":{"id":"/docs/components/tooltip-21","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#best-practices","content":"Tooltips are not shown on touch screen interactions. Ensure your UI is usable without tooltips."},"622":{"id":"/docs/components/tooltip-22","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#best-practices","content":"Do not place interactive content inside tooltips. Use a `Popover` instead."},"623":{"id":"/docs/components/chart/axis-title","page_id":"/docs/components/chart/axis-title","type":"page","content":"AxisTitle","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/axis-title"},"624":{"id":"/docs/components/chart/axis-title-0","page_id":"/docs/components/chart/axis-title","tags":[],"type":"text","url":"/docs/components/chart/axis-title","content":"The AxisTitle is an internal component used for displaying axis titles in chart components"},"625":{"id":"/docs/components/chart/axis-title-1","page_id":"/docs/components/chart/axis-title","type":"heading","tags":[],"url":"/docs/components/chart/axis-title#internal-component","content":"Internal Component"},"626":{"id":"/docs/components/chart/axis-title-2","page_id":"/docs/components/chart/axis-title","type":"heading","tags":[],"url":"/docs/components/chart/axis-title#props","content":"Props"},"627":{"id":"/docs/components/chart/axis-title-3","page_id":"/docs/components/chart/axis-title","type":"heading","tags":[],"url":"/docs/components/chart/axis-title#examples","content":"Examples"},"628":{"id":"/docs/components/chart/axis-title-4","page_id":"/docs/components/chart/axis-title","type":"heading","tags":[],"url":"/docs/components/chart/axis-title#x-axis-title","content":"X-Axis Title"},"629":{"id":"/docs/components/chart/axis-title-5","page_id":"/docs/components/chart/axis-title","type":"heading","tags":[],"url":"/docs/components/chart/axis-title#y-axis-title","content":"Y-Axis Title"},"630":{"id":"/docs/components/chart/axis-title-6","page_id":"/docs/components/chart/axis-title","type":"heading","tags":[],"url":"/docs/components/chart/axis-title#rtl","content":"RTL"},"631":{"id":"/docs/components/chart/axis-title-7","page_id":"/docs/components/chart/axis-title","tags":[],"type":"text","url":"/docs/components/chart/axis-title#internal-component","content":"This component is **internal-only** and not exported from the package. It is designed for use within chart components."},"632":{"id":"/docs/components/chart/axis-title-8","page_id":"/docs/components/chart/axis-title","tags":[],"type":"text","url":"/docs/components/chart/axis-title#props","content":"The `AxisTitle` component accepts the following props:"},"633":{"id":"/docs/components/chart/axis-title-9","page_id":"/docs/components/chart/axis-title","tags":[],"type":"text","url":"/docs/components/chart/axis-title#x-axis-title","content":"X-axis title with default orientation."},"634":{"id":"/docs/components/chart/axis-title-10","page_id":"/docs/components/chart/axis-title","tags":[],"type":"text","url":"/docs/components/chart/axis-title#y-axis-title","content":"Y-axis title with default orientation."},"635":{"id":"/docs/components/chart/axis-title-11","page_id":"/docs/components/chart/axis-title","tags":[],"type":"text","url":"/docs/components/chart/axis-title#rtl","content":"The axis title follows the current **layout direction** (LTR or RTL). By default, that direction is detected automatically from the browser or system settings, so the title stays aligned with the page."},"636":{"id":"/docs/components/chart/donut-chart","page_id":"/docs/components/chart/donut-chart","type":"page","content":"DonutChart","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/donut-chart"},"637":{"id":"/docs/components/chart/donut-chart-0","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart","content":"Donut charts are for parts-to-whole comparison—how partial elements add up to a total—shown as a ring so a few categories are easy to compare at a glance."},"638":{"id":"/docs/components/chart/donut-chart-1","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#installation","content":"Installation"},"639":{"id":"/docs/components/chart/donut-chart-2","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#props","content":"Props"},"640":{"id":"/docs/components/chart/donut-chart-3","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#examples","content":"Examples"},"641":{"id":"/docs/components/chart/donut-chart-4","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#basic","content":"Basic"},"642":{"id":"/docs/components/chart/donut-chart-5","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#single-slice","content":"Single slice"},"643":{"id":"/docs/components/chart/donut-chart-6","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#legend-placement","content":"Legend placement"},"644":{"id":"/docs/components/chart/donut-chart-7","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#small-slices","content":"Small slices"},"645":{"id":"/docs/components/chart/donut-chart-8","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#format-value","content":"Format value"},"646":{"id":"/docs/components/chart/donut-chart-9","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#basic","content":"You give the chart a `data` array (`id`, `name`, `value`) and a `label` in the middle—this is the everyday setup when you want several categories on one ring and a headline number or title in the hole."},"647":{"id":"/docs/components/chart/donut-chart-10","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#single-sl