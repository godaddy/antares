t","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`balance` is most commonly used for headlines, titles, and labels."},"583":{"id":"/docs/components/text-17","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`pretty` is most commonly used for body text."},"584":{"id":"/docs/components/text-18","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`stable` is commonly used for editable text, such as textareas."},"585":{"id":"/docs/components/text-field","page_id":"/docs/components/text-field","type":"page","content":"TextField","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/text-field"},"586":{"id":"/docs/components/text-field-0","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field","content":"TextField is a single-line or multiline text input with optional label, description, and error message. Use it in forms for short answers (email, search, name) or longer content (comments). It supports optional leading and trailing text adornments (e.g. currency or units)."},"587":{"id":"/docs/components/text-field-1","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#features","content":"Features"},"588":{"id":"/docs/components/text-field-2","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#installation","content":"Installation"},"589":{"id":"/docs/components/text-field-3","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#props","content":"Props"},"590":{"id":"/docs/components/text-field-4","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#examples","content":"Examples"},"591":{"id":"/docs/components/text-field-5","page_id":"/docs/components/text-field","type":"heading","tags":[],"