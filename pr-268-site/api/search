ggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#rtl-direction","content":"RTL Direction"},"1114":{"id":"/docs/components/toggle-button-13","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#customization","content":"Customization"},"1115":{"id":"/docs/components/toggle-button-14","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#data-attributes","content":"Data Attributes"},"1116":{"id":"/docs/components/toggle-button-15","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#component-customization","content":"Component Customization"},"1117":{"id":"/docs/components/toggle-button-16","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#accessibility","content":"Accessibility"},"1118":{"id":"/docs/components/toggle-button-17","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#keyboard-navigation","content":"Keyboard Navigation"},"1119":{"id":"/docs/components/toggle-button-18","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#aria-support","content":"ARIA Support"},"1120":{"id":"/docs/components/toggle-button-19","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#troubleshooting","content":"Troubleshooting"},"1121":{"id":"/docs/components/toggle-button-20","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#selection-not-updating","content":"Selection Not Updating"},"1122":{"id":"/docs/components/toggle-button-21","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#styling-overrides-not-applying","content":"Styling Overrides Not Applying"},"1123":{"id":"/docs/components/toggle-button-22","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#keyboard-navigation-not-working","content":"Keyboard Navigation Not Working"},"1124":{"id":"/docs/components/toggle-button-23","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#best-practices","content":"Best Practices"},"1125":{"id":"/docs/components/toggle-button-24","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#when-to-use","content":"When to Use"},"1126":{"id":"/docs/components/toggle-button-25","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#keep-variants-consistent","content":"Keep Variants Consistent"},"1127":{"id":"/docs/components/toggle-button-26","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#balance-label-lengths","content":"Balance Label Lengths"},"1128":{"id":"/docs/components/toggle-button-27","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#alignment","content":"Alignment"},"1129":{"id":"/docs/components/toggle-button-28","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#label-guidelines","content":"Label Guidelines"},"1130":{"id":"/docs/components/toggle-button-29","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#icon-only-items","content":"Icon-Only Items"},"1131":{"id":"/docs/components/toggle-button-30","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#default-single-selection","content":"A `ToggleButton` toggles between selected and unselected. Wrap multiple inside a `ToggleButtonGroup` to link them with shared selection and keyboard navigation — `defaultSelectedKeys` sets the initial selection."},"1132":{"id":"/docs/components/toggle-button-31","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#multiple-selection","content":"Use `selectionMode=\"multiple\"` to allow more than one item to be active at a time."},"1133":{"id":"/docs/components/toggle-button-32","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#controlled","content":"Use `selectedKeys` and `onSelectionChange` to control selection from parent state — `onSelectionChange` receives a `Set<string>` of the selected item `id` values."},"1134":{"id":"/docs/components/toggle-button-33","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#disabled-states","content":"Disable the entire group with `isDisabled` on the container, or disable individual items with `isDisabled` on specific `ToggleButton` elements."},"1135":{"id":"/docs/components/toggle-button-34","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#sizes","content":"Two sizes are available: `sm` and `md` (default)."},"1136":{"id":"/docs/components/toggle-button-35","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#icon--text","content":"Items can include an `Icon` alongside text for added visual context."},"1137":{"id":"/docs/components/toggle-button-36","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#icon-only","content":"For compact layouts, items can contain only icons. Padding adjusts automatically to keep the button square — no extra prop required. Always provide an `aria-label` on each icon-only item so screen readers can identify the action."},"1138":{"id":"/docs/components/toggle-button-37","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#with-dropdown","content":"Wrap a `ToggleButton` in a `MenuTrigger` to add sub-options to a group item."},"1139":{"id":"/docs/components/toggle-button-38","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#rtl-direction","content":"The group follows the document's layout direction, detected automatically from the browser locale."},"1140":{"id":"/docs/components/toggle-button-39","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#data-attributes","content":"Components automatically add data attributes for styling different states:"},"1141":{"id":"/docs/components/toggle-button-40","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#data-attributes","content":"**ToggleButtonGroup Container:** `data-size`"},"1142":{"id":"/docs/components/toggle-button-41","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#data-attributes","content":"**ToggleButton Item:** `data-selected`, `data-hovered`, `data-pressed`, `data-focus-visible`, `data-disabled`"},"1143":{"id":"/docs/components/toggle-button-42","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#component-customization","content":"Individual components can be styled by passing `className` props:"},"1144":{"id":"/docs/components/toggle-button-43","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Key"},"1145":{"id":"/docs/components/toggle-button-44","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Action"},"1146":{"id":"/docs/components/toggle-button-45","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Tab**"},"1147":{"id":"/docs/components/toggle-button-46","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Moves focus to/from the button group (single tab stop)"},"1148":{"id":"/docs/components/toggle-button-47","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Arrow Left / Right**"},"1149":{"id":"/docs/components/toggle-button-48","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Move focus between items (RAC automatically reverses in RTL)"},"1150":{"id":"/docs/components/toggle-button-49","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Space / Enter**"},"1151":{"id":"/docs/components/toggle-button-50","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Toggle the focused item"},"1152":{"id":"/docs/components/toggle-button-51","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Home**"},"1153":{"id":"/docs/components/toggle-button-52","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Move focus to the first item"},"1154":{"id":"/docs/components/toggle-button-53","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**End**"},"1155":{"id":"/docs/components/toggle-button-54","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Move focus to the last item"},"1156":{"id":"/docs/components/toggle-button-55","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"`selectionMode=\"single\"` → `role=\"radiogroup\"` on container, `role=\"radio\"` + `aria-checked` per item"},"1157":{"id":"/docs/components/toggle-button-56","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"`selectionMode=\"multiple\"` → `role=\"toolbar\"` on container, `role=\"button\"` + `aria-pressed` per item"},"1158":{"id":"/docs/components/toggle-button-57","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"`aria-label` (or `aria-labelledby`) is required on the group container"},"1159":{"id":"/docs/components/toggle-button-58","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"Icon-only items require `aria-label` on each `ToggleButton`"},"1160":{"id":"/docs/components/toggle-button-59","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"✅ For grouped contextual actions — two or more closely related actions that belong together (e.g. Bold / Italic / Underline, Align Left / Center / Right)"},"1161":{"id":"/docs/components/toggle-button-60","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"✅ For compact action grouping — related actions in space-constrained layouts (e.g. Undo / Redo, Zoom In / Out / Reset)"},"1162":{"id":"/docs/components/toggle-button-61","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"✅ For multi-select scenarios — when users need to select multiple options simultaneously"},"1163":{"id":"/docs/components/toggle-button-62","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ For unrelated actions that perform disconnected tasks without shared context"},"1164":{"id":"/docs/components/toggle-button-63","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ For more than 5 choices — cognitive overload; consider a **Select** instead"},"1165":{"id":"/docs/components/toggle-button-64","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ When actions require strong visual distinction (e.g. Save vs. Delete)"},"1166":{"id":"/docs/components/toggle-button-65","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ When selecting an option leads to a different page or workflow — use navigation instead"},"1167":{"id":"/docs/components/toggle-button-66","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ For mutually exclusive content views (e.g. Monthly / Yearly) — use **SegmentedController** instead"},"1168":{"id":"/docs/components/toggle-button-67","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keep-variants-consistent","content":"Avoid mixing different content types (text-only, icon-only, icon+text) within the same group. Mixing styles creates visual noise and makes the set feel fragmented rather than unified."},"1169":{"id":"/docs/components/toggle-button-68","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#balance-label-lengths","content":"Keep button labels of similar length. Large differences in text length cause irregular button widths and make the group appear uneven. Prefer short, concise wording."},"1170":{"id":"/docs/components/toggle-button-69","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"Align the group to reflect its relationship to surrounding content:"},"1171":{"id":"/docs/components/toggle-button-70","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Left** — when the group controls content directly below or within the same column (dashboards, tables)."},"1172":{"id":"/docs/components/toggle-button-71","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Center** — when the group acts as a prominent toggle affecting an entire section or page."},"1173":{"id":"/docs/components/toggle-button-72","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Right** — when the group represents utility or contextual controls (e.g. grid/list view toggle)."},"1174":{"id":"/docs/components/toggle-button-73","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#label-guidelines","content":"Use **title case**: capitalize the first letter of each word, except short prepositions."},"1175":{"id":"/docs/components/toggle-button-74","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#label-guidelines","content":"Keep labels to one or two words. Omit articles (a, an, the) and filler words."},"1176":{"id":"/docs/components/toggle-button-75","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#label-guidelines","content":"Prefer action-focused or descriptive language that communicates the option instantly."},"1177":{"id":"/docs/components/toggle-button-76","page_id":"/docs/components/toggle-b