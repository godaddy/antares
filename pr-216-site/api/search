ocs-4","page_id":"/docs","type":"heading","tags":[],"url":"/docs#nextjs","content":"Next.js"},"7":{"id":"/docs-5","page_id":"/docs","type":"heading","tags":[],"url":"/docs#remix","content":"Remix"},"8":{"id":"/docs-6","page_id":"/docs","type":"heading","tags":[],"url":"/docs#vite","content":"Vite"},"9":{"id":"/docs-7","page_id":"/docs","type":"heading","tags":[],"url":"/docs#other-bundlers","content":"Other Bundlers"},"10":{"id":"/docs-8","page_id":"/docs","type":"heading","tags":[],"url":"/docs#components","content":"Components"},"11":{"id":"/docs-9","page_id":"/docs","tags":[],"type":"text","url":"/docs","content":"Documentation | Storybook"},"12":{"id":"/docs-10","page_id":"/docs","tags":[],"type":"text","url":"/docs#quick-start","content":"Install the package:"},"13":{"id":"/docs-11","page_id":"/docs","tags":[],"type":"text","url":"/docs#quick-start","content":"Import and use a component:"},"14":{"id":"/docs-12","page_id":"/docs","tags":[],"type":"text","url":"/docs#per-component-imports","content":"Each component is available as a standalone entry point. This lets your bundler load only the JavaScript and CSS for the components you use:"},"15":{"id":"/docs-13","page_id":"/docs","tags":[],"type":"text","url":"/docs#per-component-imports","content":"This also works with autocomplete in IDEs and LLMs, so you can import from the root package and let your editor/agent suggest the available components."},"16":{"id":"/docs-14","page_id":"/docs","tags":[],"type":"text","url":"/docs#framework-setup","content":"Antares ships CSS alongside its JavaScript modules. Each component chunk imports a corresponding `.css` file (e.g., `import './src-BZhWcxqJ.css'`). Most bundlers handle this automatically, but some frameworks need extra configuration to process CSS imports from `node_modules`."},"17":{"id":"/docs-15","page_id":"/docs","tags":[],"type":"text","url":"/docs#nextjs","content":"Add `@godaddy/antares` to `transpilePackages` so Next.js processes the package through its own CSS pipeline instead of treating it as a pre-built external:"},"18":{"id":"/docs-16","page_id":"/docs","tags":[],"type":"text","url":"/docs#nextjs","content":"Without this, Next.js will throw:"},"19":{"id":"/docs-17","page_id":"/docs","tags":[],"type":"text","url":"/docs#remix","content":"Remix with Vite handles CSS imports from `node_modules` in the client bundle automatically. However, during SSR, Vite treats `node_modules` as externals by default, which bypasses CSS processing. Add `@godaddy/antares` to `ssr.noExternal` to fix this:"},"20":{"id":"/docs-18","page_id":"/docs","tags":[],"type":"text","url":"/docs#vite","content":"Vite processes CSS imports from `node_modules` out of the box. No additional configuration is needed for client-side SPAs."},"21":{"id":"/docs-19","page_id":"/docs","tags":[],"type":"text","url":"/docs#vite","content":"If you are using Vite with SSR (e.g., custom SSR setup, not Remix), add `@godaddy/antares` to `ssr.noExternal` as shown in the Remix section."},"22":{"id":"/docs-20","page_id":"/docs","tags":[],"type":"text","url":"/docs#other-bundlers","content":"Any bundler that supports CSS imports will work with Antares. If your bundler does not process CSS imports from `node_modules` by default, ensure it is configured to do so. For example, with raw webpack you may need `css-loader` configured to handle `.css` files from `node_modules`."},"23":{"id":"/docs/components/alert","page_id":"/docs/components/alert","type":"page","content":"Alert","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/alert"},"24":{"id":"/docs/components/alert-0","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert","content":"In-page alerts are non-intrusive notifications within a webpage, providing users with timely information or feedback without disrupting their experience."},"25":{"id":"/docs/components/alert-1","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#