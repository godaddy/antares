er time or along a continuous scale."},"1375":{"id":"/docs/components/chart/line-chart-81","page_id":"/docs/components/chart/line-chart","tags":[],"type":"text","url":"/docs/components/chart/line-chart#when-to-use-linechart","content":"Use when comparing a few series (e.g. 2–5 lines); avoid too many overlapping lines."},"1376":{"id":"/docs/components/chart/line-chart-82","page_id":"/docs/components/chart/line-chart","tags":[],"type":"text","url":"/docs/components/chart/line-chart#when-to-use-linechart","content":"Prefer a single chart with a legend over multiple small charts when comparing the same X range."},"1377":{"id":"/docs/components/layout/box","page_id":"/docs/components/layout/box","type":"page","content":"Box","breadcrumbs":["Docs","Components","Layout"],"tags":[],"url":"/docs/components/layout/box"},"1378":{"id":"/docs/components/layout/box-0","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box","content":"Polymorphic layout component providing consistent spacing, elevation, rounding, and self-alignment"},"1379":{"id":"/docs/components/layout/box-1","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#installation","content":"Installation"},"1380":{"id":"/docs/components/layout/box-2","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#props","content":"Props"},"1381":{"id":"/docs/components/layout/box-3","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#scale-sizes","content":"Scale Sizes"},"1382":{"id":"/docs/components/layout/box-4","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#examples","content":"Examples"},"1383":{"id":"/docs/components/layout/box-5","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#padding","content":"Padding"},"1384":{"id":"/docs/