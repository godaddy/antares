ocs/components/tooltip-20","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#best-practices","content":"Keep tooltip content short and informative."},"994":{"id":"/docs/components/tooltip-21","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#best-practices","content":"Tooltips are not shown on touch screen interactions. Ensure your UI is usable without tooltips."},"995":{"id":"/docs/components/tooltip-22","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip#best-practices","content":"Do not place interactive content inside tooltips. Use a `Popover` instead."},"996":{"id":"/docs/components/chart/donut-chart","page_id":"/docs/components/chart/donut-chart","type":"page","content":"DonutChart","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/donut-chart"},"997":{"id":"/docs/components/chart/donut-chart-0","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart","content":"Donut charts are for parts-to-whole comparison—how partial elements add up to a total—shown as a ring so a few categories are easy to compare at a glance."},"998":{"id":"/docs/components/chart/donut-chart-1","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#installation","content":"Installation"},"999":{"id":"/docs/components/chart/donut-chart-2","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#props","content":"Props"},"1000":{"id":"/docs/components/chart/donut-chart-3","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#examples","content":"Examples"},"1001":{"id":"/docs/components/chart/donut-chart-4","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#basic","content":"Basic"},"1002":{"id":"/docs/components/chart/donut-chart-5","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#single-slice","content":"Single slice"},"1003":{"id":"/docs/components/chart/donut-chart-6","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#legend-placement","content":"Legend placement"},"1004":{"id":"/docs/components/chart/donut-chart-7","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#small-slices","content":"Small slices"},"1005":{"id":"/docs/components/chart/donut-chart-8","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#format-value","content":"Format value"},"1006":{"id":"/docs/components/chart/donut-chart-9","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#basic","content":"You give the chart a `data` array (`id`, `name`, `value`) and a `label` in the middle—this is the everyday setup when you want several categories on one ring and a headline number or title in the hole."},"1007":{"id":"/docs/components/chart/donut-chart-10","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#single-slice","content":"When there is only one slice, the ring is full. Add `subLabel` if you want a smaller second line under the main center text."},"1008":{"id":"/docs/components/chart/donut-chart-11","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#legend-placement","content":"Switch `legend` to `right` to sit the legend beside the donut, or `bottom` to stack it underneath. `legendLabel` is there when you want a title above the legend items."},"1009":{"id":"/docs/components/chart/donut-chart-12","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#small-slices","content":"Very thin slices can be noisy to hover. Anything at or below `smallSliceThreshold` (default `0.05` of the total) is treated as “small,” and if those slices sit next to each other on the ring, one hover opens a single tooltip that lists the whole group."},"1010":{"id":"/docs/components/chart/donut-chart-13","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#format-value","content":"Use `formatValue` when the raw numbers in the tooltip should read like money, counts with separators, or whatever your product expects. The percentage of the total still formats on its own; your function only shapes the value column."},"1011":{"id":"/docs/components/chart/bar-chart","page_id":"/docs/components/chart/bar-chart","type":"page","content":"Bar Chart","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/bar-chart"},"1012":{"id":"/docs/components/chart/bar-chart-0","page_id":"/docs/components/chart/bar-chart","tags":[],"type":"text","url":"/docs/components/chart/bar-chart","content":"A flexible, accessible, and design-aligned data visualization solution for displaying single or multi-series bar charts."},"1013":{"id":"/docs/components/chart/bar-chart-1","page_id":"/docs/components/chart/bar-chart","type":"heading","tags":[],"url":"/docs/components/chart/bar-chart#features","content":"Features"},"1014":{"id":"/docs/components/chart/bar-chart-2","page_id":"/docs/components/chart/bar-chart","type":"heading","tags":[],"url":"/docs/components/chart/bar-chart#installation","content":"Installation"},"1015":{"id":"/docs/components/chart/bar-chart-3","page_id":"/docs/components/chart/bar-chart","type":"heading","tags":[],"url":"/docs/components/chart/bar-chart#props","content":"Props"},"1016":{"id":"/docs/components/chart/bar-chart-4","page_id":"/do