":"heading","tags":[],"url":"/docs/components/icon#decorative-icons","content":"Decorative Icons"},"347":{"id":"/docs/components/icon-29","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#semantic-icons","content":"Semantic Icons"},"348":{"id":"/docs/components/icon-30","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#interactive-icons","content":"Interactive Icons"},"349":{"id":"/docs/components/icon-31","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#performance-considerations","content":"Performance Considerations"},"350":{"id":"/docs/components/icon-32","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#default-icon-loading","content":"Default Icon Loading"},"351":{"id":"/docs/components/icon-33","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#sprite-mode-optimization","content":"Sprite Mode Optimization"},"352":{"id":"/docs/components/icon-34","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#recommendations","content":"Recommendations"},"353":{"id":"/docs/components/icon-35","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#troubleshooting","content":"Troubleshooting"},"354":{"id":"/docs/components/icon-36","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#icon-not-loading","content":"Icon Not Loading"},"355":{"id":"/docs/components/icon-37","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#performance-issues","content":"Performance Issues"},"356":{"id":"/docs/components/icon-38","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon","content":"The `Icon` component provides a flexible and performant way to display SVG icons with extensive customization options. Built on top of the Bento Icon system, it features on-demand loading from a CDN, automatic caching, and enhanced props for the Antares design system."},"357":{"id":"/docs/components/icon-39","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**On-demand loading**: Icons are loaded asynchronously from CDN only when needed"},"358":{"id":"/docs/components/icon-40","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Automatic caching**: Once loaded, icons are cached for optimal performance"},"359":{"id":"/docs/components/icon-41","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Flexible sizing**: Support for `width` and `height` props"},"360":{"id":"/docs/components/icon-42","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Color inheritance**: Uses `currentColor` by default for seamless theme integration"},"361":{"id":"/docs/components/icon-43","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Accessibility ready**: Built-in support for screen readers and keyboard navigation"},"362":{"id":"/docs/components/icon-44","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**TypeScript support**: Fully typed with comprehensive prop interfaces"},"363":{"id":"/docs/components/icon-45","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Bento integration**: Extends Bento Icon with additional Antares-specific features"},"364":{"id":"/docs/components/icon-46","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#props","content":"The `Icon` component accepts the following props:"},"365":{"id":"/docs/components/icon-47","page_id":"/docs/components/icon","t