{
  "name": "antares-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "nx run-many -t build",
    "changeset": "changeset",
    "clean": "nx reset && npm exec --workspaces -- npx rimraf node_modules dist && npx rimraf node_modules",
    "commitlint": "commitlint --edit",
    "deps:check": "syncpack list-mismatches && knip --reporter=symbols",
    "deps:fix": "syncpack fix-mismatches",
    "format": "biome check",
    "format:package": "syncpack format",
    "lint": "nx run-many -t lint",
    "postinstall": "npm run build",
    "prepare": "husky",
    "release": "npm run build && changeset publish",
    "site": "nx run site:dev",
    "site:build": "nx run site:build",
    "storybook": "nx run docs:storybook",
    "test": "nx run-many -t test",
    "test:visual": "nx run-many -t test:visual",
    "test:visual:update": "nx run-many -t test:visual:update",
    "typecheck": "nx run-many -t typecheck",
    "version": "changeset version && npm install"
  },
  "homepage": "https://github.com/godaddy/antares/tree/main",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@changesets/cli": "^2.29.8",
    "@changesets/get-github-info": "^0.8.0",
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@nx/storybook": "^22.6.4",
    "@nx/vite": "^22.6.4",
    "@nx/vitest": "^22.4.5",
    "@react-types/shared": "^3.32.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/css-modules": "^1.0.5",
    "@types/dashify": "^1.0.3",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.10.12",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "assume": "^2.3.0",
    "browserslist-to-esbuild": "^2.1.1",
    "esbuild": "^0.27.5",
    "husky": "^9.1.7",
    "knip": "^5.80.0",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.22.0",
    "nx": "22.6.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-frame-component": "^5.2.7",
    "rimraf": "^6.1.2",
    "syncpack": "^13.0.4",
    "tsdown": "^0.21.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24"
    },
    "packageManager": {
      "name": "npm",
      "version": "11"
    }
  },
  "engines": {
    "node": ">=24.12",
    "npm": ">=11"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css}": [
      "biome lint --write --error-on-warnings",
      "biome format --write"
    ],
    "{,!(.agents|.claude|.cursor)/**/}*.{md,mdx}": [
      "markdownlint-cli2 --fix"
    ]
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/@bento/*",
    "packages/@godaddy/*",
    "packages/dev/*"
  ]
}
