{
  "name": "bento",
  "private": true,
  "version": "0.0.0",
  "homepage": "https://github.com/godaddy/bento/tree/main",
  "scripts": {
    "build": "turbo build",
    "postinstall": "npm run build",
    "clean": "npm exec --workspaces -- npx rimraf node_modules && npx rimraf node_modules",
    "format": "biome check",
    "lint": "biome lint",
    "prepare": "husky",
    "test": "turbo test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@microsoft/api-extractor": "^7.50.0",
    "@types/node": "^22.10.7",
    "assume": "^2.3.0",
    "browserslist-to-esbuild": "^2.1.1",
    "c8": "^10.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "biome lint --fix",
      "biome format --fix",
      "git add"
    ]
  }
}
