{
  "name": "bento",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "turbo build",
    "clean": "npm exec --workspaces -- npx rimraf node_modules .turbo dist && npx rimraf node_modules .turbo",
    "deps:check": "syncpack list-mismatches && knip --reporter=symbols",
    "deps:fix": "syncpack fix-mismatches",
    "format": "biome check",
    "format:package": "syncpack format",
    "lint": "turbo lint",
    "postinstall": "turbo telemetry disable && npm run build",
    "prepare": "husky",
    "test": "turbo test",
    "test:root": "vitest",
    "test:visual": "playwright test -c playwright-ct.config.ts",
    "changeset": "changeset",
    "version": "changeset version && npm install",
    "release": "npm run build && changeset publish"
  },
  "homepage": "https://github.com/godaddy/bento/tree/main",
  "devDependencies": {
    "@bento/storybook-addon-helpers": "file:./packages/storybook-addon-helpers",
    "@bento/types": "file:./packages/types",
    "@biomejs/biome": "^2.3.1",
    "@changesets/cli": "^2.29.7",
    "@changesets/get-github-info": "^0.6.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@microsoft/api-extractor": "^7.53.3",
    "@playwright/experimental-ct-react": "^1.56.1",
    "@react-types/shared": "^3.32.1",
    "@storybook/react": "^9.1.15",
    "@storybook/react-vite": "^9.1.15",
    "@testing-library/user-event": "^14.6.1",
    "@types/css-modules": "^1.0.5",
    "@types/dashify": "^1.0.3",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.9.1",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.0.7",
    "assume": "^2.3.0",
    "browserslist-to-esbuild": "^2.1.1",
    "esbuild": "^0.25.11",
    "husky": "^9.1.7",
    "knip": "^5.66.3",
    "lint-staged": "^16.2.6",
    "playwright": "^1.50.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-frame-component": "^5.2.7",
    "rimraf": "^6.0.1",
    "syncpack": "^13.0.4",
    "tsup": "^8.5.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.7",
    "vitest-browser-react": "^1.0.1"
  },
  "engines": {
    "node": ">=23",
    "npm": ">=10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json}": [
      "biome lint --write",
      "biome format --write"
    ]
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
