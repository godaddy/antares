{
  "name": "bento",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "nx run-many -t build",
    "clean": "npm exec --workspaces -- npx rimraf node_modules dist && npx rimraf node_modules",
    "deps:check": "syncpack list-mismatches && knip --reporter=symbols",
    "deps:fix": "syncpack fix-mismatches",
    "format": "biome check",
    "format:package": "syncpack format",
    "lint": "nx run-many -t lint",
    "postinstall": "npm run build",
    "prepare": "husky",
    "start": "npm run storybook --workspace=docs",
    "test": "npm run test:ci && npm run test:scripts",
    "test:ci": "nx run-many -t test",
    "test:root": "vitest",
    "test:scripts": "vitest run --config scripts/test/vitest.config.ts",
    "test:visual": "playwright test -c playwright-ct.config.ts",
    "changeset": "changeset",
    "version": "changeset version && npm install",
    "release": "npm run build && changeset publish"
  },
  "homepage": "https://github.com/godaddy/bento/tree/main",
  "devDependencies": {
    "@bento/storybook-addon-helpers": "file:./packages/storybook-addon-helpers",
    "@bento/types": "file:./packages/types",
    "@biomejs/biome": "^2.3.9",
    "@changesets/cli": "^2.29.7",
    "@changesets/get-github-info": "^0.7.0",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@microsoft/api-extractor": "^7.55.2",
    "@playwright/experimental-ct-react": "^1.56.1",
    "@react-types/shared": "^3.32.1",
    "@storybook/react": "^10.1.9",
    "@storybook/react-vite": "^10.1.9",
    "@testing-library/user-event": "^14.6.1",
    "@types/css-modules": "^1.0.5",
    "@types/dashify": "^1.0.3",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.0.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "assume": "^2.3.0",
    "browserslist-to-esbuild": "^2.1.1",
    "esbuild": "^0.27.1",
    "husky": "^9.1.7",
    "knip": "^5.74.0",
    "lint-staged": "^16.2.6",
    "nx": "22.2.6",
    "playwright": "^1.50.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-frame-component": "^5.2.7",
    "rimraf": "^6.0.1",
    "syncpack": "^13.0.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.1",
    "vitest": "^4.0.16",
    "vitest-browser-react": "^2.0.2"
  },
  "engines": {
    "node": ">=23",
    "npm": ">=10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json}": [
      "biome lint --write",
      "biome format --write"
    ]
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
