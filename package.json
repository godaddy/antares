{
  "name": "antares-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "nx run-many -t build --no-tui",
    "changeset": "changeset",
    "clean": "nx reset && npm exec --workspaces -- npx rimraf node_modules dist && npx rimraf node_modules",
    "commitlint": "commitlint --edit",
    "deps:check": "syncpack lint && knip --reporter=symbols",
    "deps:fix": "syncpack fix",
    "format": "biome check",
    "format:package": "syncpack format",
    "lint": "nx run-many -t lint --no-tui",
    "postinstall": "npx playwright install --with-deps && npm run build",
    "prepare": "husky",
    "release": "npm run build && changeset publish",
    "site": "nx run site:dev --no-tui",
    "site:build": "nx run site:build --no-tui",
    "storybook": "nx run docs:storybook --no-tui",
    "test": "nx run-many -t test --no-tui",
    "test:visual": "nx run-many -t test:visual --no-tui",
    "test:visual:update": "nx run-many -t test:visual:update --no-tui",
    "typecheck": "nx run-many -t typecheck --no-tui",
    "version": "changeset version && npm install"
  },
  "homepage": "https://github.com/godaddy/antares/tree/main",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "@changesets/get-github-info": "^0.8.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@nx/storybook": "^22.7.5",
    "@nx/vite": "^22.7.5",
    "@nx/vitest": "^22.7.5",
    "@rollup/plugin-replace": "^6.0.3",
    "@testing-library/user-event": "^14.6.1",
    "@tsdown/css": "^0.22.2",
    "@types/css-modules": "^1.0.5",
    "@types/dashify": "^1.0.3",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "assume": "^2.3.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "knip": "^6.16.0",
    "lint-staged": "^17.0.5",
    "markdownlint-cli2": "^0.22.1",
    "nx": "22.7.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-frame-component": "^5.3.2",
    "rimraf": "^6.1.3",
    "syncpack": "^15.3.1",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24"
    },
    "packageManager": {
      "name": "npm",
      "version": "11"
    }
  },
  "engines": {
    "node": ">=24.12",
    "npm": ">=11"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css}": [
      "biome lint --write --error-on-warnings",
      "biome format --write"
    ],
    "{,!(.agents|.claude|.codex|.cursor|.opencode)/**/}*.{md,mdx}": [
      "markdownlint-cli2 --fix"
    ]
  },
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "packages/@bento/*",
    "packages/@godaddy/*",
    "packages/dev/*"
  ]
}
