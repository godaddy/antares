{
  "name": "bento",
  "private": true,
  "version": "0.0.0",
  "homepage": "https://github.com/godaddy/bento/tree/main",
  "scripts": {
    "build": "turbo build",
    "postinstall": "npm run build",
    "clean": "npm exec --workspaces -- npx rimraf node_modules .turbo dist && npx rimraf node_modules .turbo",
    "format": "biome check",
    "lint": "turbo lint",
    "prepare": "husky",
    "test": "turbo test",
    "test:root": "vitest",
    "test:visual": "playwright test -c playwright-ct.config.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@microsoft/api-extractor": "^7.52.2",
    "@playwright/experimental-ct-react": "^1.51.1",
    "@types/dashify": "^1.0.3",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.13.13",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-istanbul": "^3.0.9",
    "@vitest/coverage-v8": "^3.0.9",
    "@vitest/ui": "^3.0.7",
    "assume": "^2.3.0",
    "browserslist-to-esbuild": "^2.1.1",
    "c8": "^10.1.3",
    "esbuild": "^0.25.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "playwright": "^1.50.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "5.8.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "biome lint --fix",
      "biome format --fix"
    ]
  }
}
