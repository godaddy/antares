{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "../../configs/*.json",
        "../../configs/*.mjs",
        "../../configs/*.mts"
      ],
      "outputs": [".next/**", "!.next/cache/**", "storybook-static/**", "dist"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.tsx",
        "src/**/*.ts",
        "test/**/*.js",
        "test/**/*.ts",
        "examples/**/*.tsx",
        "examples/**/*.ts"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
