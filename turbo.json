{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "../../configs/*.json",
        "../../configs/*.mjs",
        "../../configs/*.mts",
        "../../biome.json",
        "../../.grit/**/*"
      ],
      "outputs": [".next/**", "!.next/cache/**", "storybook-static/**", "dist"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.tsx",
        "src/**/*.ts",
        "test/**/*.js",
        "test/**/*.ts",
        "examples/**/*.tsx",
        "examples/**/*.ts",
        "../../scripts/**/*.ts",
        "../../scripts/**/*.tsx",
        "tsconfig*.json",
        "vitest.config.*",
        "../../biome.json",
        "../../.grit/**/*"
      ]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.{js,jsx,ts,tsx}",
        "test/**/*.{js,jsx,ts,tsx}",
        "examples/**/*.{js,jsx,ts,tsx}",
        "*.{js,jsx,ts,tsx}",
        "tsconfig*.json",
        "biome.json",
        ".grit/**/*",
        "../../biome.json",
        "../../.grit/**/*"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
