l","content":"Dismiss button label"},"36":{"id":"/docs/components/alert-12","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#best-practices","content":"Best Practices"},"37":{"id":"/docs/components/alert-13","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#basic-usage","content":"A minimal alert with a title and body text."},"38":{"id":"/docs/components/alert-14","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#emphasis-variants","content":"All 7 emphasis categories. Each variant carries a distinct visual accent and semantic icon so the type of message is never communicated by color alone."},"39":{"id":"/docs/components/alert-15","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#dismissible","content":"When an `onClose` callback is provided, a dismiss button is rendered. The component does not manage its own visibility — the parent is responsible for unmounting or hiding the alert when `onClose` fires."},"40":{"id":"/docs/components/alert-16","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#with-action","content":"Pass a `Button` to the `actions` slot to give the user a clear path to resolve the alert."},"41":{"id":"/docs/components/alert-17","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#keyboard","content":"Key"},"42":{"id":"/docs/components/alert-18","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#keyboard","content":"Description"},"43":{"id":"/docs/components/alert-19","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#keyboard","content":"`Tab`"},"44":{"id":"/docs/components/alert-20","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#keyboard","content":"Moves focus to the dismiss button or action button"}