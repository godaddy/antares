-17","page_id":"/docs/components/button","tags":[],"type":"text","url":"/docs/components/button#primary","content":"The primary button should be used to indicate the most important action for the user to take in their current experience."},"73":{"id":"/docs/components/button-18","page_id":"/docs/components/button","tags":[],"type":"text","url":"/docs/components/button#secondary","content":"The secondary button indicates an action of secondary importance."},"74":{"id":"/docs/components/button-19","page_id":"/docs/components/button","tags":[],"type":"text","url":"/docs/components/button#critical","content":"The critical button signifies to the user a destructive action will take place."},"75":{"id":"/docs/components/button-20","page_id":"/docs/components/button","tags":[],"type":"text","url":"/docs/components/button#minimal","content":"The minimal button is an icon-only button that's used when space is limited and/or when the action is universally understood."},"76":{"id":"/docs/components/button-21","page_id":"/docs/components/button","tags":[],"type":"text","url":"/docs/components/button#icon","content":"You may provide an optional `Icon` element to the button. If you do not include text, you must provide an aria-label attribute to identify the purpose of the button. This will produce a square button."},"77":{"id":"/docs/components/carousel","page_id":"/docs/components/carousel","type":"page","content":"Carousel","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/carousel"},"78":{"id":"/docs/components/carousel-0","page_id":"/docs/components/carousel","tags":[],"type":"text","url":"/docs/components/carousel","content":"The Carousel component allows users to cycle through a series of content panels (typically images, cards, or text) in a horizontal or vertical layout. It is commonly used for featured content, product showcases, or testimonials."},"79":{"id":"/docs/components/carousel-1","page_id":"/docs/components/carousel","type":"heading","tags":