page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Auto-generated step numbers (opt out with `hideStepNumbers`)"},"653":{"id":"/docs/components/progress-steps-21","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Interactive (navigable) and inert (display-only) steps"},"654":{"id":"/docs/components/progress-steps-22","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Title truncation and RTL support"},"655":{"id":"/docs/components/progress-steps-23","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Rendered as a `<nav>` landmark with an ordered list for assistive technology"},"656":{"id":"/docs/components/progress-steps-24","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#props","content":"`ProgressSteps` is the container; its direct children must be `ProgressStep` elements."},"657":{"id":"/docs/components/progress-steps-25","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#default","content":"A horizontal stepper. `currentStep` marks the active step; earlier steps are `past`, later are `future`. Each `status` sets the step's icon, and an `error` step turns its accent bar red."},"658":{"id":"/docs/components/progress-steps-26","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#not-started","content":"Omit `currentStep` for a flow that hasn't begun: every step is `future` and none is marked current."},"659":{"id":"/docs/components/progress-steps-27","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#vertical","content":"Use `orientation=\"vertical\"` to place the accent bar on the leading edge and stack steps in a column."},"660":{"id":"/docs/components/progress-steps-28","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#interactive","content":"Give a step an `onPress` handler to make it navigable. Steps without `onPress` are inert."},"661":{"id":"/docs/components/progress-steps-29","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#disabled","content":"A disabled interactive step is muted, removed from the tab order, and cannot be activated."},"662":{"id":"/docs/components/progress-steps-30","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#hide-step-numbers","content":"Step numbers are prepended automatically. Set `hideStepNumbers` to omit them."},"663":{"id":"/docs/components/progress-steps-31","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"Step numbers (`\"N. \"`) are prepended automatically — keep them where possible, as user testing shows people recognize the component better with them. Set `hideStepNumbers` to omit them."},"664":{"id":"/docs/components/progress-steps-32","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"`orientation` switches between `horizontal` (accent bar on top) and `vertical` (accent bar on the leading edge)."},"665":{"id":"/docs/components/progress-steps-33","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"`currentStep` is the single source of truth for the timeline. Omit it for a not-yet-started flow where every step is `future`; pass the step count for a fully completed flow where every step is `past`."},"666":{"id":"/docs/components/progress-steps-34","pa