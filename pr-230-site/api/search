onents/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#props","content":"The `Box` component accepts the following props:"},"1246":{"id":"/docs/components/layout/box-15","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"The spacing props use semantic t-shirt sizes for padding, gap, and other spacing properties:"},"1247":{"id":"/docs/components/layout/box-16","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xs` - Extra small spacing"},"1248":{"id":"/docs/components/layout/box-17","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`sm` - Small spacing"},"1249":{"id":"/docs/components/layout/box-18","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`md` - Medium spacing"},"1250":{"id":"/docs/components/layout/box-19","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`lg` - Large spacing"},"1251":{"id":"/docs/components/layout/box-20","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xl` - Extra large spacing"},"1252":{"id":"/docs/components/layout/box-21","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`2xl` - 2x extra large spacing"},"1253":{"id":"/docs/components/layout/box-22","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"Custom CSS values are also supported for edge cases."},"1254":{"id":"/docs/components/layout/box-23","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#padding","content":"The padding props support