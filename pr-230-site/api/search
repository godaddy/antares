cs/components/chart/gauge-chart-20","page_id":"/docs/components/chart/gauge-chart","tags":[],"type":"text","url":"/docs/components/chart/gauge-chart#value-out-of-range","content":"Values outside the valid range are clamped silently at runtime. For continuous mode the range is 0–100; for segmented mode the range is 0 to the segment count."},"1131":{"id":"/docs/components/chart/donut-chart","page_id":"/docs/components/chart/donut-chart","type":"page","content":"DonutChart","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/donut-chart"},"1132":{"id":"/docs/components/chart/donut-chart-0","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart","content":"Donut charts are for parts-to-whole comparison—how partial elements add up to a total—shown as a ring so a few categories are easy to compare at a glance."},"1133":{"id":"/docs/components/chart/donut-chart-1","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#installation","content":"Installation"},"1134":{"id":"/docs/components/chart/donut-chart-2","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#props","content":"Props"},"1135":{"id":"/docs/components/chart/donut-chart-3","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#examples","content":"Examples"},"1136":{"id":"/docs/components/chart/donut-chart-4","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#basic","content":"Basic"},"1137":{"id":"/docs/components/chart/donut-chart-5","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#single-slice","content":"Single slice"},"1138":{"id":"/docs/components/chart/donut-chart-6","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#legend-placement","content":"Legend placement"},"1139":{"id":"/docs/components/chart/donut-chart-7","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#small-slices","content":"Small slices"},"1140":{"id":"/docs/components/chart/donut-chart-8","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#format-value","content":"Format value"},"1141":{"id":"/docs/components/chart/donut-chart-9","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#basic","content":"You give the chart a `data` array (`id`, `name`, `value`) and a `label` in the middle—this is the everyday setup when you want several categories on one ring and a headline number or title in the hole."},"1142":{"id":"/docs/components/chart/donut-chart-10","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#single-slice","content":"When there is only one slice, the ring is full. Add `subLabel` if you want a smaller second line under the main center text."},"1143":{"id":"/docs/components/chart/donut-chart-11","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#legend-placement","content":"Switch `legend` to `right` to sit the legend beside the donut, or `bottom` to stack it underneath. `legendLabel` is there when you want a title above the legend items."},"1144":{"id":"/docs/components/chart/donut-chart-12","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#small-slices","content":"Very thin slices can be noisy to hover. Anything at or below `smallSliceThreshold` (default `0.05` of the total) is treated as “small,” and if those slices sit next to each other on the ring, one hover opens a single tooltip that lists the whole group."},"1145":{"id":"/docs/components/chart/donut-chart-13","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#format-value","content":"Use `formatValue` when the raw numbers in the tooltip should read like money, counts with separators, or whatever your product expects. The percentage of the total still formats on its own; your function only shapes the value column."},"1146":{"id":"/docs/components/chart/line-chart","page_id":"/docs/components/chart/line-chart","type":"page","content":"LineChart","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/line-chart"},"1147":{"id":"/docs/components/chart/line-chart-0","page_id":"/docs/components/chart/line-chart","tags":[],"type":"text","url":"/docs/components/chart/line-chart","content":"Line Chart shows how something changes over time or along a continuous scale. It connects data points with lines so people can quickly spot trends, peaks, dips, and patterns."},"1148":{"id":"/docs/components/chart/line-chart-1","page_id":"/docs/components/chart/line-chart","type":"heading","tags":[],"url":"/docs/components/chart/line-chart#installation","content":"Installation"},"1149":{"id":"/docs/components/chart/line-chart-2","page_id":"/docs/components/chart/line-chart","type":"heading","tags":[],"url":"/docs/components/chart/line-chart#props","content":"Props"},"1150":{"id":"/docs/components/chart/line-chart-3","page_id":"/docs/components/chart/line-chart","type":"heading","tags":[],"url":"/docs/components/chart/line-chart#examples","content":"Examples"},"1151":{"id":"/docs/components/chart/line-chart-4","page_id":"/docs/components/chart/line-chart","type":"heading","tags":[],"url":"/docs/components/chart/line-chart#basic","content":"Basic"},"1152":{"id":"/docs/components/chart/line-chart-5","page_id":"/docs/components/chart/line-chart","type":"heading","tags":[],"url":"/docs/components/ch