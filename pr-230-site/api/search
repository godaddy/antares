s/components/tag-12","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#screen-readers","content":"Screen readers"},"750":{"id":"/docs/components/tag-13","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#decorative-icons","content":"Decorative icons"},"751":{"id":"/docs/components/tag-14","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#indicator-dot","content":"Indicator dot"},"752":{"id":"/docs/components/tag-15","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#best-practices","content":"Best Practices"},"753":{"id":"/docs/components/tag-16","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#when-to-use","content":"When to Use"},"754":{"id":"/docs/components/tag-17","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#when-not-to-use","content":"When Not to Use"},"755":{"id":"/docs/components/tag-18","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#basic","content":"A minimal tag with the default emphasis and size."},"756":{"id":"/docs/components/tag-19","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#emphasis","content":"Nine emphasis options are available. Choose the one that fits the visual tone of your context."},"757":{"id":"/docs/components/tag-20","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#sizes","content":"Choose a size that fits the surrounding content. Smaller tags work well in compact layouts like tables; larger tags suit headings or hero sections."},"758":{"id":"/docs/components/tag-21","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#inline","content":"Use `design=\"inline\"` to embed a tag within a sentence. The background and border are removed so the tag blends into the text flow."},"759":{"id":"/docs/components/tag-22","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#high-contrast","content":"A bolder color treatment for when tags need to stand out more — for example, on colored backgrounds."},"760":{"id":"/docs/components/tag-23","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#with-icon","content":"Icons reinforce the tag's meaning at a glance. Add an `Icon` as a child — it inherits the tag's color and scales with its size."},"761":{"id":"/docs/components/tag-24","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#indicator","content":"A minimal style that pairs a small colored dot with a neutral background. Well suited for dense layouts like tables or dashboards where multiple tags in close proximity would otherwise compete for attention."},"762":{"id":"/docs/components/tag-25","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#screen-readers","content":"Tags are `<span>` elements with no special ARIA role. Screen readers announce the tag's text as part of normal page content — no extra markup is needed."},"763":{"id":"/docs/components/tag-26","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#decorative-icons","content":"Icons passed as children must include `aria-hidden=\"true\"` so they are skipped by screen readers. The text label is the sole carrier of meaning."},"764":{"id":"/docs/components/tag-27","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#indicator-dot","content":"The colored dot is decorative and invisible to screen readers. The text label must convey the status on its own — never rely on the dot alone to communicate meaning."},"765":{"id":"/docs/components/tag-28","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Use the indicator style in dense layouts like tables and dashboards. Use the filled style when the tag is a prominent, standalone element on a card or hero section."},"766":{"id":"/docs/components/tag-29","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Default to the small size in compact layouts like tables and lists. Use medium or large only when the tag needs to stand out as a primary piece of information."},"767":{"id":"/docs/components/tag-30","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Use the inline design only within running prose. In grouped or standalone contexts, the filled style provides better visual separation."},"768":{"id":"/docs/components/tag-31","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Do not stack multiple tags of different emphasis on the same item. Choose the most important one — too many competing labels lose their meaning."},"769":{"id":"/docs/components/tag-32","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Showing the status of an item on a card, table row, or list entry (e.g. \"Active\", \"Expired\", \"Pending\")"},"770":{"id":"/docs/components/tag-33","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Categorizing or grouping content so users can scan and filter quickly (e.g. \"New\", \"Sale\", \"Beta\")"},"771":{"id":"/docs/components/tag-34","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Surfacing metadata about an item (e.g. \"Pro\", \"Free trial\", \"Internal\")"},"772":{"id":"/docs/components/tag-35","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Communicating priority or category in project management and collaboration tools (e.g. \"High priority\", \"In review\")"},"773":{"id":"/docs/components/tag-36","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-not-to-use","content":"If users need to click or dismiss it — use a **Button** instead."},"774":{"id":"/docs/components/tag-37","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-not-to-use","content":"If the label is part of a sentence with no visual distinction — just use text."},"775":{"id":"/docs/components/text","page_id":"/docs/components/text","type":"page","content":"Text","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/text"},"776":{"id":"/docs/components/text-0","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text","content":"Text component for displaying and formatting text content with alignment and truncation options"},"777":{"id":"/docs/components/text-1","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#installation","content":"Installation"},"778":{"id":"/docs/components/text-2","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#props","content":"Props"},"779":{"id":"/docs/components/text-3","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#examples","content":"Examples"},"780":{"id":"/docs/components/text-4","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#as","content":"As"},"781":{"id":"/docs/components/text-5","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#align","content":"Align"},"782":{"id":"/docs/components/text-6","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#max-lines","content":"Max Lines"},"783":{"id":"/docs/components/text-7","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#wrap","content":"Wrap"},"784":{"id":"/docs/components/text-8","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text","content":"The `Text` component prepares content with a few properties."},"785":{"id":"/docs/components/text-9","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#props","content":"The `Text` component accepts the following props:"},"786":{"id":"/docs/components/text-10","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#as","content":"Setting the `as` prop allows you to change the HTML tag of the `Text` component."},"787":{"id":"/docs/components/text-11","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#align","content":"Setting the `align` prop allows you to change the alignment of the text. You can choose from `start`, `center`, `end`, or `justify`.\n`start` works like `left` and `end` works like `right`. These keywords support RTL languages so you do not need to worry about the language of the text."},"788":{"id":"/docs/components/text-12","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#max-lines","content":"Setting the `maxLines` prop allows you to limit the number of lines of text that are displayed using an ellipsis. In browsers that don't support multiline text truncation using `line-clamp`, the text will be truncated after a single line regardless of the number provided for `maxLines`."},"789":{"id":"/docs/components/text-13","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"Setting the `wrap` prop allows you to change the wrapping of the text. The values can be `wrap`, `nowrap`, `balance`, `pretty`, or `stable`."},"790":{"id":"/docs/components/text-14","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`wrap` is the setting that is most commonly used. For most elements you will not to explicitly set this."},"791":{"id":"/docs/components/text-15","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`nowrap` should be avoided except in cases where it is important to prevent the text from wrapping."},"792":{"id":"/docs/components/text-16","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`balance` is most commonly used for headlines, titles, and labels."},"793":{"id":"/docs/components/text-17","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`pretty` is most commonly used for body text."},"794":{"id":"/docs/components/text-18","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`stable` is commonly used for editable text, such as textareas."},"795":{"id":"/docs/components/text-field","page_id":"/docs/components/text-field","type":"page","content":"TextField","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/text-field"},"796":{"id":"/docs/components/text-field-0","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field","content":"TextField is a single-line or multiline text input with optional label, description, and error message. Use it in forms for short answers (email, search, name) or longer content (comments). It supports optional leading and trailing text adornments (e.g. currency or units)."},"797":{"id":"/docs/components/text-field-1","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#features","content":"Features"},"798":{"id":"/docs/components/text-field-2","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#installation","content":"Installation"},"799":{"id":"/docs/components/text-field-3","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/com