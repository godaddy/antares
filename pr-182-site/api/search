eries using design token CSS variables. Safe under React concurrent rendering."},"1058":{"id":"/docs/components/chart/use-chart-color-1","page_id":"/docs/components/chart/use-chart-color","type":"heading","tags":[],"url":"/docs/components/chart/use-chart-color#for-use-with-chart-components-not-exported","content":"For use with chart components (not exported)"},"1059":{"id":"/docs/components/chart/use-chart-color-2","page_id":"/docs/components/chart/use-chart-color","type":"heading","tags":[],"url":"/docs/components/chart/use-chart-color#props","content":"Props"},"1060":{"id":"/docs/components/chart/use-chart-color-3","page_id":"/docs/components/chart/use-chart-color","type":"heading","tags":[],"url":"/docs/components/chart/use-chart-color#examples","content":"Examples"},"1061":{"id":"/docs/components/chart/use-chart-color-4","page_id":"/docs/components/chart/use-chart-color","type":"heading","tags":[],"url":"/docs/components/chart/use-chart-color#single-series","content":"Single series"},"1062":{"id":"/docs/components/chart/use-chart-color-5","page_id":"/docs/components/chart/use-chart-color","type":"heading","tags":[],"url":"/docs/components/chart/use-chart-color#multiple-series","content":"Multiple series"},"1063":{"id":"/docs/components/chart/use-chart-color-6","page_id":"/docs/components/chart/use-chart-color","tags":[],"type":"text","url":"/docs/components/chart/use-chart-color#for-use-with-chart-components-not-exported","content":"Wrap your chart (or list) with `ChartColorProvider`; each component that calls `useChartColor()` receives a CSS variable reference. Indices are assigned in an effect at mount, so allocation is safe under React concurrent rendering and StrictMode. Same component instance keeps the same color; colors cycle after the ninth consumer. No need to pass an index—order in the tree determines assignment."},"1064":{"id":"/docs/components/chart/use-chart-color-7","page_id":"/docs/components/chart/use-chart-color","tags":[],"type":"text","url":"/docs/components/chart/use-chart-color#single-series","content":"One series using the first chart color."},"1065":{"id":"/docs/components/chart/use-chart-color-8","page_id":"/docs/components/chart/use-chart-color","tags":[],"type":"text","url":"/docs/components/chart/use-chart-color#multiple-series","content":"Multiple series each receiving the next color in sequence."},"1066":{"id":"/docs/components/chart/use-normalized-series","page_id":"/docs/components/chart/use-normalized-series","type":"page","content":"useNormalizedSeries","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/use-normalized-series"},"1067":{"id":"/docs/components/chart/use-normalized-series-0","page_id":"/docs/components/chart/use-normalized-series","tags":[],"type":"text","url":"/docs/components/chart/use-normalized-series","content":"A hook that ensures every series config has a stable unique id, generating one from useId when omitted."},"1068":{"id":"/docs/components/chart/use-normalized-series-1","page_id":"/docs/components/chart/use-normalized-series","type":"heading","tags":[],"url":"/docs/components/chart/use-normalized-series#for-use-with-chart-components-not-exported","content":"For use with chart components (not exported)"},"1069":{"id":"/docs/components/chart/use-normalized-series-2","page_id":"/docs/components/chart/use-normalized-series","tags":[],"type":"text","url":"/docs/components/chart/use-normalized-series#for-use-with-chart-components-not-exported","content":"Accepts a `SeriesConfig[]` array and returns a memoized copy where each item is guaranteed to have an `id`. When an item has no `id`, one is generated using a component-scoped prefix from React's `useId`, ensuring IDs are unique across multiple chart instances on the same page. Existing `id` values are preserved as-is."},"1070":{"id":"/docs/components/chart/tooltip","page_id":"/docs/components/chart/tooltip","type":"page","content":"Tooltip","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/tooltip"},"1071":{"id":"/docs/components/chart/tooltip-0","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip","content":"An internal component used for displaying tooltip information in chart components."},"1072":{"id":"/docs/components/chart/tooltip-1","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#features","content":"Features"},"1073":{"id":"/docs/components/chart/tooltip-2","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#internal-component","content":"Internal Component"},"1074":{"id":"/docs/components/chart/tooltip-3","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#props","content":"Props"},"1075":{"id":"/docs/components/chart/tooltip-4","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#value-formatting","content":"Value formatting"},"1076":{"id":"/docs/components/chart/tooltip-5","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#examples","content":"Examples"},"1077":{"id":"/docs/components/chart/tooltip-6","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#single-series","content":"Single Series"},"1078":{"id":"/docs/components/chart/tooltip-7","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#multiple-series","content":"Multiple Series"},"1079":{"id":"/docs/components/chart/tooltip-8","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#arrow","content":"Arrow"},"1080":{"id":"/docs/components/chart/tooltip-9","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#features","content":"**Multiple series**: Shows all series that have a datum at the hovered X position in a single tooltip."},"1081":{"id":"/docs/components/chart/tooltip-10","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#features","content":"**Series matching**: Rows are built from `series` by matching `series[].id` to keys in `tooltipData.datumByKey` (from visx at the hovered X)."},"1082":{"id":"/docs/components/chart/tooltip-11","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#features","content":"**Value formatting**: You can supply a function to format each value; if you don't, the tooltip shows the point's `y` (or nothing when null). Use the formatter for custom data shapes."},"1083":{"id":"/docs/components/chart/tooltip-12","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#internal-component","content":"This component is **internal-only** and not exported from the package. It is intended for use inside chart components."},"1084":{"id":"/docs/components/chart/tooltip-13","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#props","content":"The `Tooltip` component accepts the following props:"},"1085":{"id":"/docs/components/chart/tooltip-14","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#value-formatting","content":"**Default:** When `formatValue` is not provided, the tooltip uses a formatter that reads the data point’s `y` property (same as the chart's default Y accessor), converts it to a string, and returns an empty string for null. This is correct for the default `DataPoint` shape (`{ x, y }`)."},"1086":{"id":"/docs/components/chart/tooltip-15","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#value-formatting","content":"**Custom:** Pass `formatValue` to control display. The function receives the datum and returns a string. Use it to both extract and format (e.g. currency, percentage, custom units). For custom data point shapes (generic `TooltipProps<YourDatum>`), you must pass `formatValue` because the default only reads `y`."},"1087":{"id":"/docs/components/chart/tooltip-16","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#single-series","content":"Basic tooltip with a single series and default formatting."},"1088":{"id":"/docs/components/chart/tooltip-17","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#multiple-series","content":"Tooltip with multiple series; all series at the same X position are shown together."},"1089":{"id":"/docs/components/chart/tooltip-18","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#arrow","content":"Use the `showArrow` prop to set whether the tooltip arrow is visible or not."},"1090":{"id":"/docs/components/chart/use-scrollable-xy-chart","page_id":"/docs/components/chart/use-scrollable-xy-chart","type":"page","content":"useScrollableXYChart","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/use-scrollable-xy-chart"},"1091":{"id":"/docs/components/chart/use-scrollable-xy-chart-0","page_id":"/docs/components/chart/use-scrollable-xy-chart","tags":[],"type":"text","url":"/docs/components/chart/use-scrollable-xy-chart","content":"A hook for scrollable visx XY charts that measures the rendered axes and returns margins, content-sized width and height, scroll offsets, and a vertical-labels flag, so the chart sizes itself to whatever it actually contains."},"1092":{"id":"/docs/components/chart/use-scrollable-xy-chart-1","page_id":"/docs/components/chart/use-scrollable-xy-chart","type":"heading","tags":[],"url":"/docs/components/chart/use-scrollable-xy-chart#for-use-with-chart-components-not-exported","content":"For use with chart components (not exported)"},"1093":{"id":"/docs/components/chart/use-scrollable-xy-chart-2","page_id":"/docs/components/chart/use-scrollable-xy-chart","type":"heading","tags":[],"url":"/docs/components/chart/use-scrollable-xy-chart#examples","content":"Examples"},"1094":{"id":"/docs/components/chart/use-scrollable-xy-chart-3","page_id":"/docs/components/chart/use-scrollable-xy-chart","type":"heading","tags":[],"url":"/docs/components/chart/use-scrollable-xy-chart#auto-layout","content":"Auto layout"},"1095":{"id":"/docs/components/chart/use-scrollable-xy-chart-4","page_id":"/docs/components/chart/use-scrollable-xy-chart","tags":[],"type":"text","url":"/docs/components/chart/use-scrollable-xy-chart#for-use-with-chart-components-not-exported","content":"**Inputs.** Wire `parentRef` to the scroll container and `xAxisRef` / `yAxisRef` to the axis groups. Optionally pass `xLabelsOrientation` (`'auto'` | `'horizontal'` | `'vertical'`, default `'auto'`) to force the category-label layout; `'auto'` rotates labels vertical when the visible width can't fit the horizontal-tick footprint plus the Y-axis width."},"1096":{"id":"/docs/components/chart/use-scrollable-xy-chart-5","page_id":"/docs/components/chart/use-scrollable-xy-chart","tags":[],"type":"text","url":"/docs/components/chart/use-scrollable-xy-chart#for-use-with-chart-components-not-exported","content":"**Outputs.** The hook returns `margin`, `chartWidth`, `chartHeight`, `xLabelsVertical`, `scrollLeft` / `scrollTop`, and `yAxisRect` for the chart to consume. Width and height are sized to whichever is larger — the visible slot or the room the rendered labels need — so the chart grows past the viewport and the parent scrolls when labels demand more space."},"1097":{"id":"/docs/components/chart/use-scrollable-xy-chart-6","page_id":"/docs/components/chart/use-scrollable-xy-chart","tags":[],"type":"text","url":"/docs/components/chart/use-scrollable-xy-chart#for-use-with-chart-components-not-exported","content":"**Behavior.** Measurement runs through `useParentSize`, a `MutationObserver`, and a `ResizeObserver` on the wired nodes. All axis measurements are batched in one `requestAnimationFrame` and bail out when the result hasn't changed, so a burst of observer fires costs at most one reflow and one render per frame."},"1098":{"id":"/docs/components/chart/use-scrollable-xy-chart-7","page_id":"/docs/components/chart/use-scrollable-xy-chart","tags":[],"type":"text","url":"/docs/components/chart/use-scrollable-xy-chart#auto-layout","content":"Hook wired to a scrolling parent; scroll or resize to watch the returned values update."},"1099":{"id":"/docs/components/layout/box","page_id":"/docs/components/layout/box","type":"page","content":"Box","breadcrumbs":["Docs","Components","Layout"],"tags":[],"url":"/docs/components/layout/box"},"1100":{"id":"/docs/components/layout/box-0","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box","content":"Polymorphic layout component providing consistent spacing, elevation, rounding, and self-alignment"},"1101":{"id":"/docs/components/layout/box-1","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#installation","content":"Installation"},"1102":{"id":"/docs/components/layout/box-2","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#props","content":"Props"},"1103":{"id":"/docs/components/layout/box-3","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#scale-sizes","content":"Scale Sizes"},"1104":{"id":"/docs/components/layout/box-4","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#examples","content":"Examples"},"1105":{"id":"/docs/components/layout/box-5","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#padding","content":"Padding"},"1106":{"id":"/docs/components/layout/box-6","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#elevation","content":"Elevation"},"1107":{"id":"/docs/components/layout/box-7","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#rounding","content":"Rounding"},"1108":{"id":"/docs/components/layout/box-8","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#polymorphic-as-prop","content":"Polymorphic `as` Prop"},"1109":{"id":"/docs/components/layout/box-9","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#alignment","content":"Alignment"},"1110":{"id":"/docs/components/layout/box-10","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#rtl-support","content":"RTL Support"},"1111":{"id":"/docs/components/layout/box-11","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#design-tokens","content":"Design Tokens"},"1112":{"id":"/docs/components/layout/box-12","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box","content":"Box is a polymorphic layout component that renders as any HTML element or custom component via the `as` prop. It provides consistent spacing, elevation, rounding, and self-alignment within flex or grid containers."},"1113":{"id":"/docs/components/layout/box-13","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box","content":"**Important**: Since `Flex` and `Grid` extend `Box`, prefer them for layouts. Use `Box` only when you need a non-flex, non-grid container."},"1114":{"id":"/docs/components/layout/box-14","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#props","content":"The `Box` component accepts the following props:"},"1115":{"id":"/docs/components/layout/box-15","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"The spacing props use semantic t-shirt sizes for padding, gap, and other spacing properties:"},"1116":{"id":"/docs/components/layout/box-16","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xs` - Extra small spacing"},"1117":{"id":"/docs/components/layout/box-17","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`sm` - Small spacing"},"1118":{"id":"/docs/components/layout/box-18","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`md` - Medium spacing"},"1119":{"id":"/docs/components/layout/box-19","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`lg` - Large spacing"},"1120":{"id":"/docs/components/layout/box-20","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xl` - Extra large spacing"},"1121":{"id":"/docs/components/layout/box-21","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`2xl` - 2x extra large spacing"},"1122":{"id":"/docs/components/layout/box-22","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"Custom CSS values are also supported for edge cases."},"1123":{"id":"/docs/components/layout/box-23","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#padding","content":"The padding props support t-shirt sizes and CSS logical properties for RTL support."},"1124":{"id":"/docs/components/layout/box-24","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#elevation","content":"The elevation prop adds visual depth using box-shadow."},"1125":{"id":"/docs/components/layout/box-25","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#rounding","content":"The rounding prop sets border-radius. Use `full` for fully rounded corners."},"1126":{"id":"/docs/components/layout/box-26","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"Box is fully polymorphic - the `as` prop allows rendering as any HTML element or custom component while preserving type-safe props."},"1127":{"id":"/docs/components/layout/box-27","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**HTML Elements:** When using `as=\"button\"`, TypeScript enforces button-specific props like `type`, `disabled`, and `onClick`."},"1128":{"id":"/docs/components/layout/box-28","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**Custom Components:** When using `as={MyComponent}`, Box accepts that component's props. If there's a prop name conflict, Box's props take priority."},"1129":{"id":"/docs/components/layout/box-29","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**Typed Refs:** Refs are correctly typed based on the `as` value - `useRef<HTMLButtonElement>` works with `as=\"button\"`."},"1130":{"id":"/docs/components/layout/box-30","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#alignment","content":"Self-alignment props allow Box to position itself within flex or grid containers."},"1131":{"id":"/docs/components/layout/box-31","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#rtl-support","content":"Box uses CSS logical properties (`padding-inline-start`, `padding-block-end`, etc.) which automatically adapt to RTL layouts. No additional configuration is needed."},"1132":{"id":"/docs/components/layout/box-32","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#design-tokens","content":"All spacing, elevation, and rounding values are derived from the theme. If no theme is provided, default values are used. This ensures consistency across the design system."},"1133":{"id":"/docs/components/layout/flex","page_id":"/docs/components/layout/flex","type":"page","content":"Flex","breadcrumbs":["Docs","Components","Layout"],"tags":[],"url":"/docs/components/layout/flex"},"1134":{"id":"/docs/components/layout/flex-0","page_id":"/docs/components/layout/flex","tags":[],"type":"text","url":"/docs/components/layout/flex","content":"One-dimensional layout component for arranging children in rows or columns with alignment and spacing control"},"1135":{"id":"/docs/components/layout/flex-1","page_id":"/docs/components/layout/flex","type":"heading","tags":[],"url":"/docs/components/layout/flex#installation","content":"Installation"},"1136":{"id":"/docs/components/layout/flex-2","page_id":"/docs/components/layout/flex","type":"heading","tags":[],"url":"/docs/components/layout/flex#props","content":"Props"},"1137":{"id":"/docs/components/layout/flex-3","page_id":"/docs/components/layout/flex","type":"heading","tags":[],"url":"/docs/components/layout/flex#scale-sizes","content":"Scale Sizes"},"1138":{"id":"/docs/components/layout/flex-4","page_id":"/docs/components/layout/flex","type":"heading","tags":[],"url":"/docs/components/layout/flex#examples","content":"Examples"},"1139":{"id":"/docs/components/layout/flex-5","page_id":"/docs/components/layout/flex","type":"heading","tags":[],"url":"/docs/components/layout/flex#default","content