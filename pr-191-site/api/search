e-chart#tooltip-or-crosshair-not-showing","content":"Ensure `tooltip`, `showCrosshair`, or `showDataPoints` are not set to `false`, and that the chart receives pointer events (e.g. no overlay blocking hover)."},"990":{"id":"/docs/components/chart/line-chart-80","page_id":"/docs/components/chart/line-chart","tags":[],"type":"text","url":"/docs/components/chart/line-chart#when-to-use-linechart","content":"Use for trends over time or along a continuous scale."},"991":{"id":"/docs/components/chart/line-chart-81","page_id":"/docs/components/chart/line-chart","tags":[],"type":"text","url":"/docs/components/chart/line-chart#when-to-use-linechart","content":"Use when comparing a few series (e.g. 2–5 lines); avoid too many overlapping lines."},"992":{"id":"/docs/components/chart/line-chart-82","page_id":"/docs/components/chart/line-chart","tags":[],"type":"text","url":"/docs/components/chart/line-chart#when-to-use-linechart","content":"Prefer a single chart with a legend over multiple small charts when comparing the same X range."},"993":{"id":"/docs/components/chart/tooltip","page_id":"/docs/components/chart/tooltip","type":"page","content":"Tooltip","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/tooltip"},"994":{"id":"/docs/components/chart/tooltip-0","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip","content":"An internal component used for displaying tooltip information in chart components."},"995":{"id":"/docs/components/chart/tooltip-1","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#features","content":"Features"},"996":{"id":"/docs/components/chart/tooltip-2","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#internal-component","content":"Internal Component"},"997":{"id":"/docs/components/chart/tooltip-3","page_id":"/docs/components/chart/tooltip","type":"head