ntrol the active page externally."},"522":{"id":"/docs/components/pagination-11","page_id":"/docs/components/pagination","tags":[],"type":"text","url":"/docs/components/pagination#default-active-index","content":"Use `defaultActiveIndex` to set the starting page in uncontrolled mode."},"523":{"id":"/docs/components/pagination-12","page_id":"/docs/components/pagination","tags":[],"type":"text","url":"/docs/components/pagination#with-limit","content":"Limit the number of items shown per page. When `limit` is greater than 1, the number of pages (dots) is derived from `Math.ceil(total / limit)`. For example, 10 items with a limit of 3 produces 4 pages (dots)."},"524":{"id":"/docs/components/pagination-13","page_id":"/docs/components/pagination","tags":[],"type":"text","url":"/docs/components/pagination#onchange-event","content":"The `onChange` callback fires with the new page index whenever the user navigates."},"525":{"id":"/docs/components/popover","page_id":"/docs/components/popover","type":"page","content":"Popover","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/popover"},"526":{"id":"/docs/components/popover-0","page_id":"/docs/components/popover","tags":[],"type":"text","url":"/docs/components/popover","content":"The Popover component is an overlay element positioned relative to a trigger element."},"527":{"id":"/docs/components/popover-1","page_id":"/docs/components/popover","type":"heading","tags":[],"url":"/docs/components/popover#installation","content":"Installation"},"528":{"id":"/docs/components/popover-2","page_id":"/docs/components/popover","type":"heading","tags":[],"url":"/docs/components/popover#props","content":"Props"},"529":{"id":"/docs/components/popover-3","page_id":"/docs/components/popover","type":"heading","tags":[],"url":"/docs/components/popover#examples","content":"Examples"},"530":{"id":"/docs/components/popover-4","page_id":"/docs/components/popover","type":"heading","tags":[],"url":"/docs/components/popover#basic-us