ation**."},"1085":{"id":"/docs/components/layout/flex-19","page_id":"/docs/components/layout/flex","tags":[],"type":"text","url":"/docs/components/layout/flex#default","content":"Basic horizontal flex layout with gap."},"1086":{"id":"/docs/components/layout/flex-20","page_id":"/docs/components/layout/flex","tags":[],"type":"text","url":"/docs/components/layout/flex#direction","content":"The `direction` prop controls the main axis orientation."},"1087":{"id":"/docs/components/layout/flex-21","page_id":"/docs/components/layout/flex","tags":[],"type":"text","url":"/docs/components/layout/flex#alignment","content":"Use `justifyContent` for main-axis distribution and `alignItems` for cross-axis alignment."},"1088":{"id":"/docs/components/layout/flex-22","page_id":"/docs/components/layout/flex","tags":[],"type":"text","url":"/docs/components/layout/flex#gap","content":"The `gap` prop controls spacing between children. Use `rowGap` and `columnGap` for independent control."},"1089":{"id":"/docs/components/layout/flex-23","page_id":"/docs/components/layout/flex","tags":[],"type":"text","url":"/docs/components/layout/flex#wrap","content":"The `wrap` prop controls whether items wrap to multiple lines."},"1090":{"id":"/docs/components/layout/flex-24","page_id":"/docs/components/layout/flex","tags":[],"type":"text","url":"/docs/components/layout/flex#navbar","content":"A common navigation bar pattern using space-between and nested Flex containers."},"1091":{"id":"/docs/components/layout/flex-25","page_id":"/docs/components/layout/flex","tags":[],"type":"text","url":"/docs/components/layout/flex#sidebar","content":"A sidebar layout demonstrating Flex child props (`flexShrink`, `flexGrow`)."},"1092":{"id":"/docs/components/layout/flex-26","page_id":"/docs/components/layout/flex","tags":[],"type":"text","url":"/docs/components/layout/flex#rtl-support","content":"Flex uses CSS logical properties which automatically adapt to RTL layouts. The `direction` prop values (`row`, `row-rever