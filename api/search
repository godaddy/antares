:"DonutChart","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/donut-chart"},"926":{"id":"/docs/components/chart/donut-chart-0","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart","content":"Donut charts are for parts-to-whole comparison—how partial elements add up to a total—shown as a ring so a few categories are easy to compare at a glance."},"927":{"id":"/docs/components/chart/donut-chart-1","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#installation","content":"Installation"},"928":{"id":"/docs/components/chart/donut-chart-2","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#props","content":"Props"},"929":{"id":"/docs/components/chart/donut-chart-3","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#examples","content":"Examples"},"930":{"id":"/docs/components/chart/donut-chart-4","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#basic","content":"Basic"},"931":{"id":"/docs/components/chart/donut-chart-5","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#single-slice","content":"Single slice"},"932":{"id":"/docs/components/chart/donut-chart-6","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#legend-placement","content":"Legend placement"},"933":{"id":"/docs/components/chart/donut-chart-7","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#small-slices","content":"Small slices"},"934":{"id":"/docs/components/chart/donut-chart-8","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/d