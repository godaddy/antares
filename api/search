sing the drawer."},"223":{"id":"/docs/components/drawer-26","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#no-escape-dismiss","content":"Use `isKeyboardDismissDisabled` to prevent the drawer from being dismissed by the escape key."},"224":{"id":"/docs/components/drawer-27","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Key"},"225":{"id":"/docs/components/drawer-28","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Action"},"226":{"id":"/docs/components/drawer-29","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"`Escape`"},"227":{"id":"/docs/components/drawer-30","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Close the drawer (unless `isKeyboardDismissDisabled`)"},"228":{"id":"/docs/components/drawer-31","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"`Tab`"},"229":{"id":"/docs/components/drawer-32","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Move focus within the drawer (focus is trapped)"},"230":{"id":"/docs/components/drawer-33","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#aria","content":"`role=\"dialog\"` with `aria-modal=\"true\"` on the drawer panel (via RAC Modal)"},"231":{"id":"/docs/components/drawer-34","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#aria","content":"Dialog accessible name via `aria-label`"},"232":{"id":"/docs/components/drawer-35","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#aria","content":"`aria-label=\"Close\"` on the built-in close button"},"233":{"id":"/docs/components/drawer-36","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#best-practices","content":"Always provide an `aria-label` so the dialog has an accessible name."},"234":{"id":"/docs/components/drawer-37","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#best-practices","content":"Use `isDismissable` to allow closing via backdrop click."},"235":{"id":"/docs/components/drawer-38","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#best-practices","content":"Don't nest drawers."},"236":{"id":"/docs/components/drop-zone","page_id":"/docs/components/drop-zone","type":"page","content":"DropZone","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/drop-zone"},"237":{"id":"/docs/components/drop-zone-0","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone","content":"A standalone region that accepts drag-and-drop file interactions, rendering a clearly defined target area where users can drop files."},"238":{"id":"/docs/components/drop-zone-1","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#installation","content":"Installation"},"239":{"id":"/docs/components/drop-zone-2","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#props","content":"Props"},"240":{"id":"/docs/components/drop-zone-3","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#examples","content":"Examples"},"241":{"id":"/docs/components/drop-zone-4","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#basic-usage","content":"Basic Usage"},"242":{"id":"/docs/components/drop-zone-5","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#disabled","content":"Disabled"},"243":{"id":"/docs/components/drop-zone-6","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#file-upload","content":"File Upload"},"244":{"id":"/docs/components/drop-zone-7","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#drop-target-label","content":"Drop Target Label"},"245":{"id":"/docs/components/drop-zone-8","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#replace-existing-file","content":"Replace Existing File"},"246":{"id":"/docs/components/drop-zone-9","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#accessibility","content":"Accessibility"},"247":{"id":"/docs/components/drop-zone-10","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#keyboard","content":"Keyboard"},"248":{"id":"/docs/components/drop-zone-11","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#screen-readers","content":"Screen readers"},"249":{"id":"/docs/components/drop-zone-12","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#best-practices","content":"Best Practices"},"250":{"id":"/docs/components/drop-zone-13","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#basic-usage","content":"A minimal drop zone. The `onDrop` callback receives the dropped items; use the exported `isFileDropItem` guard to narrow them to files. Wrap the instructional text in `<Text slot=\"label\">` so it labels the visually hidden drop button for screen readers."},"251":{"id":"/docs/components/drop-zone-14","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#disabled","content":"Set `isDisabled` to prevent the drop zone from accepting interactions. The zone is dimmed and the cursor indicates it is not interactive."},"252":{"id":"/docs/components/drop-zone-15","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#file-upload","content":"A reference composition combining `DropZone` with `FileTrigger` to support both click-to-browse and drag-and-drop. Use this as a starting point and adapt the accepted formats, size limit, and handlers to your product's requirements."},"253":{"id":"/docs/components/drop-zone-16","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#drop-target-label","content":"Pass a render-prop function as `children` to change the zone's content while a valid drag is active. Branching on `isDropTarget` requires no extra state. Pair it with `getDropOperation` to reject unsupported types — the label only appears when the drag is accepted."},"254":{"id":"/docs/components/drop-zone-17","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#replace-existing-file","content":"Use `children` as a render function to show different content based on the current zone state — here, swapping the default label for \"Drop to replace\" when a file is already selected and a new drag is active. The same `onDrop` handler services both the drag path and the `FileTrigger` click path, so either gesture replaces the selection."},"255":{"id":"/docs/components/drop-zone-18","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"Key"},"256":{"id":"/docs/components/drop-zone-19","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"Description"},"257":{"id":"/docs/components/drop-zone-20","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"`Tab`"},"258":{"id":"/docs/components/drop-zone-21","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"Moves focus to the drop zone"},"259":{"id":"/docs/components/drop-zone-22","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"`Enter` / `Space`"},"260":{"id":"/docs/components/drop-zone-23","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"Opens the file picker so files can be selected without a pointer"},"261":{"id":"/docs/components/drop-zone-24","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#screen-readers","content":"The drop zone renders a visually hidden `<button>` inside the container. Assistive technology discovers and announces this button as an interactive element — activating it opens the native file picker without a pointer."},"262":{"id":"/docs/components/drop-zone-25","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#screen-readers","content":"The button's accessible name is built from two sources, combined in order:"},"263":{"id":"/docs/components/drop-zone-26","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#screen-readers","content":"**`<Text slot=\"label\">`** — any `Text` child with `slot=\"label\"` has its `id` linked to the button via `aria-labelledby`. This is the recommended way to provide a contextual label that is also visible to sighted users."},"264":{"id":"/docs/components/drop-zone-27","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#screen-readers","content":"**`aria-label`** — pass `aria-label` on the `DropZone` component to override or supplement the label (e.g. `aria-label=\"Upload profile photo\"`). When no `Text slot=\"label\"` is present and no `aria-label` is set, the button falls back to the default \"DropZone\" label provided by React Aria."},"265":{"id":"/docs/components/drop-zone-28","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#best-practices","content":"Use the drop zone alongside a button-based file picker — drag-and-drop is a convenience, never the only way to upload."},"266":{"id":"/docs/components/drop-zone-29","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#best-practices","content":"Replace the default text with `children` to communicate the accepted file types and size limits up front."},"267":{"id":"/docs/components/drop-zone-30","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#best-practices","content":"Let the drop zone fill its container; constrain it with the surrounding layout rather than setting a fixed width on the component itself."},"268":{"id":"/docs/components/drop-zone-31","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#best-practices","content":"Reflect upload state (validating, uploading, error) outside the drop zone so the target area stays clear and predictable."},"269":{"id":"/docs/components/field","page_id":"/docs/components/field","type":"page","content":"Field primitives","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/field"},"270":{"id":"/docs/components/field-0","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"Composable primitives (Field, FieldLabel, FieldGroup, FieldError) for building form fields"},"271":{"id":"/docs/components/field-1","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#usage","content":"Usage"},"272":{"id":"/docs/components/field-2","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#basic-example","content":"Basic example"},"273":{"id":"/docs/components/field-3","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#composition","content":"Composition"},"274":{"id":"/docs/components/field-4","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#positioning-controls-inside-the-group","content":"Positioning controls inside the group"},"275":{"id":"/docs/components/field-5","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#states","content":"States"},"276":{"id":"/docs/components/field-6","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#examples","content":"Examples"},"277":{"id":"/docs/components/field-7","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#leading-control","content":"Leading control"},"278":{"id":"/docs/components/field-8","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#trailing-control","content":"Trailing control"},"279":{"id":"/docs/components/field-9","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#icon-accessories","content":"Icon accessories"},"280":{"id":"/docs/components/field-10","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**Composition primitives.** The field components (TextField, NumberField, DateField, Select, RadioGroup, CheckboxGroup) compose these internally — reach for those first. These primitives are also the building blocks for custom composite fields, e.g. an input and a select sharing one bordered box."},"281":{"id":"/docs/components/field-11","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"The field decoration is split into granular, composable pieces so the same structure is shared across every field:"},"282":{"id":"/docs/components/field-12","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`Field`** — stacks a field's label, control, description, and error in one consistently spaced column (pure layout — a `Flex` column with the standard field gap)."},"283":{"id":"/docs/components/field-13","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldLabel`** — names the field and flags whether it's required (wraps React Aria `Label`, rendering an optional `*` indicator)."},"284":{"id":"/docs/components/field-14","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldGroup`** — the bordered box that visually unites a field's controls and reflects their shared focus, disabled, and invalid state. Used only by \"boxed\" fields (TextField, NumberField, Select, DateField); presentationally it is a React Aria `Group`."},"285":{"id":"/docs/components/field-15","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldInput`*&#x2A; / &#x2A;*`FieldTextArea`** — the control the user types into (normalized React Aria `Input`/`TextArea` given antares spacing via `Box`)."},"286":{"id":"/docs/components/field-16","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldButton`** — an actionable control placed inside the box, such as the NumberField steppers or a search submit (a click target within the group)."},"287":{"id":"/docs/components/field-17","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldDescription`** — helper text that explains the field; renders nothing when empty (wraps the antares `Text` with `slot=\"description\"`)."},"288":{"id":"/docs/components/field-18","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldError`** — surfaces the field's validation messages when it is invalid, and nothing when valid (a thin wrapper over React Aria `FieldError`)."},"289":{"id":"/docs/components/field-19","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"`FieldLabel`, `FieldDescription`, and `FieldError` each render `null` when they have no content, so callers pass `label` / `description` / `errorMessage` straight through without guarding."},"290":{"id":"/docs/components/field-20","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#usage","content":"The `FieldGroup` component has the following props:"},"291":{"id":"/docs/components/field-21","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"A boxed field composes the primitives inside its React Aria field wrapper. Use\n`Field as={...}` to merge the field wrapper and the layout column into a single\nelement:"},"292":{"id":"/docs/components/field-22","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"A field without a box (RadioGroup / CheckboxGroup) composes `Field` + `FieldLabel` + `FieldError` and omits `FieldGroup`."},"293":{"id":"/docs/components/field-23","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"`FieldGroup` is purely presentational — it renders the styled `Group` and holds no React Aria context. The surrounding field wires value, disabled, and validation state into its controls."},"294":{"id":"/docs/components/field-24","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#positioning-controls-inside-the-group","content":"`FieldGroup` rounds its outer corners from DOM order: the group's CSS rounds the start corners of its **first child** and the end corners of its **last child**, so controls are seamless inside and rounded only at the box edges. Author children in visual order and the rounding follows — no per-control positioning prop. A lone control (a TextField input, a Select trigger) is both first and last, so it rounds both edges. The rules are RTL-safe (they use logical `start`/`end` corners)."},"295":{"id":"/docs/components/field-25","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"The states **disabled**, **readonly**, and **invalid** are applied by the field wrapper (e.g. TextField, NumberField, Select). The group reflects them via data attributes on the group."},"296":{"id":"/docs/components/field-26","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"State"},"297":{"id":"/docs/components/field-27","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"CSS Selector"},"298":{"id":"/docs/components/field-28","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"disabled — Applied when the field wrapper is disabled."},"299":{"id":"/docs/components/field-29","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-disabled]`"},"300":{"id":"/docs/components/field-30","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"invalid — Applied when the field wrapper is invalid (e.g. validation failed)."},"301":{"id":"/docs/components/field-31","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-invalid]`"},"302":{"id":"/docs/components/field-32","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"focus — Whether an element within the group has keyboard focus (for focus-ring styling)."},"303":{"id":"/docs/components/field-33","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-focused]`"},"304":{"id":"/docs/components/file-trigger","page_id":"/docs/components/file-trigger","type":"page","content":"FileTrigger","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/file-trigger"},"305":{"id":"/docs/components/file-trigger-0","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger","content":"A style-less primitive that wraps any pressable component and opens the native file picker when it is activated."},"306":{"id":"/docs/components/file-trigger-1","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#features","content":"Features"},"307":{"id":"/docs/components/file-trigger-2","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#installation","content":"Installation"},"308":{"id":"/docs/components/file-trigger-3","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#props","content":"Props"},"309":{"id":"/docs/components/file-trigger-4","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#examples","content":"Examples"},"310":{"id":"/docs/components/file-trigger-5","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#basic-usage","content":"Basic Usage"},"311":{"id":"/docs/components/file-trigger-6","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#accepted-types","content":"Accepted Types"},"312":{"id":"/docs/components/file-trigger-7","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#accessibility","content":"Accessibility"},"313":{"id":"/docs/components/file-trigger-8","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#best-practices","content":"Best Practices"},"314":{"id":"/docs/components/file-trigger-9","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#features","content":"Turns any pressable component (such as an Antares `Button`) into a file picker trigger."},"315":{"id":"/docs/components/file-trigger-10","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#features","content":"Renders a visually hidden `<input type=\"file\">` — no styling of its own."},"316":{"id":"/docs/components/file-trigger-11","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#features","content":"Restricts selection by MIME type, allows multiple files, directory selection, and camera capture."},"317":{"id":"/docs/components/file-trigger-12","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#features","content":"Resets the input value before every open, so re-selecting the same file still fires `onSelect`."},"318":{"id":"/docs/components/file-trigger-13","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#basic-usage","content":"Wrap any pressable component. Activating the child opens the native file picker; the selected files arrive in `onSelect`."},"319":{"id":"/docs/components/file-trigger-14","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#accepted-types","content":"Restrict the picker to specific MIME types with `acceptedFileTypes`, and allow more than one file with `allowsMultiple`."},"320":{"id":"/docs/components/file-trigger-15","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#accessibility","content":"`FileTrigger` adds no visuals or ARIA of its own — accessibility comes from the pressable child you provide. Use a component with an accessible name (e.g. an Antares `Button` with clear label text) so assistive technology announces the action. The underlying `<input>` is visually hidden but remains operable by keyboard through the child's press behavior."},"321":{"id":"/docs/components/file-trigger-16","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#best-practices","content":"`acceptedFileTypes` is a best-effort filter for the OS picker — always validate file type and size again in your `onSelect` handler, since it can be bypassed."},"322":{"id":"/docs/components/file-trigger-17","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#best-practices","content":"Pair `FileTrigger` with `DropZone` to offer both click-to-browse and drag-and-drop. See the DropZone \"File Upload\" example."},"323":{"id":"/docs/components/file-trigger-18","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#best-practices","content":"Keep the child a single pressable element; `FileTrigger` forwards press behavior to whatever you nest inside it."},"324":{"id":"/docs/components/icon","page_id":"/docs/components/icon","type":"page","content":"Icon","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/icon"},"325":{"id":"/docs/components/icon-0","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon","content":"Flexible SVG icon component with on-demand loading, automatic caching, and extensive customization options"},"326":{"id":"/docs/components/icon-1","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#features","content":"Features"},"327":{"id":"/docs/components/icon-2","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#installation","content":"Installation"},"328":{"id":"/docs/components/icon-3","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#props","content":"Props"},"329":{"id":"/docs/components/icon-4","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#prop-inheritance","content":"Prop Inheritance"},"330":{"id":"/docs/components/icon-5","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#basic-usage","content":"Basic Usage"},"331":{"id":"/docs/components/icon-6","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#size-variants","content":"Size Variants"},"332":{"id":"/docs/components/icon-7","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#customization","content":"Customization"},"333":{"id":"/docs/components/icon-8","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#slots","content":"Slots"},"334":{"id":"/docs/components/icon-9","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#component-hierarchy","content":"Component Hierarchy"},"335":{"id":"/docs/components/icon-10","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#available-slot-overrides","content":"Available Slot Overrides"},"336":{"id":"/docs/components/icon-11","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#custom-icons","content":"Custom Icons"},"337":{"id":"/docs/components/icon-12","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#adding-icons-synchronously","content":"Adding Icons Synchronously"},"338":{"id":"/docs/components/icon-13","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#adding-icons-asynchronously","content":"Adding Icons Asynchronously"},"339":{"id":"/docs/components/icon-14","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#custom-icon-apis","content":"Custom Icon APIs"},"340":{"id":"/docs/components/icon-15","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#notes","content":"Notes"},"341":{"id":"/docs/components/icon-16","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#styling","content":"Styling"},"342":{"id":"/docs/components/icon-17","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#css-classes","content":"CSS Classes"},"343":{"id":"/docs/components/icon-18","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#data-attributes","content":"Data Attributes"},"344":{"id":"/docs/components/icon-19","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#color-customization","content":"Color Customization"},"345":{"id":"/docs/components/icon-20","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#inherit-from-parent-default","content":"Inherit from Parent (Default)"},"346":{"id":"/docs/components/icon-21","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#explicit-colors","content":"Explicit Colors"},"347":{"id":"/docs/components/icon-22","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#icon-transformations","content":"Icon Transformations"},"348":{"id":"/docs/components/icon-23","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#rotation","content":"Rotation"},"349":{"id":"/docs/components/icon-24","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#flipping","content":"Flipping"},"350":{"id":"/docs/components/icon-25","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#loading-states","content":"Loading States"},"351":{"id":"/docs/components/icon-26","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#placeholder-content","content":"Placeholder Content"},"352":{"id":"/docs/components/icon-27","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#accessibility","content":"Accessibility"},"353":{"id":"/docs/components/icon-28","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#decorative-icons","content":"Decorative Icons"},"354":{"id":"/docs/components/icon-29","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#semantic-icons","content":"Semantic Icons"},"355":{"id":"/docs/components/icon-30","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#interactive-icons","content":"Interactive Icons"},"356":{"id":"/docs/components/icon-31","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#performance-considerations","content":"Performance Considerations"},"357":{"id":"/docs/components/icon-32","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#default-icon-loading","content":"Default Icon Loading"},"358":{"id":"/docs/components/icon-33","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#sprite-mode-optimization","content":"Sprite Mode Optimization"},"359":{"id":"/docs/components/icon-34","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#recommendations","content":"Recommendations"},"360":{"id":"/docs/components/icon-35","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#troubleshooting","content":"Troubleshooting"},"361":{"id":"/docs/components/icon-36","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#icon-not-loading","content":"Icon Not Loading"},"362":{"id":"/docs/components/icon-37","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#performance-issues","content":"Performance Issues"},"363":{"id":"/docs/components/icon-38","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon","content":"The `Icon` component provides a flexible and performant way to display SVG icons with extensive customization options. Built on top of the Bento Icon system, it features on-demand loading from a CDN, automatic caching, and enhanced props for the Antares design system."},"364":{"id":"/docs/components/icon-39","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**On-demand loading**: Icons are loaded asynchronously from CDN only when needed"},"365":{"id":"/docs/components/icon-40","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Automatic caching**: Once loaded, icons are cached for optimal performance"},"366":{"id":"/docs/components/icon-41","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Flexible sizing**: Support for `width` and `height` props"},"367":{"id":"/docs/components/icon-42","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Color inheritance**: Uses `currentColor` by default for seamless theme integration"},"368":{"id":"/docs/components/icon-43","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Accessibility ready**: Built-in support for screen readers and keyboard navigation"},"369":{"id":"/docs/components/icon-44","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**TypeScript support**: Fully typed with comprehensive prop interfaces"},"370":{"id":"/docs/components/icon-45","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Bento integration**: Extends Bento Icon with additional Antares-specific features"},"37