"/docs/components/circular-progress#sizes","content":"Four circle diameters are available: `sm` (64px), `md` (96px), `lg` (128px), and `xl` (160px)."},"188":{"id":"/docs/components/circular-progress-10","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#emphasis","content":"Use the `emphasis` prop to communicate status: `success`, `warning`, or `critical`. When omitted, the default teal fill is used."},"189":{"id":"/docs/components/circular-progress-11","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`role=\"progressbar\"` on the container"},"190":{"id":"/docs/components/circular-progress-12","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`aria-valuenow` reflects the current value (clamped to 0–100)"},"191":{"id":"/docs/components/circular-progress-13","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`aria-valuemin` and `aria-valuemax` define the range (default `0`–`100`)"},"192":{"id":"/docs/components/circular-progress-14","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`aria-valuetext` provides a formatted string (e.g. `\"60%\"`) via `Intl.NumberFormat`; the same string is rendered inside the circle. Override the text with the `aria-valuetext` prop, or control formatting with `formatOptions`"},"193":{"id":"/docs/components/circular-progress-15","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`aria-labelledby` associates the visible label when the `label` prop is provided"},"194":{"id":"/docs/components/circular-progress-16","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`aria-describedby` wires the `helperText` to the progressbar for screen readers"},"195":{"id":"/docs/components/circular-progress-17","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"The decorative SVG and output text are hidden via `aria-hidden=\"true\"`"},"196":{"id":"/docs/components/drawer","page_id":"/docs/components/drawer","type":"page","content":"Drawer","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/drawer"},"197":{"id":"/docs/components/drawer-0","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer","content":"An overlay panel that slides in from a screen edge, supporting sidebar navigation and bottom sheets."},"198":{"id":"/docs/components/drawer-1","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#features","content":"Features"},"199":{"id":"/docs/components/drawer-2","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#installation","content":"Installation"},"200":{"id":"/docs/components/drawer-3","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#props","content":"Props"},"201":{"id":"/docs/components/drawer-4","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#examples","content":"Examples"},"202":{"id":"/docs/components/drawer-5","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#basic-usage","content":"Basic Usage"},"203":{"id":"/docs/components/drawer-6","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#bottom-sheet","content":"Bottom Sheet"},"204":{"id":"/docs/components/drawer-7","page_id":"/docs/components/drawer","type":"heading","tags":[],"url"