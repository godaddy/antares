ts/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#best-practices","content":"`titleInfo` requires `title` to be set — the info icon is contextually tied to the title label. If `title` is absent, `titleInfo` has no effect."},"473":{"id":"/docs/components/metrics-lockup-27","page_id":"/docs/components/metrics-lockup","tags":[],"type":"text","url":"/docs/components/metrics-lockup#best-practices","content":"`trend` is intended to accompany `description` to provide temporal context (e.g. \"↑ +3% vs. last month\"). A trend icon alone, with no description, leaves the direction unanchored (\"up since *when*?\"). If `description` is not provided, `trend` has no effect."},"474":{"id":"/docs/components/number-field","page_id":"/docs/components/number-field","type":"page","content":"NumberField","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/number-field"},"475":{"id":"/docs/components/number-field-0","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field","content":"NumberField is a numeric input with optional label, description, error message, min/max/step, and increment/decrement stepper buttons. Use it in forms for quantities, amounts, or percentages."},"476":{"id":"/docs/components/number-field-1","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#installation","content":"Installation"},"477":{"id":"/docs/components/number-field-2","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#props","content":"Props"},"478":{"id":"/docs/components/number-field-3","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#examples","content":"Examples"},"479":{"id":"/docs/components/number-field-4","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#basic","content":"Basic"},"