ield-21","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#disabled","content":"Use `isDisabled` to prevent input."},"940":{"id":"/docs/components/text-field-22","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#adornments","content":"Use `leadingText` and `trailingText` for fixed text before and after the input (e.g. currency)."},"941":{"id":"/docs/components/text-field-23","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#multiline","content":"Use `multiline` to render a textarea."},"942":{"id":"/docs/components/toggle-button","page_id":"/docs/components/toggle-button","type":"page","content":"ToggleButton","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/toggle-button"},"943":{"id":"/docs/components/toggle-button-0","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button","content":"Accessible toggle button component for grouped contextual actions with single or multiple selection, keyboard navigation, and RTL-aware layouts."},"944":{"id":"/docs/components/toggle-button-1","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#installation","content":"Installation"},"945":{"id":"/docs/components/toggle-button-2","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#props","content":"Props"},"946":{"id":"/docs/components/toggle-button-3","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#examples","content":"Examples"},"947":{"id":"/docs/components/toggle-button-4","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#default-single-selection","content":"Default (Single Selection)"},"948":{"id":"/docs/components/toggle-button-5","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#multiple-selection","content":"Multiple Selection"},"949":{"id":"/docs/components/toggle-button-6","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#controlled","content":"Controlled"},"950":{"id":"/docs/components/toggle-button-7","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#disabled-states","content":"Disabled States"},"951":{"id":"/docs/components/toggle-button-8","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#sizes","content":"Sizes"},"952":{"id":"/docs/components/toggle-button-9","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#icon--text","content":"Icon + Text"},"953":{"id":"/docs/components/toggle-button-10","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#icon-only","content":"Icon Only"},"954":{"id":"/docs/components/toggle-button-11","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#with-dropdown","content":"With Dropdown"},"955":{"id":"/docs/components/toggle-button-12","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#rtl-direction","content":"RTL Direction"},"956":{"id":"/docs/components/toggle-button-13","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#customization","content":"Customization"},"957":{"id":"/docs/components/toggle-button-14","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#data-attributes","content":"Data Attributes"},"958":{"id":"/docs/components/toggle-button-15","page_id":"/docs/components/toggle-button","type"