","tags":[],"type":"text","url":"/docs/components/select#basic","content":"Minimal usage with a label and a placeholder."},"934":{"id":"/docs/components/select-19","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#controlled","content":"Use `value` and `onChange` for controlled state."},"935":{"id":"/docs/components/select-20","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#multiple","content":"Set `selectionMode=\"multiple\"` to allow multiple values. `value` is an array of keys."},"936":{"id":"/docs/components/select-21","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#invalid","content":"Use `isInvalid` with `errorMessage` for validation feedback."},"937":{"id":"/docs/components/select-22","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#disabled","content":"Use `isDisabled` to prevent interaction."},"938":{"id":"/docs/components/select-23","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#form","content":"Set `name` to submit the value with a native `<form>`. Multiple-mode values submit as repeated entries with the same `name`."},"939":{"id":"/docs/components/tag","page_id":"/docs/components/tag","type":"page","content":"Tag","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/tag"},"940":{"id":"/docs/components/tag-0","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag","content":"Non-interactive labels that highlight statuses and categories."},"941":{"id":"/docs/components/tag-1","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#installation","content":"Installation"},"942":{"id":"/docs/components/tag-2","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#props","content":"Props"},"943":{"id":"/docs/components/tag-3","page_id":"/doc