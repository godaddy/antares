[],"url":"/docs/components/drawer#examples","content":"Examples"},"281":{"id":"/docs/components/drawer-5","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#basic-usage","content":"Basic Usage"},"282":{"id":"/docs/components/drawer-6","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#bottom-sheet","content":"Bottom Sheet"},"283":{"id":"/docs/components/drawer-7","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#placements","content":"Placements"},"284":{"id":"/docs/components/drawer-8","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#nested-popover","content":"Nested Popover"},"285":{"id":"/docs/components/drawer-9","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#no-escape-dismiss","content":"No Escape Dismiss"},"286":{"id":"/docs/components/drawer-10","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#accessibility","content":"Accessibility"},"287":{"id":"/docs/components/drawer-11","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#keyboard","content":"Keyboard"},"288":{"id":"/docs/components/drawer-12","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#aria","content":"ARIA"},"289":{"id":"/docs/components/drawer-13","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#best-practices","content":"Best Practices"},"290":{"id":"/docs/components/drawer-14","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer","content":"An overlay panel that slides in from a screen edge. Built like `Modal` (a RAC modal overlay with an `elevation=\"overlay\"` panel and CSS transitions), it supports sidebar navigation and bottom sheets."},"291":{"id":"/docs/components/drawer-15","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer","content":"`DrawerTrigger` is the composition helper: it wraps a trigger button and a `<Drawer>`, handling open state and `aria-controls` linkage automatically. Based on RAC `DialogTrigger`."},"292":{"id":"/docs/components/drawer-16","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#features","content":"Slides in from any screen edge (top, bottom, left, right)"},"293":{"id":"/docs/components/drawer-17","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#features","content":"`overlay` elevation panel over a dimmed backdrop, matching `Modal`"},"294":{"id":"/docs/components/drawer-18","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#features","content":"Physical `placement` (does not flip for RTL)"},"295":{"id":"/docs/components/drawer-19","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#features","content":"Focus trapping, backdrop dismiss, and scroll lock via RAC Modal"},"296":{"id":"/docs/components/drawer-20","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#features","content":"CSS transitions with `prefers-reduced-motion` support"},"297":{"id":"/docs/components/drawer-21","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#props","content":"The `DrawerTrigger` component accepts the following props:"},"298":{"id":"/docs/components/drawer-22","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#basic-usage","content":"Use `<DrawerTrigger>` to wrap a trigger button and a `<Drawer>`. The drawer opens when the trigger is pressed."},"299":{"id":"/docs/components/drawer-23","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#bottom-sheet","content":"Use `placement=\"bottom\"` with controlled state for a bottom sheet pattern."},"300":{"id":"/docs/components/drawer-24","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#placements","content":"The drawer slides in from whichever edge you set with `placement`."},"301":{"id":"/docs/components/drawer-25","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#nested-popover","content":"Popovers rendered inside a drawer stay open without dismissing the drawer."},"302":{"id":"/docs/components/drawer-26","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#no-escape-dismiss","content":"Use `isKeyboardDismissDisabled` to prevent the drawer from being dismissed by the escape key."},"303":{"id":"/docs/components/drawer-27","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Key"},"304":{"id":"/docs/components/drawer-28","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Action"},"305":{"id":"/docs/components/drawer-29","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"`Escape`"},"306":{"id":"/docs/components/drawer-30","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Close the drawer (unless `isKeyboardDismissDisabled`)"},"307":{"id":"/docs/components/drawer-31","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"`Tab`"},"308":{"id":"/docs/components/drawer-32","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Move focus within the drawer (focus is trapped)"},"309":{"id":"/docs/components/drawer-33","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#aria","content":"`role=\"dialog\"` with `aria-modal=\"true\"` on the drawer panel (via RAC Modal)"},"310":{"id":"/docs/components/drawer-34","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#aria","content":"Dialog accessible name via `aria-label`"},"311":{"id":"/docs/components/drawer-35","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#aria","content":"`aria-label=\"Close\"` on the built-in close button"},"312":{"id":"/docs/components/drawer-36","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#best-practices","content":"Always provide an `aria-label` so the dialog has an accessible name."},"313":{"id":"/docs/components/drawer-37","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#best-practices","content":"Use `isDismissable` to allow closing via backdrop click."},"314":{"id":"/docs/components/drawer-38","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#best-practices","content":"Don't nest drawers."},"315":{"id":"/docs/components/drop-zone","page_id":"/docs/components/drop-zone","type":"page","content":"DropZone","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/drop-zone"},"316":{"id":"/docs/components/drop-zone-0","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone","content":"A standalone region that accepts drag-and-drop file interactions, rendering a clearly defined target area where users can drop files."},"317":{"id":"/docs/components/drop-zone-1","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#installation","content":"Installation"},"318":{"id":"/docs/components/drop-zone-2","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#props","content":"Props"},"319":{"id":"/docs/components/drop-zone-3","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#examples","content":"Examples"},"320":{"id":"/docs/components/drop-zone-4","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#basic-usage","content":"Basic Usage"},"321":{"id":"/docs/components/drop-zone-5","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#disabled","content":"Disabled"},"322":{"id":"/docs/components/drop-zone-6","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#file-upload","content":"File Upload"},"323":{"id":"/docs/components/drop-zone-7","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#drop-target-label","content":"Drop Target Label"},"324":{"id":"/docs/components/drop-zone-8","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#replace-existing-file","content":"Replace Existing File"},"325":{"id":"/docs/components/drop-zone-9","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#accessibility","content":"Accessibility"},"326":{"id":"/docs/components/drop-zone-10","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#keyboard","content":"Keyboard"},"327":{"id":"/docs/components/drop-zone-11","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#screen-readers","content":"Screen readers"},"328":{"id":"/docs/components/drop-zone-12","page_id":"/docs/components/drop-zone","type":"heading","tags":[],"url":"/docs/components/drop-zone#best-practices","content":"Best Practices"},"329":{"id":"/docs/components/drop-zone-13","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#basic-usage","content":"A minimal drop zone. The `onDrop` callback receives the dropped items; use the exported `isFileDropItem` guard to narrow them to files. Wrap the instructional text in `<Text slot=\"label\">` so it labels the visually hidden drop button for screen readers."},"330":{"id":"/docs/components/drop-zone-14","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#disabled","content":"Set `isDisabled` to prevent the drop zone from accepting interactions. The zone is dimmed and the cursor indicates it is not interactive."},"331":{"id":"/docs/components/drop-zone-15","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#file-upload","content":"A reference composition combining `DropZone` with `FileTrigger` to support both click-to-browse and drag-and-drop. Use this as a starting point and adapt the accepted formats, size limit, and handlers to your product's requirements."},"332":{"id":"/docs/components/drop-zone-16","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#drop-target-label","content":"Pass a render-prop function as `children` to change the zone's content while a valid drag is active. Branching on `isDropTarget` requires no extra state. Pair it with `getDropOperation` to reject unsupported types — the label only appears when the drag is accepted."},"333":{"id":"/docs/components/drop-zone-17","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#replace-existing-file","content":"Use `children` as a render function to show different content based on the current zone state — here, swapping the default label for \"Drop to replace\" when a file is already selected and a new drag is active. The same `onDrop` handler services both the drag path and the `FileTrigger` click path, so either gesture replaces the selection."},"334":{"id":"/docs/components/drop-zone-18","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"Key"},"335":{"id":"/docs/components/drop-zone-19","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"Description"},"336":{"id":"/docs/components/drop-zone-20","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"`Tab`"},"337":{"id":"/docs/components/drop-zone-21","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"Moves focus to the drop zone"},"338":{"id":"/docs/components/drop-zone-22","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"`Enter` / `Space`"},"339":{"id":"/docs/components/drop-zone-23","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#keyboard","content":"Opens the file picker so files can be selected without a pointer"},"340":{"id":"/docs/components/drop-zone-24","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#screen-readers","content":"The drop zone renders a visually hidden `<button>` inside the container. Assistive technology discovers and announces this button as an interactive element — activating it opens the native file picker without a pointer."},"341":{"id":"/docs/components/drop-zone-25","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#screen-readers","content":"The button's accessible name is built from two sources, combined in order:"},"342":{"id":"/docs/components/drop-zone-26","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#screen-readers","content":"**`<Text slot=\"label\">`** — any `Text` child with `slot=\"label\"` has its `id` linked to the button via `aria-labelledby`. This is the recommended way to provide a contextual label that is also visible to sighted users."},"343":{"id":"/docs/components/drop-zone-27","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#screen-readers","content":"**`aria-label`** — pass `aria-label` on the `DropZone` component to override or supplement the label (e.g. `aria-label=\"Upload profile photo\"`). When no `Text slot=\"label\"` is present and no `aria-label` is set, the button falls back to the default \"DropZone\" label provided by React Aria."},"344":{"id":"/docs/components/drop-zone-28","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#best-practices","content":"Use the drop zone alongside a button-based file picker — drag-and-drop is a convenience, never the only way to upload."},"345":{"id":"/docs/components/drop-zone-29","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#best-practices","content":"Replace the default text with `children` to communicate the accepted file types and size limits up front."},"346":{"id":"/docs/components/drop-zone-30","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#best-practices","content":"Let the drop zone fill its container; constrain it with the surrounding layout rather than setting a fixed width on the component itself."},"347":{"id":"/docs/components/drop-zone-31","page_id":"/docs/components/drop-zone","tags":[],"type":"text","url":"/docs/components/drop-zone#best-practices","content":"Reflect upload state (validating, uploading, error) outside the drop zone so the target area stays clear and predictable."},"348":{"id":"/docs/components/field","page_id":"/docs/components/field","type":"page","content":"Field primitives","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/field"},"349":{"id":"/docs/components/field-0","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"Composable primitives (Field, FieldLabel, FieldGroup, FieldError) for building form fields"},"350":{"id":"/docs/components/field-1","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#usage","content":"Usage"},"351":{"id":"/docs/components/field-2","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#basic-example","content":"Basic example"},"352":{"id":"/docs/components/field-3","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#composition","content":"Composition"},"353":{"id":"/docs/components/field-4","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#positioning-controls-inside-the-group","content":"Positioning controls inside the group"},"354":{"id":"/docs/components/field-5","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#states","content":"States"},"355":{"id":"/docs/components/field-6","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#examples","content":"Examples"},"356":{"id":"/docs/components/field-7","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#leading-control","content":"Leading control"},"357":{"id":"/docs/components/field-8","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#trailing-control","content":"Trailing control"},"358":{"id":"/docs/components/field-9","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#icon-accessories","content":"Icon accessories"},"359":{"id":"/docs/components/field-10","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**Composition primitives.** The field components (TextField, NumberField, DateField, Select, RadioGroup, CheckboxGroup) compose these internally — reach for those first. These primitives are also the building blocks for custom composite fields, e.g. an input and a select sharing one bordered box."},"360":{"id":"/docs/components/field-11","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"The field decoration is split into granular, composable pieces so the same structure is shared across every field:"},"361":{"id":"/docs/components/field-12","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`Field`** — stacks a field's label, control, description, and error in one consistently spaced column (pure layout — a `Flex` column with the standard field gap)."},"362":{"id":"/docs/components/field-13","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldLabel`** — names the field and flags whether it's required (wraps React Aria `Label`, rendering an optional `*` indicator)."},"363":{"id":"/docs/components/field-14","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldGroup`** — the bordered box that visually unites a field's controls and reflects their shared focus, disabled, and invalid state. Used only by \"boxed\" fields (TextField, NumberField, Select, DateField); presentationally it is a React Aria `Group`."},"364":{"id":"/docs/components/field-15","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldInput`** — the single-line control the user types into (a normalized React Aria `Input` given antares spacing via `Box`)."},"365":{"id":"/docs/components/field-16","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldTextArea`** — the multiline control the user types into (a normalized React Aria `TextArea` given antares spacing via `Box`)."},"366":{"id":"/docs/components/field-17","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldButton`** — an actionable control placed inside the box, such as the NumberField steppers or a search submit (a click target within the group)."},"367":{"id":"/docs/components/field-18","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldTrigger`** — a full-width value-display button inside the box that opens an overlay (used by Select and DatePicker): a value area plus a trailing icon, laid out across the group. `variant=\"select\"` is transparent and input-like; `variant=\"control\"` is a filled segment inside a shared group."},"368":{"id":"/docs/components/field-19","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldDescription`** — helper text that explains the field; renders nothing when empty (wraps the antares `Text` with `slot=\"description\"`)."},"369":{"id":"/docs/components/field-20","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldError`** — surfaces the field's validation messages when it is invalid, and nothing when valid (a thin wrapper over React Aria `FieldError`)."},"370":{"id":"/docs/components/field-21","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"`FieldLabel`, `FieldDescription`, and `FieldError` each render `null` when they have no content, so callers pass `label` / `description` / `errorMessage` straight through without guarding."},"371":{"id":"/docs/components/field-22","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#usage","content":"The `FieldGroup` component has the following props:"},"372":{"id":"/docs/components/field-23","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"A boxed field composes the primitives inside its React Aria field wrapper. Use\n`Field as={...}` to merge the field wrapper and the layout column into a single\nelement:"},"373":{"id":"/docs/components/field-24","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"A field without a box (RadioGroup / CheckboxGroup) composes `Field` + `FieldLabel` + `FieldError` and omits `FieldGroup`."},"374":{"id":"/docs/components/field-25","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"`FieldGroup` is purely presentational — it renders the styled `Group` and holds no React Aria context. The surrounding field wires value, disabled, and validation state into its controls."},"375":{"id":"/docs/components/field-26","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#positioning-controls-inside-the-group","content":"`FieldGroup` rounds its outer corners from DOM order: the group's CSS rounds the start corners of its **first child** and the end corners of its **last child**, so controls are seamless inside and rounded only at the box edges. Author children in visual order and the rounding follows — no per-control positioning prop. A lone control (a TextField input, a Select trigger) is both first and last, so it rounds both edges. The rules are RTL-safe (they use logical `start`/`end` corners)."},"376":{"id":"/docs/components/field-27","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"The states **disabled**, **readonly**, and **invalid** are applied by the field wrapper (e.g. TextField, NumberField, Select). The group reflects them via data attributes on the group."},"377":{"id":"/docs/components/field-28","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"State"},"378":{"id":"/docs/components/field-29","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"CSS Selector"},"379":{"id":"/docs/components/field-30","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"disabled — Applied when the field wrapper is disabled."},"380":{"id":"/docs/components/field-31","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-disabled]`"},"381":{"id":"/docs/components/field-32","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"invalid — Applied when the field wrapper is invalid (e.g. validation failed)."},"382":{"id":"/docs/components/field-33","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-invalid]`"},"383":{"id":"/docs/components/field-34","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"focus — Whether an element within the group has keyboard focus (for focus-ring styling)."},"384":{"id":"/docs/components/field-35","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-focused]`"},"385":{"id":"/docs/components/file-trigger","page_id":"/docs/components/file-trigger","type":"page","content":"FileTrigger","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/file-trigger"},"386":{"id":"/docs/components/file-trigger-0","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger","content":"A style-less primitive that wraps any pressable component and opens the native file picker when it is activated."},"387":{"id":"/docs/components/file-trigger-1","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#features","content":"Features"},"388":{"id":"/docs/components/file-trigger-2","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#installation","content":"Installation"},"389":{"id":"/docs/components/file-trigger-3","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#props","content":"Props"},"390":{"id":"/docs/components/file-trigger-4","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#examples","content":"Examples"},"391":{"id":"/docs/components/file-trigger-5","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#basic-usage","content":"Basic Usage"},"392":{"id":"/docs/components/file-trigger-6","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#accepted-types","content":"Accepted Types"},"393":{"id":"/docs/components/file-trigger-7","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#accessibility","content":"Accessibility"},"394":{"id":"/docs/components/file-trigger-8","page_id":"/docs/components/file-trigger","type":"heading","tags":[],"url":"/docs/components/file-trigger#best-practices","content":"Best Practices"},"395":{"id":"/docs/components/file-trigger-9","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#features","content":"Turns any pressable component (such as an Antares `Button`) into a file picker trigger."},"396":{"id":"/docs/components/file-trigger-10","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#features","content":"Renders a visually hidden `<input type=\"file\">` — no styling of its own."},"397":{"id":"/docs/components/file-trigger-11","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#features","content":"Restricts selection by MIME type, allows multiple files, directory selection, and camera capture."},"398":{"id":"/docs/components/file-trigger-12","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#features","content":"Resets the input value before every open, so re-selecting the same file still fires `onSelect`."},"399":{"id":"/docs/components/file-trigger-13","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#basic-usage","content":"Wrap any pressable component. Activating the child opens the native file picker; the selected files arrive in `onSelect`."},"400":{"id":"/docs/components/file-trigger-14","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#accepted-types","content":"Restrict the picker to specific MIME types with `acceptedFileTypes`, and allow more than one file with `allowsMultiple`."},"401":{"id":"/docs/components/file-trigger-15","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#accessibility","content":"`FileTrigger` adds no visuals or ARIA of its own — accessibility comes from the pressable child you provide. Use a component with an accessible name (e.g. an Antares `Button` with clear label text) so assistive technology announces the action. The underlying `<input>` is visually hidden but remains operable by keyboard through the child's press behavior."},"402":{"id":"/docs/components/file-trigger-16","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#best-practices","content":"`acceptedFileTypes` is a best-effort filter for the OS picker — always validate file type and size again in your `onSelect` handler, since it can be bypassed."},"403":{"id":"/docs/components/file-trigger-17","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#best-practices","content":"Pair `FileTrigger` with `DropZone` to offer both click-to-browse and drag-and-drop. See the DropZone \"File Upload\" example."},"404":{"id":"/docs/components/file-trigger-18","page_id":"/docs/components/file-trigger","tags":[],"type":"text","url":"/docs/components/file-trigger#best-practices","content":"Keep the child a single pressable element; `FileTrigger` forwards press behavior to whatever you nest inside it."},"405":{"id":"/docs/components/icon","page_id":"/docs/components/icon","type":"page","content":"Icon","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/icon"},"406":{"id":"/docs/components/icon-0","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon","content":"Flexible SVG icon component with on-demand loading, automatic caching, and extensive customization options"},"407":{"id":"/docs/components/icon-1","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#features","content":"Features"},"408":{"id":"/docs/components/icon-2","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#installation","content":"Installation"},"409":{"id":"/docs/components/icon-3","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#props","content":"Props"},"410":{"id":"/docs/components/icon-4","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#prop-inheritance","content":"Prop Inheritance"},"411":{"id":"/docs/components/icon-5","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#basic-usage","content":"Basic Usage"},"412":{"id":"/docs/components/icon-6","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#size-variants","content":"Size Variants"},"413":{"id":"/docs/components/icon-7","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#customization","content":"Customization"},"414":{"id":"/docs/components/icon-8","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/com