atically adds data attributes for styling hooks:"},"479":{"id":"/docs/components/icon-73","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-icon`: The icon name (always present)"},"480":{"id":"/docs/components/icon-74","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-color`: Applied when color prop is set"},"481":{"id":"/docs/components/icon-75","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-loading`: Applied during icon loading from CDN"},"482":{"id":"/docs/components/icon-76","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-mode`: Applied when mode prop is set (e.g., \"sprite\")"},"483":{"id":"/docs/components/icon-77","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-flip`: Applied when flip prop is set (\"horizontal\" or \"vertical\")"},"484":{"id":"/docs/components/icon-78","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-rotate`: Applied when rotate prop is set (90, 180, or 270)"},"485":{"id":"/docs/components/icon-79","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"The component also includes accessibility attributes:"},"486":{"id":"/docs/components/icon-80","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`role=\"presentation\"`: For decorative icons"},"487":{"id":"/docs/components/icon-81","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`role=\"img\"`: When title prop is provided"},"488":{"id":"/docs/components/icon-82","page_id":"/docs/