"},"863":{"id":"/docs/components/tag-4","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#basic","content":"Basic"},"864":{"id":"/docs/components/tag-5","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#emphasis","content":"Emphasis"},"865":{"id":"/docs/components/tag-6","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#sizes","content":"Sizes"},"866":{"id":"/docs/components/tag-7","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#inline","content":"Inline"},"867":{"id":"/docs/components/tag-8","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#high-contrast","content":"High Contrast"},"868":{"id":"/docs/components/tag-9","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#with-icon","content":"With Icon"},"869":{"id":"/docs/components/tag-10","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#indicator","content":"Indicator"},"870":{"id":"/docs/components/tag-11","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#accessibility","content":"Accessibility"},"871":{"id":"/docs/components/tag-12","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#screen-readers","content":"Screen readers"},"872":{"id":"/docs/components/tag-13","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#decorative-icons","content":"Decorative icons"},"873":{"id":"/docs/components/tag-14","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#indicator-dot","content":"Indicator dot"},"874":{"id":"/docs/components/tag-15","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#best-practices","content":"Best Practices"},"875":{"id":"/docs/components/tag-16","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#when-to-use","content":"When to Use"},"876":{"id":"/docs/components/tag-17","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#when-not-to-use","content":"When Not to Use"},"877":{"id":"/docs/components/tag-18","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#basic","content":"A minimal tag with the default emphasis and size."},"878":{"id":"/docs/components/tag-19","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#emphasis","content":"Nine emphasis options are available. Choose the one that fits the visual tone of your context."},"879":{"id":"/docs/components/tag-20","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#sizes","content":"Choose a size that fits the surrounding content. Smaller tags work well in compact layouts like tables; larger tags suit headings or hero sections."},"880":{"id":"/docs/components/tag-21","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#inline","content":"Use `design=\"inline\"` to embed a tag within a sentence. The background and border are removed so the tag blends into the text flow."},"881":{"id":"/docs/components/tag-22","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#high-contrast","content":"A bolder color treatment for when tags need to stand out more — for example, on colored backgrounds."},"882":{"id":"/docs/components/tag-23","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#with-icon","content":"Icons reinforce the tag's meaning at a glance. Add an `Icon` as a child — it inherits the tag's color and scales with its size."},"883":{"id":"/docs/components/tag-24","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#indicator","content":"A minimal style that pairs a small colored dot with a neutral background. Well suited for dense layouts like tables or dashboards where multiple tags in close proximity would otherwise compete for attention."},"884":{"id":"/docs/components/tag-25","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#screen-readers","content":"Tags are `<span>` elements with no special ARIA role. Screen readers announce the tag's text as part of normal page content — no extra markup is needed."},"885":{"id":"/docs/components/tag-26","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#decorative-icons","content":"Icons passed as children must include `aria-hidden=\"true\"` so they are skipped by screen readers. The text label is the sole carrier of meaning."},"886":{"id":"/docs/components/tag-27","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#indicator-dot","content":"The colored dot is decorative and invisible to screen readers. The text label must convey the status on its own — never rely on the dot alone to communicate meaning."},"887":{"id":"/docs/components/tag-28","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Use the indicator style in dense layouts like tables and dashboards. Use the filled style when the tag is a prominent, standalone element on a card or hero section."},"888":{"id":"/docs/components/tag-29","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Default to the small size in compact layouts like tables and lists. Use medium or large only when the tag needs to stand out as a primary piece of information."},"889":{"id":"/docs/components/tag-30","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Use the inline design only within running prose. In grouped or standalone contexts, the filled style provides better visual separation."},"890":{"id":"/docs/components/tag-31","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Do not stack multiple tags of different emphasis on the same item. Choose the most important one — too many competing labels lose their meaning."},"891":{"id":"/docs/components/tag-32","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Showing the status of an item on a card, table row, or list entry (e.g. \"Active\", \"Expired\", \"Pending\")"},"892":{"id":"/docs/components/tag-33","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Categorizing or grouping content so users can scan and filter quickly (e.g. \"New\", \"Sale\", \"Beta\")"},"893":{"id":"/docs/components/tag-34","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Surfacing metadata about an item (e.g. \"Pro\", \"Free trial\", \"Internal\")"},"894":{"id":"/docs/components/tag-35","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Communicating priority or category in project management and collaboration tools (e.g. \"High priority\", \"In review\")"},"895":{"id":"/docs/components/tag-36","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-not-to-use","content":"If users need to click or dismiss it — use a **Button** instead."},"896":{"id":"/docs/components/tag-37","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-not-to-use","content":"If the label is part of a sentence with no visual distinction — just use text."},"897":{"id":"/docs/components/telephone-field","page_id":"/docs/components/telephone-field","type":"page","content":"TelephoneField","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/telephone-field"},"898":{"id":"/docs/components/telephone-field-0","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field","content":"TelephoneField pairs a country/dial-code picker with a phone number input inside one bordered field, for capturing an international phone number."},"899":{"id":"/docs/components/telephone-field-1","page_id":"/docs/components/telephone-field","type":"heading","tags":[],"url":"/docs/components/telephone-field#features","content":"Features"},"900":{"id":"/docs/components/telephone-field-2","page_id":"/docs/components/telephone-field","type":"heading","tags":[],"url":"/docs/components/telephone-field#installation","content":"Installation"},"901":{"id":"/docs/components/telephone-field-3","page_id":"/docs/components/telephone-field","type":"heading","tags":[],"url":"/docs/components/telephone-field#props","content":"Props"},"902":{"id":"/docs/components/telephone-field-4","page_id":"/docs/components/telephone-field","type":"heading","tags":[],"url":"/docs/components/telephone-field#examples","content":"Examples"},"903":{"id":"/docs/components/telephone-field-5","page_id":"/docs/components/telephone-field","type":"heading","tags":[],"url":"/docs/components/telephone-field#basic","content":"Basic"},"904":{"id":"/docs/components/telephone-field-6","page_id":"/docs/components/telephone-field","type":"heading","tags":[],"url":"/docs/components/telephone-field#controlled","content":"Controlled"},"905":{"id":"/docs/components/telephone-field-7","page_id":"/docs/components/telephone-field","type":"heading","tags":[],"url":"/docs/components/telephone-field#invalid","content":"Invalid"},"906":{"id":"/docs/components/telephone-field-8","page_id":"/docs/components/telephone-field","type":"heading","tags":[],"url":"/docs/components/telephone-field#disabled","content":"Disabled"},"907":{"id":"/docs/components/telephone-field-9","page_id":"/docs/components/telephone-field","type":"heading","tags":[],"url":"/docs/components/telephone-field#sizes","content":"Sizes"},"908":{"id":"/docs/components/telephone-field-10","page_id":"/docs/components/telephone-field","type":"heading","tags":[],"url":"/docs/components/telephone-field#accessibility","content":"Accessibility"},"909":{"id":"/docs/components/telephone-field-11","page_id":"/docs/components/telephone-field","type":"heading","tags":[],"url":"/docs/components/telephone-field#best-practices","content":"Best Practices"},"910":{"id":"/docs/components/telephone-field-12","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#features","content":"**Country picker + phone input**: A country/dial-code `Select` and a phone number input share one bordered field"},"911":{"id":"/docs/components/telephone-field-13","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#features","content":"**Label, description, error**: Optional label, helper text, and error message with proper accessibility"},"912":{"id":"/docs/components/telephone-field-14","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#features","content":"**Controlled or uncontrolled**: Use `country`/`onCountryChange` and `value`/`onChange` for controlled state, or `defaultCountry`/`defaultValue` for uncontrolled"},"913":{"id":"/docs/components/telephone-field-15","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#features","content":"**Validation states**: Use `isInvalid` with `errorMessage` and `isDisabled` for validation and disabled state"},"914":{"id":"/docs/components/telephone-field-16","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#features","content":"**Raw values, no formatting**: The phone number is the exact string the user typed — TelephoneField applies no masking or E.164 formatting, so combine `country` and `value` however the consuming form or backend expects"},"915":{"id":"/docs/components/telephone-field-17","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#features","content":"**Composable options**: Country options are plain `SelectItem` children, so callers control the exact list and label of supported countries"},"916":{"id":"/docs/components/telephone-field-18","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#props","content":"The TelephoneField component accepts the following props:"},"917":{"id":"/docs/components/telephone-field-19","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#basic","content":"Minimal usage with a label, a default country, and a placeholder."},"918":{"id":"/docs/components/telephone-field-20","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#controlled","content":"Use `country`/`onCountryChange` and `value`/`onChange` for controlled state."},"919":{"id":"/docs/components/telephone-field-21","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#invalid","content":"Use `isInvalid` with `errorMessage` for validation feedback."},"920":{"id":"/docs/components/telephone-field-22","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#disabled","content":"Use `isDisabled` to prevent interaction with both the country picker and the phone input."},"921":{"id":"/docs/components/telephone-field-23","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#sizes","content":"Set `size=\"sm\"` for a more compact field."},"922":{"id":"/docs/components/telephone-field-24","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#accessibility","content":"The country picker gets its own accessible name from `countryLabel`, since it has no visible label of its own — always pass one, localized for your UI"},"923":{"id":"/docs/components/telephone-field-25","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#accessibility","content":"For anything else the country picker needs (`aria-describedby`, `aria-labelledby`, `id`, …), pass `countryProps`, which is spread onto its underlying `FieldSelect`"},"924":{"id":"/docs/components/telephone-field-26","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#accessibility","content":"`label`, `description`, and `errorMessage` are associated with the field automatically"},"925":{"id":"/docs/components/telephone-field-27","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#accessibility","content":"Built on React Aria's `TextField` and `Select`, giving full keyboard support: `Tab` moves between the country picker and the phone input, `Enter`/`Space` opens the country picker, and arrow keys/typeahead navigate its options"},"926":{"id":"/docs/components/telephone-field-28","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#accessibility","content":"`isDisabled` and `isInvalid` are reflected with `aria-disabled`/`data-disabled` and `aria-invalid`/`data-invalid` on both segments"},"927":{"id":"/docs/components/telephone-field-29","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#best-practices","content":"Keep country option labels short and consistent (e.g. always `<ISO code> +<dial code>`) so the trigger stays readable at both `md` and `sm` sizes"},"928":{"id":"/docs/components/telephone-field-30","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#best-practices","content":"Pair `isInvalid` with a specific `errorMessage` (e.g. \"Enter a valid phone number\") rather than a generic one"},"929":{"id":"/docs/components/telephone-field-31","page_id":"/docs/components/telephone-field","tags":[],"type":"text","url":"/docs/components/telephone-field#best-practices","content":"Validate and format the combined `country` + `value` where the number is consumed (on submit, or server-side) — TelephoneField intentionally does not mask or format as the user types"},"930":{"id":"/docs/components/text","page_id":"/docs/components/text","type":"page","content":"Text","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/text"},"931":{"id":"/docs/components/text-0","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text","content":"Text component for displaying and formatting text content with alignment and truncation options"},"932":{"id":"/docs/components/text-1","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#installation","content":"Installation"},"933":{"id":"/docs/components/text-2","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#props","content":"Props"},"934":{"id":"/docs/components/text-3","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#examples","content":"Examples"},"935":{"id":"/docs/components/text-4","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#as","content":"As"},"936":{"id":"/docs/components/text-5","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#align","content":"Align"},"937":{"id":"/docs/components/text-6","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#max-lines","content":"Max Lines"},"938":{"id":"/docs/components/text-7","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#wrap","content":"Wrap"},"939":{"id":"/docs/components/text-8","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text","content":"The `Text` component prepares content with a few properties."},"940":{"id":"/docs/components/text-9","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#props","content":"The `Text` component accepts the following props:"},"941":{"id":"/docs/components/text-10","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#as","content":"Setting the `as` prop allows you to change the HTML tag of the `Text` component."},"942":{"id":"/docs/components/text-11","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#align","content":"Setting the `align` prop allows you to change the alignment of the text. You can choose from `start`, `center`, `end`, or `justify`.\n`start` works like `left` and `end` works like `right`. These keywords support RTL languages so you do not need to worry about the language of the text."},"943":{"id":"/docs/components/text-12","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#max-lines","content":"Setting the `maxLines` prop allows you to limit the number of lines of text that are displayed using an ellipsis. In browsers that don't support multiline text truncation using `line-clamp`, the text will be truncated after a single line regardless of the number provided for `maxLines`."},"944":{"id":"/docs/components/text-13","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"Setting the `wrap` prop allows you to change the wrapping of the text. The values can be `wrap`, `nowrap`, `balance`, `pretty`, or `stable`."},"945":{"id":"/docs/components/text-14","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`wrap` is the setting that is most commonly used. For most elements you will not to explicitly set this."},"946":{"id":"/docs/components/text-15","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`nowrap` should be avoided except in cases where it is important to prevent the text from wrapping."},"947":{"id":"/docs/components/text-16","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`balance` is most commonly used for headlines, titles, and labels."},"948":{"id":"/docs/components/text-17","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`pretty` is most commonly used for body text."},"949":{"id":"/docs/components/text-18","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`stable` is commonly used for editable text, such as textareas."},"950":{"id":"/docs/components/text-field","page_id":"/docs/components/text-field","type":"page","content":"TextField","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/text-field"},"951":{"id":"/docs/components/text-field-0","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field","content":"TextField is a single-line or multiline text input with optional label, description, and error message. Use it in forms for short answers (email, search, name) or longer content (comments). It supports optional leading and trailing text adornments (e.g. currency or units)."},"952":{"id":"/docs/components/text-field-1","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#features","content":"Features"},"953":{"id":"/docs/components/text-field-2","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#installation","content":"Installation"},"954":{"id":"/docs/components/text-field-3","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#props","content":"Props"},"955":{"id":"/docs/components/text-field-4","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#examples","content":"Examples"},"956":{"id":"/docs/components/text-field-5","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#basic","content":"Basic"},"957":{"id":"/docs/components/text-field-6","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#controlled","content":"Controlled"},"958":{"id":"/docs/components/text-field-7","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#invalid","content":"Invalid"},"959":{"id":"/docs/components/text-field-8","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#disabled","content":"Disabled"},"960":{"id":"/docs/components/text-field-9","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#adornments","content":"Adornments"},"961":{"id":"/docs/components/text-field-10","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#multiline","content":"Multiline"},"962":{"id":"/docs/components/text-field-11","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Label, description, error**: Optional label, helper text, and error message with proper accessibility"},"963":{"id":"/docs/components/text-field-12","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Adornments**: Optional `leadingText` and `trailingText` for fixed text before or after the input (e.g. `$`, `.00`, `px`)"},"964":{"id":"/docs/components/text-field-13","page_id":"/docs/c