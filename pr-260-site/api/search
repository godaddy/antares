 for validation feedback."},"1053":{"id":"/docs/components/text-field-21","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#disabled","content":"Use `isDisabled` to prevent input."},"1054":{"id":"/docs/components/text-field-22","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#adornments","content":"Use `leadingText` and `trailingText` for fixed text before and after the input (e.g. currency)."},"1055":{"id":"/docs/components/text-field-23","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#multiline","content":"Use `multiline` to render a textarea."},"1056":{"id":"/docs/components/toggle-button","page_id":"/docs/components/toggle-button","type":"page","content":"ToggleButton","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/toggle-button"},"1057":{"id":"/docs/components/toggle-button-0","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button","content":"Accessible toggle button component for grouped contextual actions with single or multiple selection, keyboard navigation, and RTL-aware layouts."},"1058":{"id":"/docs/components/toggle-button-1","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#installation","content":"Installation"},"1059":{"id":"/docs/components/toggle-button-2","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#props","content":"Props"},"1060":{"id":"/docs/components/toggle-button-3","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#examples","content":"Examples"},"1061":{"id":"/docs/components/toggle-button-4","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#default-single-selection","content":"Default (Si