hair-not-showing","content":"Ensure `tooltip`, `showCrosshair`, or `showDataPoints` are not set to `false`, and that the chart receives pointer events (e.g. no overlay blocking hover)."},"1382":{"id":"/docs/components/chart/line-chart-80","page_id":"/docs/components/chart/line-chart","tags":[],"type":"text","url":"/docs/components/chart/line-chart#when-to-use-linechart","content":"Use for trends over time or along a continuous scale."},"1383":{"id":"/docs/components/chart/line-chart-81","page_id":"/docs/components/chart/line-chart","tags":[],"type":"text","url":"/docs/components/chart/line-chart#when-to-use-linechart","content":"Use when comparing a few series (e.g. 2–5 lines); avoid too many overlapping lines."},"1384":{"id":"/docs/components/chart/line-chart-82","page_id":"/docs/components/chart/line-chart","tags":[],"type":"text","url":"/docs/components/chart/line-chart#when-to-use-linechart","content":"Prefer a single chart with a legend over multiple small charts when comparing the same X range."},"1385":{"id":"/docs/components/layout/box","page_id":"/docs/components/layout/box","type":"page","content":"Box","breadcrumbs":["Docs","Components","Layout"],"tags":[],"url":"/docs/components/layout/box"},"1386":{"id":"/docs/components/layout/box-0","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box","content":"Polymorphic layout component providing consistent spacing, elevation, rounding, and self-alignment"},"1387":{"id":"/docs/components/layout/box-1","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#installation","content":"Installation"},"1388":{"id":"/docs/components/layout/box-2","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#props","content":"Props"},"1389":{"id":"/docs/components/layout/box-3","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#scale-sizes",