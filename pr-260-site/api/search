/icon","type":"heading","tags":[],"url":"/docs/components/icon#performance-considerations","content":"Performance Considerations"},"438":{"id":"/docs/components/icon-32","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#default-icon-loading","content":"Default Icon Loading"},"439":{"id":"/docs/components/icon-33","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#sprite-mode-optimization","content":"Sprite Mode Optimization"},"440":{"id":"/docs/components/icon-34","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#recommendations","content":"Recommendations"},"441":{"id":"/docs/components/icon-35","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#troubleshooting","content":"Troubleshooting"},"442":{"id":"/docs/components/icon-36","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#icon-not-loading","content":"Icon Not Loading"},"443":{"id":"/docs/components/icon-37","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#performance-issues","content":"Performance Issues"},"444":{"id":"/docs/components/icon-38","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon","content":"The `Icon` component provides a flexible and performant way to display SVG icons with extensive customization options. Built on top of the Bento Icon system, it features on-demand loading from a CDN, automatic caching, and enhanced props for the Antares design system."},"445":{"id":"/docs/components/icon-39","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**On-demand loading**: Icons are loaded asynchronously from CDN only when needed"},"446":{"id":"/docs/components/icon-40","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Automatic caching**: Once loaded, icons are cached for optimal performance"},"447":{"id":"/docs/components/icon-41","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Flexible sizing**: Support for `width` and `height` props"},"448":{"id":"/docs/components/icon-42","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Color inheritance**: Uses `currentColor` by default for seamless theme integration"},"449":{"id":"/docs/components/icon-43","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Accessibility ready**: Built-in support for screen readers and keyboard navigation"},"450":{"id":"/docs/components/icon-44","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**TypeScript support**: Fully typed with comprehensive prop interfaces"},"451":{"id":"/docs/components/icon-45","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#features","content":"**Bento integration**: Extends Bento Icon with additional Antares-specific features"},"452":{"id":"/docs/components/icon-46","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#props","content":"The `Icon` component accepts the following props:"},"453":{"id":"/docs/components/icon-47","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#prop-inheritance","content":"The component extends `BentoIconProps` and passes through all standard HTML attributes and accessibility props to the underlying Bento Icon component. This includes:"},"454":{"id":"/docs/components/icon-48","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#prop-inheritance","content":"**Accessibility**: `aria-label`, `aria-describedby`, `role`, `title`"},"455":{"id":"/docs/components/icon-49","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#prop-inheritance","content":"**Events**: `onClick`, `onMouseOver`, `onFocus`, etc."},"456":{"id":"/docs/components/icon-50","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#prop-inheritance","content":"**Styling**: `className`, `style`, `data-*` attributes"},"457":{"id":"/docs/components/icon-51","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#prop-inheritance","content":"**Transform**: `rotate`, `flip` for icon transformations"},"458":{"id":"/docs/components/icon-52","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#size-variants","content":"Specify explicit width and height values:"},"459":{"id":"/docs/components/icon-53","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#size-variants","content":"You can use different values for width and height:"},"460":{"id":"/docs/components/icon-54","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#slots","content":"The Icon component uses Bento's slot system with the following component hierarchy and available slot override points:"},"461":{"id":"/docs/components/icon-55","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#available-slot-overrides","content":"**`icon`**: Overrides the entire BentoIcon component - affects icon loading, caching, sprite/SVG mode switching, data attributes, and the overall icon wrapper"},"462":{"id":"/docs/components/icon-56","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#available-slot-overrides","content":"**`icon.content`**: Overrides the BentoIllustration component - affects SVG transformations (rotate, flip), accessibility attributes (`role`, `focusable`, `aria-labelledby`), viewBox calculations, and final SVG element rendering"},"463":{"id":"/docs/components/icon-57","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#available-slot-overrides","content":"For complete slot override patterns and examples, see the `@bento/slots` package documentation."},"464":{"id":"/docs/components/icon-58","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#custom-icons","content":"While the Icon component loads design system approved icons from the CDN by default, teams can introduce custom icons using the underlying Bento Icon system."},"465":{"id":"/docs/components/icon-59","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#adding-icons-synchronously","content":"Use the `set` method to add custom icons that are available immediately:"},"466":{"id":"/docs/components/icon-60","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#adding-icons-asynchronously","content":"Use the `ondemand` method to load custom icons from your own sources:"},"467":{"id":"/docs/components/icon-61","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#custom-icon-apis","content":"The following methods are exported from `@godaddy/antares` for custom icon management:"},"468":{"id":"/docs/components/icon-62","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#custom-icon-apis","content":"**`set(icons)`**: Synchronously add icons to the store"},"469":{"id":"/docs/components/icon-63","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#custom-icon-apis","content":"**`ondemand(loader)`**: Register an asynchronous icon loader (returns unregister function)"},"470":{"id":"/docs/components/icon-64","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#custom-icon-apis","content":"**`parser(svgString)`**: Parse SVG strings into React elements"},"471":{"id":"/docs/components/icon-65","page_id"