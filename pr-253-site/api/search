ress-steps-18","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Four completion statuses (`none`, `partial`, `complete`, `error`) with status icons"},"703":{"id":"/docs/components/progress-steps-19","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Timeline (past / current / future) derived from a single `currentStep` prop"},"704":{"id":"/docs/components/progress-steps-20","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Auto-generated step numbers (opt out with `hideStepNumbers`)"},"705":{"id":"/docs/components/progress-steps-21","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Interactive (navigable) and inert (display-only) steps"},"706":{"id":"/docs/components/progress-steps-22","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Title truncation and RTL support"},"707":{"id":"/docs/components/progress-steps-23","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Rendered as a `<nav>` landmark with an ordered list for assistive technology"},"708":{"id":"/docs/components/progress-steps-24","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#props","content":"`ProgressSteps` is the container; its direct children must be `ProgressStep` elements."},"709":{"id":"/docs/components/progress-steps-25","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#default","content":"A horizontal stepper. `currentStep` marks the active step; earlier steps are `past`, later are `future`. Each `status` sets the step's icon, and an `error` step turns its accent bar red."},"710":{"id":"/docs/components/progress-steps-26","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#not-started","content":"Omit `currentStep` for a flow that hasn't begun: every step is `future` and none is marked current."},"711":{"id":"/docs/components/progress-steps-27","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#vertical","content":"Use `orientation=\"vertical\"` to place the accent bar on the leading edge and stack steps in a column."},"712":{"id":"/docs/components/progress-steps-28","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#interactive","content":"Give a step an `onPress` handler to make it navigable. Steps without `onPress` are inert."},"713":{"id":"/docs/components/progress-steps-29","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#disabled","content":"A disabled interactive step is muted, removed from the tab order, and cannot be activated."},"714":{"id":"/docs/components/progress-steps-30","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#hide-step-numbers","content":"Step numbers are prepended automatically. Set `hideStepNumbers` to omit them."},"715":{"id":"/docs/components/progress-steps-31","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"Step numbers (`\"N. \"`) are prepended automatically — keep them where possible, as user testing shows people recognize the component better with them. Set `hideStepNumbers` to omit them."},"716":{"id":"/docs/components/progress-steps-32","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"`orientation` switches between `horizontal` (accent bar on top) and `vertical` (accent bar on the leading edge)."},"717":{"id":"/docs/components/progress-steps-33","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"`currentStep` is the single source of truth for the timeline. Omit it for a not-yet-started flow where every step is `future`; pass the step count for a fully completed flow where every step is `past`."},"718":{"id":"/docs/components/progress-steps-34","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"`status` is independent of timeline and only controls the status icon and (for `error`) the accent bar color."},"719":{"id":"/docs/components/progress-steps-35","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"Pass `className` to the container or an individual step to extend the styles."},"720":{"id":"/docs/components/progress-steps-36","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#accessibility","content":"The container renders a `<nav>` landmark; set `aria-label` to name it (defaults to `\"Progress\"`)."},"721":{"id":"/docs/components/progress-steps-37","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#accessibility","content":"Steps are an ordered list (`<ol>`/`<li>`) so assistive technology conveys position and count."},"722":{"id":"/docs/components/progress-steps-38","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#accessibility","content":"The current step is marked with `aria-current=\"step\"`."},"723":{"id":"/docs/components/progress-steps-39","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#accessibility","content":"Interactive steps are real buttons: focusable in the natural **Tab** order and activated with **Enter** or **Space**. Status icons are decorative (`aria-hidden`)."},"724":{"id":"/docs/components/progress-steps-40","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#accessibility","content":"Focus is shown with a visible outline; disabled steps use `0.4` opacity and are not focusable."},"725":{"id":"/docs/components/progress-steps-41","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#best-practices","content":"Drive the timeline from `currentStep` rather than styling individual steps."},"726":{"id":"/docs/components/progress-steps-42","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#best-practices","content":"Provide `onPress` only for steps a user can actually navigate to; leave it off for display-only steps."},"727":{"id":"/docs/components/progress-steps-43","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#best-practices","content":"Keep titles short — they truncate with an ellipsis when space is tight."},"728":{"id":"/docs/components/progress-steps-44","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#best-practices","content":"Always give the container an `aria-label` that describes the flow (e.g. `\"Checkout progress\"`)."},"729":{"id":"/docs/components/progress-steps-45","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#troubleshooting","content":"**No step is highlighted:** `currentStep` is omitted, negative, or out of range. Set it to the active step's 0-based index."},"730":{"id":"/docs/components/progress-steps-46","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#troubleshooting","content":"**A step isn't clickable:** it has no `onPress`, so it's inert by design. Add `onPress` to make it interactive."},"731":{"id":"/docs/components/progress-steps-47","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#troubleshooting","content":"**Titles overflow:** that's expected — titles truncate. Shorten the title."},"732":{"id":"/docs/components/segmented-controller","page_id":"/docs/components/segmented-controller","type":"page","content":"SegmentedController","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/segmented-controller"},"733":{"id":"/docs/components/segmented-controller-0","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller","content":"A segmented controller is a linear set of two or more segments, each of which functions as a button. A segmented controller allows users to select options, switch views, or sort elements."},"734":{"id":"/docs/components/segmented-controller-1","page_id":"/docs/components/segmented-controller","type":"heading","tags":[],"url":"/docs/components/segmented-controller#installation","content":"Installation"},"735":{"id":"/docs/components/segmented-controller-2","page_id":"/docs/components/segmented-controller","type":"heading","tags":[],"url":"/docs/components/segmented-controller#props","content":"Props"},"736":{"id":"/docs/components/segmented-controller-3","page_id":"/docs/components/segmented-controller","type":"heading","tags":[],"url":"/docs/components/segmented-controller#examples","content":"Examples"},"737":{"id":"/docs/components/segmented-controller-4","page_id":"/docs/components/segmented-controller","type":"heading","tags":[],"url":"/docs/components/segmented-controller#basic","content":"Basic"},"738":{"id":"/docs/components/segmented-controller-5","page_id":"/docs/components/segmented-controller","type":"heading","tags":[],