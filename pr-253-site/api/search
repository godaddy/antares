":"/docs/components/drawer-13","page_id":"/docs/components/drawer","type":"heading","tags":[],"url":"/docs/components/drawer#best-practices","content":"Best Practices"},"209":{"id":"/docs/components/drawer-14","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer","content":"An overlay panel that slides in from a screen edge. Built like `Modal` (a RAC modal overlay with an `elevation=\"overlay\"` panel and CSS transitions), it supports sidebar navigation and bottom sheets."},"210":{"id":"/docs/components/drawer-15","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer","content":"`DrawerTrigger` is the composition helper: it wraps a trigger button and a `<Drawer>`, handling open state and `aria-controls` linkage automatically. Based on RAC `DialogTrigger`."},"211":{"id":"/docs/components/drawer-16","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#features","content":"Slides in from any screen edge (top, bottom, left, right)"},"212":{"id":"/docs/components/drawer-17","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#features","content":"`overlay` elevation panel over a dimmed backdrop, matching `Modal`"},"213":{"id":"/docs/components/drawer-18","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#features","content":"Physical `placement` (does not flip for RTL)"},"214":{"id":"/docs/components/drawer-19","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#features","content":"Focus trapping, backdrop dismiss, and scroll lock via RAC Modal"},"215":{"id":"/docs/components/drawer-20","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#features","content":"CSS transitions with `prefers-reduced-motion` support"},"216":{"id":"/docs/components/drawer-21","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#props","content":"The `DrawerTrigger` component accepts the following props:"},"217":{"id":"/docs/components/drawer-22","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#basic-usage","content":"Use `<DrawerTrigger>` to wrap a trigger button and a `<Drawer>`. The drawer opens when the trigger is pressed."},"218":{"id":"/docs/components/drawer-23","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#bottom-sheet","content":"Use `placement=\"bottom\"` with controlled state for a bottom sheet pattern."},"219":{"id":"/docs/components/drawer-24","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#placements","content":"The drawer slides in from whichever edge you set with `placement`."},"220":{"id":"/docs/components/drawer-25","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#nested-popover","content":"Popovers rendered inside a drawer stay open without dismissing the drawer."},"221":{"id":"/docs/components/drawer-26","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#no-escape-dismiss","content":"Use `isKeyboardDismissDisabled` to prevent the drawer from being dismissed by the escape key."},"222":{"id":"/docs/components/drawer-27","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Key"},"223":{"id":"/docs/components/drawer-28","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Action"},"224":{"id":"/docs/components/drawer-29","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"`Escape`"},"225":{"id":"/docs/components/drawer-30","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Close the drawer (unless `isKeyboardDismissDisabled`)"},"226":{"id":"/docs/components/drawer-31","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"`Tab`"},"227":{"id":"/docs/components/drawer-32","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#keyboard","content":"Move focus within the drawer (focus is trapped)"},"228":{"id":"/docs/components/drawer-33","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#aria","content":"`role=\"dialog\"` with `aria-modal=\"true\"` on the drawer panel (via RAC Modal)"},"229":{"id":"/docs/components/drawer-34","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#aria","content":"Dialog accessible name via `aria-label`"},"230":{"id":"/docs/components/drawer-35","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#aria","content":"`aria-label=\"Close\"` on the built-in close button"},"231":{"id":"/docs/components/drawer-36","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#best-practices","content":"Always provide an `aria-label` so the dialog has an accessible name."},"232":{"id":"/docs/components/drawer-37","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#best-practices","content":"Use `isDismissable` to allow closing via backdrop click."},"233":{"id":"/docs/components/drawer-38","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#best-practices","content":"Don't nest drawers."},"234":{"id":"/docs/components/field","page_id":"/docs/components/field","type":"page","content":"Field primitives","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/field"},"235":{"id":"/docs/components/field-0","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"Composable primitives (Field, FieldLabel, FieldGroup, FieldError) for building form fields"},"236":{"id":"/docs/components/field-1","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#usage","content":"Usage"},"237":{"id":"/docs/components/field-2","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#fieldgroup-props","content":"FieldGroup props"},"238":{"id":"/docs/components/field-3","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#basic-example","content":"Basic example"},"239":{"id":"/docs/components/field-4","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#composition","content":"Composition"},"240":{"id":"/docs/components/field-5","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#positioning-controls-inside-the-group","content":"Positioning controls inside the group"},"241":{"id":"/docs/components/field-6","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#states","content":"States"},"242":{"id":"/docs/components/field-7","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#examples","content":"Examples"},"243":{"id":"/docs/components/field-8","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#leading-control","content":"Leading control"},"244":{"id":"/docs/components/field-9","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#trailing-control","content":"Trailing control"},"245":{"id":"/docs/components/field-10","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#icon-accessories","content":"Icon accessories"},"246":{"id":"/docs/components/field-11","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**Composition primitives.** The field components (TextField, NumberField, DateField, Select, RadioGroup, CheckboxGroup) compose these internally — reach for those first. These primitives are also the building blocks for custom composite fields, e.g. an input and a select sharing one bordered box."},"247":{"id":"/docs/components/field-12","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"The field decoration is split into granular, composable pieces so the same structure is shared across every field:"},"248":{"id":"/docs/components/field-13","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`Field`** — stacks a field's label, control, description, and error in one consistently spaced column (pure layout — a `Flex` column with the standard field gap)."},"249":{"id":"/docs/components/field-14","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldLabel`** — names the field and flags whether it's required (wraps React Aria `Label`, rendering an optional `*` indicator)."},"250":{"id":"/docs/components/field-15","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldGroup`** — the bordered box that visually unites a field's controls and reflects their shared focus, disabled, and invalid state. Used only by \"boxed\" fields (TextField, NumberField, Select, DateField); presentationally it is a React Aria `Group`."},"251":{"id":"/docs/components/field-16","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldInput`*&#x2A; / &#x2A;*`FieldTextArea`** — the control the user types into (normalized React Aria `Input`/`TextArea` given antares spacing via `Box`)."},"252":{"id":"/docs/components/field-17","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldButton`** — an actionable control placed inside the box, such as the NumberField steppers or a search submit (a click target within the group)."},"253":{"id":"/docs/components/field-18","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldDescription`** — helper text that explains the field; renders nothing when empty (wraps the antares `Text` with `slot=\"description\"`)."},"254":{"id":"/docs/components/field-19","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldError`** — surfaces the field's validation messages when it is invalid, and nothing when valid (a thin wrapper over React Aria `FieldError`)."},"255":{"id":"/docs/components/field-20","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"`FieldLabel`, `FieldDescription`, and `FieldError` each render `null` when they have no content, so callers pass `label` / `description` / `errorMessage` straight through without guarding."},"256":{"id":"/docs/components/field-21","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"A boxed field composes the primitives inside its React Aria field wrapper. Use\n`Field as={...}` to merge the field wrapper and the layout column into a single\nelement:"},"257":{"id":"/docs/components/field-22","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"A field without a box (RadioGroup / CheckboxGroup) composes `Field` + `FieldLabel` + `FieldError` and omits `FieldGroup`."},"258":{"id":"/docs/components/field-23","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"`FieldGroup` is purely presentational — it renders the styled `Group` and holds no React Aria context. The surrounding field wires value, disabled, and validation state into its controls."},"259":{"id":"/docs/components/field-24","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#positioning-controls-inside-the-group","content":"`FieldGroup` rounds its outer corners from DOM order: the group's CSS rounds the start corners of its **first child** and the end corners of its **last child**, so controls are seamless inside and rounded only at the box edges. Author children in visual order and the rounding follows — no per-control positioning prop. A lone control (a TextField input, a Select trigger) is both first and last, so it rounds both edges. The rules are RTL-safe (they use logical `start`/`end` corners)."},"260":{"id":"/docs/components/field-25","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"The states **disabled**, **readonly**, and **invalid** are applied by the field wrapper (e.g. TextField, NumberField, Select). The group reflects them via data attributes on the group."},"261":{"id":"/docs/components/field-26","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"State"},"262":{"id":"/docs/components/field-27","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"CSS Selector"},"263":{"id":"/docs/components/field-28","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"disabled — Applied when the field wrapper is disabled."},"264":{"id":"/docs/components/field-29","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-disabled]`"},"265":{"id":"/docs/components/field-30","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"invalid — Applied when the field wrapper is invalid (e.g. validation failed)."},"266":{"id":"/docs/components/field-31","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-invalid]`"},"267":{"id":"/docs/components/field-32","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"focus — Whether an element within the group has keyboard focus (for focus-ring styling)."},"268":{"id":"/docs/components/field-33","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-focused]`"},"269":{"id":"/docs/components/icon","page_id":"/docs/components/icon","type":"page","content":"Icon","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/icon"},"270":{"id":"/docs/components/icon-0","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon","content":"Flexible SVG icon component with on-demand loading, automatic caching, and extensive customization options"},"271":{"id":"/docs/components/icon-1","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#features","content":"Features"},"272":{"id":"/docs/components/icon-2","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#installation","content":"Installation"},"273":{"id":"/docs/components/icon-3","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#props","content":"Props"},"274":{"id":"/docs/components/icon-4","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#prop-inheritance","content":"Prop Inheritance"},"275":{"id":"/docs/components/icon-5","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#basic-usage","content":"Basic Usage"},"276":{"id":"/docs/components/icon-6","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#size-variants","content":"Size Variants"},"277":{"id":"/docs/components/icon-7","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/