al\")"},"842":{"id":"/docs/components/tag-35","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Communicating priority or category in project management and collaboration tools (e.g. \"High priority\", \"In review\")"},"843":{"id":"/docs/components/tag-36","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-not-to-use","content":"If users need to click or dismiss it — use a **Button** instead."},"844":{"id":"/docs/components/tag-37","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-not-to-use","content":"If the label is part of a sentence with no visual distinction — just use text."},"845":{"id":"/docs/components/text","page_id":"/docs/components/text","type":"page","content":"Text","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/text"},"846":{"id":"/docs/components/text-0","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text","content":"Text component for displaying and formatting text content with alignment and truncation options"},"847":{"id":"/docs/components/text-1","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#installation","content":"Installation"},"848":{"id":"/docs/components/text-2","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#props","content":"Props"},"849":{"id":"/docs/components/text-3","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#examples","content":"Examples"},"850":{"id":"/docs/components/text-4","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#as","content":"As"},"851":{"id":"/docs/components/text-5","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#align","content":"Align"},"852":{"id":"/docs/components/text-6","page_id":"/docs/components/text","ty