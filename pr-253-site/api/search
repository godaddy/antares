dules`."},"17":{"id":"/docs-15","page_id":"/docs","tags":[],"type":"text","url":"/docs#nextjs","content":"Add `@godaddy/antares` to `transpilePackages` so Next.js processes the package through its own CSS pipeline instead of treating it as a pre-built external:"},"18":{"id":"/docs-16","page_id":"/docs","tags":[],"type":"text","url":"/docs#nextjs","content":"Without this, Next.js will throw:"},"19":{"id":"/docs-17","page_id":"/docs","tags":[],"type":"text","url":"/docs#remix","content":"Remix with Vite handles CSS imports from `node_modules` in the client bundle automatically. However, during SSR, Vite treats `node_modules` as externals by default, which bypasses CSS processing. Add `@godaddy/antares` to `ssr.noExternal` to fix this:"},"20":{"id":"/docs-18","page_id":"/docs","tags":[],"type":"text","url":"/docs#vite","content":"Vite processes CSS imports from `node_modules` out of the box. No additional configuration is needed for client-side SPAs."},"21":{"id":"/docs-19","page_id":"/docs","tags":[],"type":"text","url":"/docs#vite","content":"If you are using Vite with SSR (e.g., custom SSR setup, not Remix), add `@godaddy/antares` to `ssr.noExternal` as shown in the Remix section."},"22":{"id":"/docs-20","page_id":"/docs","tags":[],"type":"text","url":"/docs#other-bundlers","content":"Any bundler that supports CSS imports will work with Antares. If your bundler does not process CSS imports from `node_modules` by default, ensure it is configured to do so. For example, with raw webpack you may need `css-loader` configured to handle `.css` files from `node_modules`."},"23":{"id":"/docs/components/alert","page_id":"/docs/components/alert","type":"page","content":"Alert","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/alert"},"24":{"id":"/docs/components/alert-0","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert","content":"In-page alerts are non-intrusive notifications within a webpage, providing users with timely information or feedback without disrupting their experience."},"25":{"id":"/docs/components/alert-1","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#installation","content":"Installation"},"26":{"id":"/docs/components/alert-2","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#props","content":"Props"},"27":{"id":"/docs/components/alert-3","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#examples","content":"Examples"},"28":{"id":"/docs/components/alert-4","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#basic-usage","content":"Basic Usage"},"29":{"id":"/docs/components/alert-5","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#emphasis-variants","content":"Emphasis Variants"},"30":{"id":"/docs/components/alert-6","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#dismissible","content":"Dismissible"},"31":{"id":"/docs/components/alert-7","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#with-action","content":"With Action"},"32":{"id":"/docs/components/alert-8","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#accessibility","content":"Accessibility"},"33":{"id":"/docs/components/alert-9","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#keyboard","content":"Keyboard"},"34":{"id":"/docs/components/alert-10","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#screen-readers","content":"Screen readers"},"35":{"id":"/docs/components/alert-11","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#dismiss-button-label","content":"Dismiss button label"},"36":{"id":"/docs/components/alert-12","page_id":"/docs/components/alert","type":"heading","tags":[],"url":"/docs/components/alert#best-practices","content":"Best Practices"},"37":{"id":"/docs/components/alert-13","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#basic-usage","content":"A minimal alert with a title and body text."},"38":{"id":"/docs/components/alert-14","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#emphasis-variants","content":"All 7 emphasis categories. Each variant carries a distinct visual accent and semantic icon so the type of message is never communicated by color alone."},"39":{"id":"/docs/components/alert-15","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#dismissible","content":"When an `onClose` callback is provided, a dismiss button is rendered. The component does not manage its own visibility — the parent is responsible for unmounting or hiding the alert when `onClose` fires."},"40":{"id":"/docs/components/alert-16","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#with-action","content":"Pass a `Button` to the `actions` slot to give the user a clear path to resolve the alert."},"41":{"id":"/docs/components/alert-17","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#keyboard","content":"Key"},"42":{"id":"/docs/components/alert-18","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#keyboard","content":"Description"},"43":{"id":"/docs/components/alert-19","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#keyboard","content":"`Tab`"},"44":{"id":"/docs/components/alert-20","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#keyboard","content":"Moves focus to the dismiss button or action button"},"45":{"id":"/docs/components/alert-21","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#keyboard","content":"`Space` / `Enter`"},"46":{"id":"/docs/components/alert-22","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#keyboard","content":"Activates the focused button"},"47":{"id":"/docs/components/alert-23","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#screen-readers","content":"The alert container uses `role=\"alert\"`, which creates an ARIA live region. When an alert is rendered or its content changes, screen readers announce the message automatically — the user does not need to navigate to the alert to hear it."},"48":{"id":"/docs/components/alert-24","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#dismiss-button-label","content":"The dismiss button defaults to `aria-label=\"Close\"`. Override it via `ariaLabels={{ close: '...' }}` to provide more specific context for screen readers (e.g. `\"Dismiss payment warning\"`). This is especially useful when multiple alerts are visible at the same time."},"49":{"id":"/docs/components/alert-25","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#best-practices","content":"Write alert content from the user's perspective: describe what happened and what they can do next, not the underlying technical error."},"50":{"id":"/docs/components/alert-26","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#best-practices","content":"Use `critical` only when the user truly cannot continue without resolving the issue. Overusing it reduces its impact."},"51":{"id":"/docs/components/alert-27","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#best-practices","content":"Always provide a `title` when the alert includes a dismiss button — it improves the reading experience for screen reader users."},"52":{"id":"/docs/components/alert-28","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#best-practices","content":"When using `actions`, prefer `secondary` or `tertiary` Button variants. Avoid placing a primary action inside an alert."},"53":{"id":"/docs/components/alert-29","page_id":"/docs/components/alert","tags":[],"type":"text","url":"/docs/components/alert#best-practices","content":"Do not stack multiple alerts of the same emphasis; consolidate the message into a single alert."},"54":{"id":"/docs/components/button","page_id":"/docs/components/button","type":"page","content":"Button","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/button"},"55":{"id":"/docs/components/button-0","page_id":"/docs/components/button","tags":[],"type":"text","url":"/docs/components/button","content":"The Button component allows users to initiate actions or submit forms with a single click"},"56":{"id":"/docs/components/button-1","page_id":"/docs/components/button","type":"heading","tags":[],"url":"/docs/components/button#installation","content":"Installation"},"57":{"id":"/docs/components/button-2","page_id":"/docs/components/button","type":"heading","tags":[],"url":"/docs/components/button#props","content":"Props"},"58":{"id":"/docs/components/button-3","page_id":"/docs/components/button","type":"heading","tags":[],"url":"/docs/components/button#examples","content":"Examples"},"59":{"id":"/docs/components/button-4","page_id":"/docs/components/button","type":"heading","tags":[],"url":"/docs/components/button#basic-usage","content":"Basic Usage"},"60":{"id":"/docs/components/button-5","page_id":"/docs/components/button","type":"heading","tags":[],"url":"/docs/components/button#primary","content":"Primary"},"61":{"id":"/docs/components/button-6","page_id":"/docs/components/button","type":"heading","tags":[],"url":"/docs/components/button#secondary","content":"Secondary"},"62":{"id":"/docs/components/button-7","page_id":"/docs/components/button","type":"heading","tags":[],"url":"/docs/compone