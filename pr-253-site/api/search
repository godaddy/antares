/docs/components/select","type":"heading","tags":[],"url":"/docs/components/select#form","content":"Form"},"789":{"id":"/docs/components/select-11","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#features","content":"**Label, description, error**: Optional label, helper text, and error message with proper accessibility"},"790":{"id":"/docs/components/select-12","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#features","content":"**Single or multiple selection**: Set `selectionMode=\"multiple\"` to allow multiple values"},"791":{"id":"/docs/components/select-13","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#features","content":"**Controlled or uncontrolled**: Use `value` and `onChange` for controlled state, or `defaultValue` for uncontrolled"},"792":{"id":"/docs/components/select-14","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#features","content":"**Validation states**: Use `isInvalid` with `errorMessage` and `isDisabled` for validation and disabled state"},"793":{"id":"/docs/components/select-15","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#features","content":"**Form integration**: Set `name` and the value submits as part of a native `<form>` (multiple values submit as repeated entries)"},"794":{"id":"/docs/components/select-16","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#features","content":"**React Aria integration**: Built on React Aria Select for accessibility, keyboard navigation, and typeahead"},"795":{"id":"/docs/components/select-17","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#props","content":"The Select component accepts the following props:"},"796":{"id":"/docs/components/select-18","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#basic","content":"Minimal usage with a label and a placeholder."},"797":{"id":"/docs/components/select-19","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#controlled","content":"Use `value` and `onChange` for controlled state."},"798":{"id":"/docs/components/select-20","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#multiple","content":"Set `selectionMode=\"multiple\"` to allow multiple values. `value` is an array of keys."},"799":{"id":"/docs/components/select-21","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#invalid","content":"Use `isInvalid` with `errorMessage` for validation feedback."},"800":{"id":"/docs/components/select-22","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#disabled","content":"Use `isDisabled` to prevent interaction."},"801":{"id":"/docs/components/select-23","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select#form","content":"Set `name` to submit the value with a native `<form>`. Multiple-mode values submit as repeated entries with the same `name`."},"802":{"id":"/docs/components/tag","page_id":"/docs/components/tag","type":"page","content":"Tag","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/tag"},"803":{"id":"/docs/components/tag-0","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag","content":"Non-interactive labels that highlight statuses and categories."},"804":{"id":"/docs/components/tag-1","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#installation","content":"Installation"},"805":{"id":"/docs/components/tag-2","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#props","content":"Props"},"806":{"id":"/docs/components/tag-3","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#examples","content":"Examples"},"807":{"id":"/docs/components/tag-4","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#basic","content":"Basic"},"808":{"id":"/docs/components/tag-5","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#emphasis","content":"Emphasis"},"809":{"id":"/docs/components/tag-6","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#sizes","content":"Sizes"},"810":{"id":"/docs/components/tag-7","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#inline","content":"Inline"},"811":{"id":"/docs/components/tag-8","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#high-contrast","content":"High Contrast"},"812":{"id":"/docs/components/tag-9","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#with-icon","content":"With Icon"},"813":{"id":"/docs/components/tag-10","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#indicator","content":"Indicator"},"814":{"id":"/docs/components/tag-11","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#accessibility","content":"Accessibility"},"815":{"id":"/docs/components/tag-12","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#screen-readers","content":"Screen readers"},"816":{"id":"/docs/components/tag-13","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#decorative-icons","content":"Decorative icons"},"817":{"id":"/docs/components/tag-14","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#indicator-dot","content":"Indicator dot"},"818":{"id":"/docs/components/tag-15","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#best-practices","content":"Best Practices"},"819":{"id":"/docs/components/tag-16","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#when-to-use","content":"When to Use"},"820":{"id":"/docs/components/tag-17","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#when-not-to-use","content":"When Not to Use"},"821":{"id":"/docs/components/tag-18","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#basic","content":"A minimal tag with the default emphasis and size."},"822":{"id":"/docs/components/tag-19","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#emphasis","content":"Nine emphasis options are available. Choose the one that fits the visual tone of your context."},"823":{"id":"/docs/components/tag-20","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#sizes","content":"Choose a size that fits the surrounding content. Smaller tags work well in compact layouts like tables; larger tags suit headings or hero sections."},"824":{"id":"/docs/components/tag-21","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#inline","content":"Use `design=\"inline\"` to embed a tag within a sentence. The background and border are removed so the tag blends into the text flow."},"825":{"id":"/docs/components/tag-22","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#high-contrast","content":"A bolder color treatment for when tags need to stand out more — for example, on colored backgrounds."},"826":{"id":"/docs/components/tag-23","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#with-icon","content":"Icons reinforce the tag's meaning at a glance. Add an `Icon` as a child — it inherits the tag's color and scales with its size."},"827":{"id":"/docs/components/tag-24","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#indicator","content":"A minimal style that pairs a small colored dot with a neutral background. Well suited for dense layouts like tables or dashboards where multiple tags in close proximity would otherwise compete for attention."},"828":{"id":"/docs/components/tag-25","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#screen-readers","content":"Tags are `<span>` elements with no special ARIA role. Screen readers announce the tag's text as part of normal page content — no extra markup is needed."},"829":{"id":"/docs/components/tag-26","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#decorative-icons","content":"Icons passed as children must include `aria-hidden=\"true\"` so they are skipped by screen readers. The text label is the sole carrier of meaning."},"830":{"id":"/docs/components/tag-27","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#indicator-dot","content":"The colored dot is decorative and invisible to screen readers. The text label must convey the status on its own — never rely on the dot alone to communicate meaning."},"831":{"id":"/docs/components/tag-28","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Use the indicator style in dense layouts like tables and dashboards. Use the filled style when the tag is a prominent, standalone element on a card or hero section."},"832":{"id":"/docs/components/tag-29","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Default to the small size in compact layouts like tables and lists. Use medium or large only when the tag needs to stand out as a primary piece of information."},"833":{"id":"/docs/components/tag-30","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Use the inline design only within running prose. In grouped or standalone contexts, the filled style provides better visual separation."},"834":{"id":"/docs/components/tag-31","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Do not stack multiple tags of different emphasis on the same item. Choose the most important one — too many competing labels lose their meaning."},"835":{"id":"/docs/components/tag-32","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Showing the status of an item on a card, table row, or list entry (e.g. \"Active\", \"Expired\", \"Pending\")"},"836":{"id":"/docs/components/tag-33","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Categorizing or grouping content so users can scan and filter quickly (e.g. \"New\", \"Sale\", \"Beta\")"},"837":{"id":"/docs/components/tag-34","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Surfacing metadata about an item (e.g. \"Pro\", \"Free trial\", \"Internal\")"},"838":{"id":"/docs/components/tag-35","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Communicating priority or category in project management and collaboration tools (e.g. \"High priority\", \"In review\")"},"839":{"id":"/docs/components/tag-36","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-not-to-use","content":"If users need to click or dismiss it — use a **Button** instead."},"840":{"id":"/docs/components/tag-37","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-not-to-use","content":"If the label is part of a sentence with no visual distinction — just use text."},"841":{"id":"/docs/components/text","page_id":"/docs/components/text","type":"page","content":"Text","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/text"},"842":{"id":"/docs/components/text-0","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text","content":"Text component for displaying and formatting text content with alignment and truncation options"},"843":{"id":"/docs/components/text-1","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#installation","content":"Installation"},"844":{"id":"/docs/components/text-2","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#props","content":"Props"},"845":{"id":"/docs/components/text-3","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#examples","content":"Examples"},"846":{"id":"/docs/components/text-4","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#as","content":"As"},"847":{"id":"/docs/components/text-5","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#align","content":"Align"},"848":{"id":"/docs/components/text-6","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#max-lines","content":"Max Lines"},"849":{"id":"/docs/components/text-7","page_id":"/docs/components/text","type":"heading","tags":[],"url":"/docs/components/text#wrap","content":"Wrap"},"850":{"id":"/docs/components/text-8","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text","content":"The `Text` component prepares content with a few properties."},"851":{"id":"/docs/components/text-9","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#props","content":"The `Text` component accepts the following props:"},"852":{"id":"/docs/components/text-10","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#as","content":"Setting the `as` prop allows you to change the HTML tag of the `Text` component."},"853":{"id":"/docs/components/text-11","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#align","content":"Setting the `align` prop allows you to change the alignment of the text. You can choose from `start`, `center`, `end`, or `justify`.\n`start` works like `left` and `end` works like `right`. These keywords support RTL languages so you do not need to worry about the language of the text."},"854":{"id":"/docs/components/text-12","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#max-lines","content":"Setting the `maxLines` prop allows you to limit the number of lines of text that are displayed using an ellipsis. In browsers that don't support multiline text truncation using `line-clamp`, the text will be truncated after a single line regardless of the number provided for `maxLines`."},"855":{"id":"/docs/components/text-13","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"Setting the `wrap` prop allows you to change the wrapping of the text. The values can be `wrap`, `nowrap`, `balance`, `pretty`, or `stable`."},"856":{"id":"/docs/components/text-14","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`wrap` is the setting that is most commonly used. For most elements you will not to explicitly set this."},"857":{"id":"/docs/components/text-15","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`nowrap` should be avoided except in cases where it is important to prevent the text from wrapping."},"858":{"id":"/docs/components/text-16","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`balance` is most commonly used for headlines, titles, and labels."},"859":{"id":"/docs/components/text-17","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`pretty` is most commonly used for body text."},"860":{"id":"/docs/components/text-18","page_id":"/docs/components/text","tags":[],"type":"text","url":"/docs/components/text#wrap","content":"`stable` is commonly used for editable text, such as textareas."},"861":{"id":"/docs/components/text-field","page_id":"/docs/components/text-field","type":"page","content":"TextField","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/text-field"},"862":{"id":"/docs/components/text-field-0","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field","content":"TextField is a single-line or multiline text input with optional label, description, and error message. Use it in forms for short answers (email, search, name) or longer content (comments). It supports optional leading and trailing text adornments (e.g. currency or units)."},"863":{"id":"/docs/components/text-field-1","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#features","content":"Features"},"864":{"id":"/docs/components/text-field-2","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#installation","content":"Installation"},"865":{"id":"/docs/components/text-field-3","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#props","content":"Props"},"866":{"id":"/docs/components/text-field-4","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#examples","content":"Examples"},"867":{"id":"/docs/components/text-field-5","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#basic","content":"Basic"},"868":{"id":"/docs/components/text-field-6","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#controlled","content":"Controlled"},"869":{"id":"/docs/components/text-field-7","page_id":"/docs/