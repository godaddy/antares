or toggling settings or features on/off"},"163":{"id":"/docs/components/checkbox-63","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#when-to-use-checkboxes","content":"✅ When all available options should be visible"},"164":{"id":"/docs/components/checkbox-64","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#when-to-use-checkboxes","content":"❌ For mutually exclusive options (use Radio instead)"},"165":{"id":"/docs/components/checkbox-65","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#when-to-use-checkboxes","content":"❌ For simple on/off toggles without labels (use Toggle/Switch instead)"},"166":{"id":"/docs/components/checkbox-66","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#label-guidelines","content":"Use clear, concise labels that describe what selecting the option means"},"167":{"id":"/docs/components/checkbox-67","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#label-guidelines","content":"Keep labels short (1-5 words when possible)"},"168":{"id":"/docs/components/checkbox-68","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#label-guidelines","content":"Ensure labels are descriptive without being verbose"},"169":{"id":"/docs/components/checkbox-69","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#label-guidelines","content":"Place the most commonly selected options first in groups"},"170":{"id":"/docs/components/checkbox-70","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#validation","content":"Always provide clear error messages and use appropriate validation states:"},"171":{"id":"/docs/components/checkbox-71","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#group-organization","content":"Limit checkbox groups to 7-10 options for better usability"},"172":{"id":"/docs/components/checkbox-72","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#group-organization","content":"Use logical ordering (alphabetical, frequency of use, or importance)"},"173":{"id":"/docs/components/checkbox-73","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#group-organization","content":"Consider using CheckboxGroup for related options, even if there are only 2-3"},"174":{"id":"/docs/components/checkbox-74","page_id":"/docs/components/checkbox","tags":[],"type":"text","url":"/docs/components/checkbox#group-organization","content":"Provide a group label that clearly describes the choice being made"},"175":{"id":"/docs/components/circular-progress","page_id":"/docs/components/circular-progress","type":"page","content":"CircularProgress","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/circular-progress"},"176":{"id":"/docs/components/circular-progress-0","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress","content":"A circular progress indicator shows determinate progress of an operation over time"},"177":{"id":"/docs/components/circular-progress-1","page_id":"/docs/components/circular-progress","type":"heading","tags":[],"url":"/docs/components/circular-progress#installation","content":"Installation"},"178":{"id":"/docs/components/circular-progress-2","page_id":"/docs/components/circular-progress","type":"heading","tags":[],"url":"/docs/components/circular-progress#props","content":"Props"},"179":{"id":"/docs/components/circular-progress-3","page_id":"/docs/components/circular-progress","type":"heading","tags":[],"url":"/docs/components/circular-progress#examples","content":"Examples"},"180":{"id":"/docs/components/circular-progress-4","page_id":"/docs/components/circular-progress","type":"heading","tags":[],"url":"/docs/components/circular-progress#basic-usage","content":"Basic Usage"},"181":{"id":"/docs/components/circular-progress-5","page_id":"/docs/components/circular-progress","type":"heading","tags":[],"url":"/docs/components/circular-progress#sizes","content":"Sizes"},"182":{"id":"/docs/components/circular-progress-6","page_id":"/docs/components/circular-progress","type":"heading","tags":[],"url":"/docs/components/circular-progress#emphasis","content":"Emphasis"},"183":{"id":"/docs/components/circular-progress-7","page_id":"/docs/components/circular-progress","type":"heading","tags":[],"url":"/docs/components/circular-progress#accessibility","content":"Accessibility"},"184":{"id":"/docs/components/circular-progress-8","page_id":"/docs/components/circular-progress","type":"heading","tags":[],"url":"/docs/components/circular-progress#aria-support","content":"ARIA Support"},"185":{"id":"/docs/components/circular-progress-9","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#sizes","content":"Four circle diameters are available: `sm` (64px), `md` (96px), `lg` (128px), and `xl` (160px)."},"186":{"id":"/docs/components/circular-progress-10","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#emphasis","content":"Use the `emphasis` prop to communicate status: `success`, `warning`, or `critical`. When omitted, the default teal fill is used."},"187":{"id":"/docs/components/circular-progress-11","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`role=\"progressbar\"` on the container"},"188":{"id":"/docs/components/circular-progress-12","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`aria-valuenow` reflects the current value (clamped to 0–100)"},"189":{"id":"/docs/components/circular-progress-13","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`aria-valuemin` and `aria-valuemax` define the range (default `0`–`100`)"},"190":{"id":"/docs/components/circular-progress-14","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`aria-valuetext` provides a formatted string (e.g. `\"60%\"`) via `Intl.NumberFormat`; the same string is rendered inside the circle. Override the text with the `aria-valuetext` prop, or control formatting with `formatOptions`"},"191":{"id":"/docs/components/circular-progress-15","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`aria-labelledby` associates the visible label when the `label` prop is provided"},"192":{"id":"/docs/components/circular-progress-16","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"`aria-describedby` wires the `helperText` to the progressbar for screen readers"},"193":{"id":"/docs/components/circular-progress-17","page_id":"/docs/components/circular-progress","tags":[],"type":"text","url":"/docs/components/circular-progress#aria-support","content":"The decorative SVG and output text are hidden via `aria-hidden=\"true\"`"},"194":{"id":"/docs/components/drawer","page_id":"/docs/components/drawer","type":"page","content":"Drawer","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/drawer"},"195":{"id":"/docs/components/drawer-0","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer","content":"An overlay panel that slides in from a screen edge, supporting sidebar navigation and bottom sheets."},"196":{"id":"/docs/components/drawer-1","page_id":"/docs/