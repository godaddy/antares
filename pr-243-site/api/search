onents/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"The component automatically adds data attributes for styling hooks:"},"408":{"id":"/docs/components/icon-73","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-icon`: The icon name (always present)"},"409":{"id":"/docs/components/icon-74","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-color`: Applied when color prop is set"},"410":{"id":"/docs/components/icon-75","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-loading`: Applied during icon loading from CDN"},"411":{"id":"/docs/components/icon-76","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-mode`: Applied when mode prop is set (e.g., \"sprite\")"},"412":{"id":"/docs/components/icon-77","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-flip`: Applied when flip prop is set (\"horizontal\" or \"vertical\")"},"413":{"id":"/docs/components/icon-78","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`data-rotate`: Applied when rotate prop is set (90, 180, or 270)"},"414":{"id":"/docs/components/icon-79","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"The component also includes accessibility attributes:"},"415":{"id":"/docs/components/icon-80","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`role=\"presentation\"`: For decorative icons"},"416":{"id":"/docs/components/icon-81","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`role=\"img\"`: When title prop is provided"},"417":{"id":"/docs/components/icon-82","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#data-attributes","content":"`focusable=\"false\"`: Prevents keyboard focus"},"418":{"id":"/docs/components/icon-83","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#inherit-from-parent-default","content":"By default, icons inherit the color from their parent element via `currentColor`:"},"419":{"id":"/docs/components/icon-84","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#explicit-colors","content":"Override the color with specific values:"},"420":{"id":"/docs/components/icon-85","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#icon-transformations","content":"Transform capabilities are inherited from the Bento Illustration component. For complete transformation options and implementation details, see the `@bento/illustration` package documentation."},"421":{"id":"/docs/components/icon-86","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#rotation","content":"Rotate icons by 90-degree increments:"},"422":{"id":"/docs/components/icon-87","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#flipping","content":"Flip icons horizontally or vertically:"},"423":{"id":"/docs/components/icon-88","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#placeholder-content","content":"Provide fallback SVG content while icons load from the CDN:"},"424":{"id":"/docs/components/icon-89","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#decorative-icons","content":"For purely decorative icons, no additional attributes are needed. The icon will have `role=\"presentation\"` and be ignored by screen readers:"},"425":{"id":"/docs/components/icon-90","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#semantic-icons","content":"For icons that convey meaning, use the `title` prop. This automatically adds `role=\"img\"` and provides screen reader accessible text:"},"426":{"id":"/docs/components/icon-91","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#interactive-icons","content":"For interactive icons within buttons or links, use the `title` prop on the icon and `aria-label` on the interactive element:"},"427":{"id":"/docs/components/icon-92","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#default-icon-loading","content":"Icons are loaded on-demand from a CDN using the following process:"},"428":{"id":"/docs/components/icon-93","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#default-icon-loading","content":"**First Request**: When an icon is first encountered, it triggers an asynchronous fetch from the CDN"},"429":{"id":"/docs/components/icon-94","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#default-icon-loading","content":"**SVG Parsing**: The fetched SVG string is parsed into a React element using `@bento/svg-parser`"},"430":{"id":"/docs/components/icon-95","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#default-icon-loading","content":"**Automatic Caching**: Once loaded, the icon is cached in memory to avoid subsequent network requests"},"431":{"id":"/docs/components/icon-96","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#default-icon-loading","content":"**Full SVG Rendering**: Each icon instance renders as a complete SVG element with all path data"},"432":{"id":"/docs/components/icon-97","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#default-icon-loading","content":"This approach works well for SSR and small numbers of icons, but can lead to DOM bloat when the same icon appears many times."},"433":{"id":"/docs/components/icon-98","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"When `mode=\"sprite\"` is enabled, the component switches to a more efficient rendering strategy:"},"434":{"id":"/docs/components/icon-99","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**What happens with sprite mode:**"},"435":{"id":"/docs/components/icon-100","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**Sprite Sheet Creation**: A hidden SVG sprite sheet is automatically injected into the DOM containing symbol definitions"},"436":{"id":"/docs/components/icon-101","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**Reference Rendering**: Each icon renders as a lightweight `<use>` element that references the sprite"},"437":{"id":"/docs/components/icon-102","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**Deduplication**: Icon path data only exists once in the sprite sheet, regardless of how many times it's used"},"438":{"id":"/docs/components/icon-103","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**Client-Side Hydration**: The sprite sheet is generated and injected after hydration, causing a brief paint event"},"439":{"id":"/docs/components/icon-104","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**DOM Output:**"},"440":{"id":"/docs/components/icon-105","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**Performance Benefits:**"},"441":{"id":"/docs/components/icon-106","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**Reduced DOM Size**: Path data stored once instead of duplicated"},"442":{"id":"/docs/components/icon-107","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**Lower Memory Usage**: Especially beneficial with many repeated icons"},"443":{"id":"/docs/components/icon-108","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**Faster Rendering**: Browser optimizations for `<use>` elements"},"444":{"id":"/docs/components/icon-109","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**Trade-offs:**"},"445":{"id":"/docs/components/icon-110","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**SSR Limitation**: Sprite references render empty until client-side hydration"},"446":{"id":"/docs/components/icon-111","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#sprite-mode-optimization","content":"**Initial Flash**: Brief moment where icons appear/disappear during sprite injection"},"447":{"id":"/docs/components/icon-112","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#recommendations","content":"**Use default mode** for SSR applications or when icons appear infrequently"},"448":{"id":"/docs/components/icon-113","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#recommendations","content":"**Use sprite mode** when the same icons appear many times (navigation, lists, tables)"},"449":{"id":"/docs/components/icon-114","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#recommendations","content":"**Consider preloading** frequently used icons to reduce loading delays"},"450":{"id":"/docs/components/icon-115","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#recommendations","content":"**Provide fallback content** for critical icons to handle loading states"},"451":{"id":"/docs/components/icon-116","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#icon-not-loading","content":"If an icon fails to load:"},"452":{"id":"/docs/components/icon-117","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#icon-not-loading","content":"**Check icon name**: Ensure the icon exists in the CDN"},"453":{"id":"/docs/components/icon-118","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#icon-not-loading","content":"**Network connectivity**: Verify CDN is accessible"},"454":{"id":"/docs/components/icon-119","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#icon-not-loading","content":"**Check browser console**: Look for network errors"},"455":{"id":"/docs/components/icon-120","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#icon-not-loading","content":"**Fallback content**: Provide placeholder content for loading states"},"456":{"id":"/docs/components/icon-121","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#performance-issues","content":"For performance optimization:"},"457":{"id":"/docs/components/icon-122","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#performance-issues","content":"**Preload common icons**: Consider preloading frequently used icons"},"458":{"id":"/docs/components/icon-123","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#performance-issues","content":"**Use sprite mode**: For repeated icons, consider sprite mode which consolidates multiple icons into a single SVG sprite sheet, reducing DOM size and improving performance when the same icon appears multiple times"},"459":{"id":"/docs/components/icon-124","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon#performance-issues","content":"**Minimize icon sets**: Only load icons that are actually used"},"460":{"id":"/docs/components/field","page_id":"/docs/components/field","type":"page","content":"Field primitives","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/field"},"461":{"id":"/docs/components/field-0","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"Composable primitives (Field, FieldLabel, FieldGroup, FieldError) for building form fields"},"462":{"id":"/docs/components/field-1","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#usage","content":"Usage"},"463":{"id":"/docs/components/field-2","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#fieldgroup-props","content":"FieldGroup props"},"464":{"id":"/docs/components/field-3","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#basic-example","content":"Basic example"},"465":{"id":"/docs/components/field-4","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#composition","content":"Composition"},"466":{"id":"/docs/components/field-5","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#positioning-controls-inside-the-group","content":"Positioning controls inside the group"},"467":{"id":"/docs/components/field-6","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#states","content":"States"},"468":{"id":"/docs/components/field-7","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#examples","content":"Examples"},"469":{"id":"/docs/components/field-8","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#leading-control","content":"Leading control"},"470":{"id":"/docs/components/field-9","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#trailing-control","content":"Trailing control"},"471":{"id":"/docs/components/field-10","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#icon-accessories","content":"Icon accessories"},"472":{"id":"/docs/components/field-11","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**Composition primitives.** The field components (TextField, NumberField, DateField, Select, RadioGroup, CheckboxGroup) compose these internally — reach for those first. These primitives are also the building blocks for custom composite fields, e.g. an input and a select sharing one bordered box."},"473":{"id":"/docs/components/field-12","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"The field decoration is split into granular, composable pieces so the same structure is shared across every field:"},"474":{"id":"/docs/components/field-13","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`Field`** — stacks a field's label, control, description, and error in one consistently spaced column (pure layout — a `Flex` column with the standard field gap)."},"475":{"id":"/docs/components/field-14","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldLabel`** — names the field and flags whether it's required (wraps React Aria `Label`, rendering an optional `*` indicator)."},"476":{"id":"/docs/components/field-15","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldGroup`** — the bordered box that visually unites a field's controls and reflects their shared focus, disabled, and invalid state. Used only by \"boxed\" fields (TextField, NumberField, Select, DateField); presentationally it is a React Aria `Group`."},"477":{"id":"/docs/components/field-16","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldInput`** — the single-line control the user types into (a normalized React Aria `Input` given antares spacing via `Box`)."},"478":{"id":"/docs/components/field-17","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldTextArea`** — the multiline control the user types into (a normalized React Aria `TextArea` given antares spacing via `Box`)."},"479":{"id":"/docs/components/field-18","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldButton`** — an actionable control placed inside the box, such as the NumberField steppers or a search submit (a click target within the group)."},"480":{"id":"/docs/components/field-19","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldTrigger`** — a full-width value-display button inside the box that opens an overlay (used by Select and DatePicker): a value area plus a trailing icon, laid out across the group. `variant=\"select\"` is transparent and input-like; `variant=\"control\"` is a filled segment inside a shared group."},"481":{"id":"/docs/components/field-20","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldDescription`** — helper text that explains the field; renders nothing when empty (wraps the antares `Text` with `slot=\"description\"`)."},"482":{"id":"/docs/components/field-21","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldError`** — surfaces the field's validation messages when it is invalid, and nothing when valid (a thin wrapper over React Aria `FieldError`)."},"483":{"id":"/docs/components/field-22","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"`FieldLabel`, `FieldDescription`, and `FieldError` each render `null` when they have no content, so callers pass `label` / `description` / `errorMessage` straight through without guarding."},"484":{"id":"/docs/components/field-23","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"A boxed field composes the primitives inside its React Aria field wrapper. Use\n`Field as={...}` to merge the field wrapper and the layout column into a single\nelement:"},"485":{"id":"/docs/components/field-24","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"A field without a box (RadioGroup / CheckboxGroup) composes `Field` + `FieldLabel` + `FieldError` and omits `FieldGroup`."},"486":{"id":"/docs/components/field-25","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"`FieldGroup` is purely presentational — it renders the styled `Group` and holds no React Aria context. The surrounding field wires value, disabled, and validation state into its controls."},"487":{"id":"/docs/components/field-26","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#positioning-controls-inside-the-group","content":"`FieldGroup` rounds its outer corners from DOM order: the group's CSS rounds the start corners of its **first child** and the end corners of its **last child**, so controls are seamless inside and rounded only at the box edges. Author children in visual order and the rounding follows — no per-control positioning prop. A lone control (a TextField input, a Select trigger) is both first and last, so it rounds both edges. The rules are RTL-safe (they use logical `start`/`end` corners)."},"488":{"id":"/docs/components/field-27","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"The states **disabled**, **readonly**, and **invalid** are applied by the field wrapper (e.g. TextField, NumberField, Select). The group reflects them via data attributes on the group."},"489":{"id":"/docs/components/field-28","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"State"},"490":{"id":"/docs/components/field-29","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"CSS Selector"},"491":{"id":"/docs/components/field-30","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"disabled — Applied when the field wrapper is disabled."},"492":{"id":"/docs/components/field-31","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-disabled]`"},"493":{"id":"/docs/components/field-32","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"invalid — Applied when the field wrapper is invalid (e.g. validation failed)."},"494":{"id":"/docs/components/field-33","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-invalid]`"},"495":{"id":"/docs/components/field-34","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"focus — Whether an element within the group has keyboard focus (for focus-ring styling)."},"496":{"id":"/docs/components/field-35","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-focused]`"},"497":{"id":"/docs/components/inline-drawer","page_id":"/docs/components/inline-drawer","type":"page","content":"InlineDrawer","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/inline-drawer"},"498":{"id":"/docs/components/inline-drawer-0","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer","content":"An in-flow collapsible panel that expands and collapses along one axis, supporting sidebar navigation and persistent collapsed content."},"499":{"id":"/docs/components/inline-drawer-1","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#features","content":"Features"},"500":{"id":"/docs/components/inline-drawer-2","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#installation","content":"Installation"},"501":{"id":"/docs/components/inline-drawer-3","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#props","content":"Props"},"502":{"id":"/docs/components/inline-drawer-4","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#examples","content":"Examples"},"503":{"id":"/docs/components/inline-drawer-5","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#basic-usage","content":"Basic Usage"},"504":{"id":"/docs/components/inline-drawer-6","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#controlled","content":"Controlled"},"505":{"id":"/docs/components/inline-drawer-7","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#sidebar-navigation","content":"Sidebar Navigation"},"506":{"id":"/docs/components/inline-drawer-8","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#vertical-placement","content":"Vertical Placement"},"507":{"id":"/docs/components/inline-drawer-9","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#dismiss-on-blur","content":"Dismiss on Blur"},"508":{"id":"/docs/components/inline-drawer-10","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#focus-scope","content":"Focus Scope"},"509":{"id":"/docs/components/inline-drawer-11","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#accessibility","content":"Accessibility"},"510":{"id":"/docs/components/inline-drawer-12","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#keyboard","content":"Keyboard"},"511":{"id":"/docs/components/inline-drawer-13","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#aria","content":"ARIA"},"512":{"id":"/docs/components/inline-drawer-14","page_id":"/docs/components/inline-drawer","type":"heading","tags":[],"url":"/docs/components/inline-drawer#best-practices","content":"Best Practices"},"513":{"id":"/docs/components/inline-drawer-15","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#features","content":"In-flow collapsible panel with CSS transitions"},"514":{"id":"/docs/components/inline-drawer-16","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#features","content":"`minSize` keeps collapsed content visible (sidebar nav pattern)"},"515":{"id":"/docs/components/inline-drawer-17","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#features","content":"`shouldDismissOnBlur` with portal-aware focus detection"},"516":{"id":"/docs/components/inline-drawer-18","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#features","content":"Controlled and uncontrolled modes"},"517":{"id":"/docs/components/inline-drawer-19","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#features","content":"`hidden=\"until-found\"` for browser find-in-page support"},"518":{"id":"/docs/components/inline-drawer-20","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#features","content":"`prefers-reduced-motion` support"},"519":{"id":"/docs/components/inline-drawer-21","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#basic-usage","content":"The panel toggles when the trigger is pressed, pushing adjacent content as it expands."},"520":{"id":"/docs/components/inline-drawer-22","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#controlled","content":"Use `isExpanded` and `onExpandedChange` to drive state externally, e.g. from a button outside the drawer."},"521":{"id":"/docs/components/inline-drawer-23","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#sidebar-navigation","content":"Combine `minSize` and `maxSize` to create a sidebar that collapses to an icon strip instead of disappearing completely."},"522":{"id":"/docs/components/inline-drawer-24","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#vertical-placement","content":"Set `placement=\"top\"` or `\"bottom\"` to collapse vertically instead of horizontally."},"523":{"id":"/docs/components/inline-drawer-25","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#dismiss-on-blur","content":"Set `shouldDismissOnBlur` to auto-collapse when focus leaves the drawer. Tab from the inside button to the outside button to see it collapse. Focus moving to browser chrome (address bar, devtools) does not trigger collapse."},"524":{"id":"/docs/components/inline-drawer-26","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#focus-scope","content":"Wrap panel content in `<FocusScope>` to trap focus while expanded. Tab cycles between Action A and Action B without escaping to main content. Use `contain={isExpanded}` so trapping only applies when open."},"525":{"id":"/docs/components/inline-drawer-27","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#keyboard","content":"Key"},"526":{"id":"/docs/components/inline-drawer-28","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#keyboard","content":"Action"},"527":{"id":"/docs/components/inline-drawer-29","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#keyboard","content":"`Enter` / `Space`"},"528":{"id":"/docs/components/inline-drawer-30","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#keyboard","content":"Toggle the drawer via the trigger button"},"529":{"id":"/docs/components/inline-drawer-31","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#keyboard","content":"`Tab`"},"530":{"id":"/docs/components/inline-drawer-32","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#keyboard","content":"Move focus into/out of the panel (or trapped when using `FocusScope`)"},"531":{"id":"/docs/components/inline-drawer-33","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#aria","content":"`aria-expanded` on the trigger button reflects panel state (via RAC Disclosure)"},"532":{"id":"/docs/components/inline-drawer-34","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#aria","content":"`aria-controls` links the trigger to the panel"},"533":{"id":"/docs/components/inline-drawer-35","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#aria","content":"`hidden=\"until-found\"` on collapsed panels (browser find-in-page support)"},"534":{"id":"/docs/components/inline-drawer-36","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#aria","content":"Panels with `minSize` override `aria-hidden` to keep collapsed content accessible"},"535":{"id":"/docs/components/inline-drawer-37","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#best-practices","content":"Use `minSize` + `maxSize` for sidebar patterns where collapsed content stays visible."},"536":{"id":"/docs/components/inline-drawer-38","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#best-practices","content":"`FocusScope` is opt-in. Don't combine `contain={true}` with `shouldDismissOnBlur` (trapped focus can't leave to trigger blur)."},"537":{"id":"/docs/components/inline-drawer-39","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#best-practices","content":"Collapsed panels use `hidden=\"until-found\"` for browser find-in-page support. Panels with `minSize` override this to keep content visible."},"538":{"id":"/docs/components/inline-drawer-40","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#best-practices","content":"Don't nest InlineDrawers."},"539":{"id":"/docs/components/listbox","page_id":"/docs/components/listbox","type":"page","content":"ListBox","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/listbox"},"540":{"id":"/docs/components/listbox-0","page_id":"/docs/components/listbox","tags":[],"type":"text","url":"/docs/components/listbox","content":"ListBox is a selectable collection of items rendered inline. Use it for non-popover pickers, inline lists, or as a building block for higher-level components like Select."},"541":{"id":"/docs/components/listbox-1","page_id":"/docs/components/listbox","type":"heading","tags":[],"url":"/docs/components/listbox#features","content":"Features"},"542":{"id":"/docs/components/listbox-2","page_id":"/docs/components/listbox","type":"heading","tags":[],"url":"/docs/components/listbox#installation","content":"Installation"},"543":{"id":"/docs/components/listbox-3","page_id":"/docs/components/listbox","type":"heading","tags":[],"url":"/docs/components/listbox#props","content":"Props"},"544":{"id":"/docs/components/listbox-4","page_id":"/docs/components/listbox","type":"heading","tags":[],"url":"/docs/components/listbox#examples","content":"Examples"},"545":{"id":"/docs/components/listbox-5","page_id":"/docs/components/listbox","type":"heading","tags":[],"url":"/docs/components/listbox#basic","content":"Basic"},"546":{"id":"/docs/components/listbox-6","page_id":"/docs/components/listbox","type":"heading","tags":[],"url":"/docs/components/listbox#controlled","content":"Controlled"},"547":{"id":"/docs/components/listbox-7","page_id":"/docs/components/listbox","type":"heading","tags":[],"url":"/docs/components/listbox#multiple","content":"Multiple"},"548":{"id":"/docs/components/listbox-8","page_id":"/docs/components/listbox","tags":[],"type":"text","url":"/docs/components/listbox#features","content":"**Single or multiple selection**: Set `selectionMode=\"single\"` or `\"multiple\"`."},"549":{"id":"/docs/components/listbox-9","page_id":"/docs/components/listbox","tags":[],"type":"text","url":"/docs/components/listbox#features","content":"**Controlled or uncontrolled**: Use `selectedKeys` and `onSelectionChange` for controlled state, or `defaultSelectedKeys` for uncontrolled."},"550":{"id":"/docs/components/listbox-10","page_id":"/docs/components/listbox","tags":[],"type":"text","url":"/docs/components/listbox#features","content":"**Layout primitive**: `ListBox` and `ListBoxItem` accept layout props (`gap`, `padding`, etc.) — they extend `FlexOwnProps`."},"551":{"id":"/docs/components/listbox-11","page_id":"/docs/components/listbox","tags":[],"type":"text","url":"/docs/components/listbox#features","content":"**Composes into other components**: `Select` uses `ListBox` internally; reach for `ListBox` directly when you need an inline list rather than a popover dropdown."},"552":{"id":"/docs/components/listbox-12","page_id":"/docs/components/listbox","tags":[],"type":"text","url":"/docs/components/listbox#features","content":"**React Aria integration**: Built on React Aria ListBox for accessibility, keyboard navigation, and typeahead."},"553":{"id":"/docs/components/listbox-13","page_id":"/docs/components/listbox","tags":[],"type":"text","url":"/docs/components/listbox#features","content":"`ListBox` requires either `aria-label` or `aria-labelledby`. For a labeled, popover-style picker, prefer `Select`."},"554":{"id":"/docs/components/listbox-14","page_id":"/docs/components/listbox","tags":[],"type":"text","url":"/docs/components/listbox#props","content":"The ListBox component accepts the following props:"},"555":{"id":"/docs/components/listbox-15","page_id":"/docs/components/listbox","tags":[],"type":"text","url":"/docs/components/listbox#basic","content":"Single selection with static children. Use `aria-label` to give the listbox an accessible name."},"556":{"id":"/docs/components/listbox-16","page_id":"/docs/components/listbox","tags":[],"type":"text","url":"/docs/components/listbox#controlled","content":"Use `selectedKeys` and `onSelectionChange` for controlled state."},"557":{"id":"/docs/components/listbox-17","page_id":"/docs/components/listbox","tags":[],"type":"text","url":"/docs/components/listbox#multiple","content":"Set `selectionMode=\"multiple\"` to allow multiple values. `selectedKeys` is a `Set<Key>` (or the literal `'all'`)."},"558":{"id":"/docs/components/menu","page_id":"/docs/components/menu","type":"page","content":"Menu","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/menu"},"559":{"id":"/docs/components/menu-0","page_id":"/docs/components/menu","tags":[],"type":"text","url":"/docs/components/menu","content":"Accessible dropdown menu supporting keyboard navigation, nested submenus, and flexible item rendering"},"560":{"id":"/docs/components/menu-1","page_id":"/docs/components/menu","type":"heading","tags":[],"url":"/docs/components/menu#installation","content":"Installation"},"561":{"id":"/docs/components/menu-2","page_id":"/docs/components/menu","type":"heading","tags":[],"url":"/docs/components/menu#props","content":"Props"},"562":{"id":"/docs/components/menu-3","page_id":"/docs/components/menu","type":"heading","tags":[],"url":"/docs/components/menu#examples","content":"Examples"},"563":{"id":"/docs/components/menu-4","page_id":"/docs/components/menu","type":"heading","tags":[],"url":"/docs/components/menu#basic","content":"Basic"},"564":{"id":"/docs/components/menu-5","page_id":"/docs/components/menu","type":"heading","tags":[],"url":"/docs/components/menu#with-submenus","content":"With Submenus"},"565":{"id":"/docs/components/menu-6","page_id":"/docs/components/menu","type":"heading","tags":[],"url":"/docs/components/menu#with-selection","content":"With Selection"},"566":{"id":"/docs/components/menu-7","page_id":"/docs/components/menu","type":"heading","tags":[],"url":"/docs/components/menu#with-sections","content":"With Sections"},"567":{"id":"/docs/components/menu-8","page_id":"/docs/components/menu","type":"heading","tags":[],"url":"/docs/components/menu#customization","content":"Customization"},"568":{"id":"/docs/components/menu-9","page_id":"/docs/components/menu","type":"heading","tags":[],"url":"/docs/components/menu#data-attributes","content":"Data Attributes"},"569":{"id":"/docs/components/menu-10","page_id":"/docs/componen