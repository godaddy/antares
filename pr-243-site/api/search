steps-11","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#customization","content":"Customization"},"725":{"id":"/docs/components/progress-steps-12","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#accessibility","content":"Accessibility"},"726":{"id":"/docs/components/progress-steps-13","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#best-practices","content":"Best Practices"},"727":{"id":"/docs/components/progress-steps-14","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#troubleshooting","content":"Troubleshooting"},"728":{"id":"/docs/components/progress-steps-15","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Horizontal and vertical orientations"},"729":{"id":"/docs/components/progress-steps-16","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Four completion statuses (`none`, `partial`, `complete`, `error`) with status icons"},"730":{"id":"/docs/components/progress-steps-17","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Timeline (past / current / future) derived from a single `currentStep` prop"},"731":{"id":"/docs/components/progress-steps-18","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Auto-generated step numbers (opt out with `hideStepNumbers`)"},"732":{"id":"/docs/components/progress-steps-19","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Interactive (navigable) and inert (display-only) steps"},"733":{"id":"/docs/components/progress-steps-20","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Title truncation and RTL support"},"734":{"id":"/docs/components/progress-steps-21","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Rendered as a `<nav>` landmark with an ordered list for assistive technology"},"735":{"id":"/docs/components/progress-steps-22","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#props","content":"The `ProgressSteps` component has the following props:"},"736":{"id":"/docs/components/progress-steps-23","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#props","content":"The `ProgressStep` component has the following props:"},"737":{"id":"/docs/components/progress-steps-24","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#default","content":"A horizontal stepper. `currentStep` marks the active step; earlier steps are `past`, later are `future`. Each `status` sets the step's icon, and an `error` step turns its accent bar red."},"738":{"id":"/docs/components/progress-steps-25","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#not-started","content":"Omit `currentStep` for a flow that hasn't begun: every step is `future` and none is marked current."},"739":{"id":"/docs/components/progress-steps-26","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#vertical","content":"Use `orientation=\"vertical\"` to place the accent bar on the leading edge and stack steps in a column."},"740":{"id":"/docs/components/progress-steps-27","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#interactive","content":"Give a step an `onPress` handler to make it navigable. Steps without `onPress` are inert."},"741":{"id":"/docs/components/progress-steps-28","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#disabled","content":"A disabled interactive step is muted, removed from the tab order, and cannot be activated."},"742":{"id":"/docs/components/progress-steps-29","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#hide-step-numbers","content":"Step numbers are prepended automatically. Set `hideStepNumbers` to omit them."},"743":{"id":"/docs/components/progress-steps-30","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"Step numbers (`\"N. \"`) are prepended automatically — keep them where possible, as user testing shows people recognize the component better with them. Set `hideStepNumbers` to omit them."},"744":{"id":"/docs/components/progress-steps-31","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"`orientation` switches between `horizontal` (accent bar on top) and `vertical` (accent bar on the leading edge)."},"745":{"id":"/docs/components/progress-steps-32","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"`currentStep` is the single source of truth for the timeline. Omit it for a not-yet-started flow where every step is `future`; pass the step count for a fully completed flow where every step is `past`."},"746":{"id":"/docs/components/progress-steps-33","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"`status` is independent of timeline and only controls the status icon and (for `error`) the accent bar color."},"747":{"id":"/docs/components/progress-steps-34","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"Pass `className` to the container or an individual step to extend the styles."},"748":{"id":"/docs/components/progress-steps-35","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#accessibility","content":"The container renders a `<nav>` landmark; set `aria-label` to name it (defaults to `\"Progress\"`)."},"749":{"id":"/docs/components/progress-steps-36","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#accessibility","content":"Steps are an ordered list (`<ol>`/`<li>`) so assistive technology conveys position and count."},"750":{"id":"/docs/components/progress-steps-37","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#accessibility","content":"The current step is marked with `aria-current=\"step\"`."},"751":{"id":"/docs/components/progress-steps-38","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#accessibility","content":"Interactive steps are real buttons: focusable in the natural **Tab** order and activated with **Enter** or **Space**. Status icons are decorative (`aria-hidden`)."},"752":{"id":"/docs/components/progress-steps-39","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#accessibility","content":"Focus is shown with a visible outline; disabled steps use `0.4` opacity and are not focusable."},"753":{"id":"/docs/components/progress-steps-40","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#best-practices","content":"Drive the timeline from `currentStep` rather than styling individual steps."},"754":{"id":"/docs/components/progress-steps-41","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#best-practices","content":"Provide `onPress` only for steps a user can actually navigate to; leave it off for display-only steps."},"755":{"id":"/docs/components/progress-steps-42","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#best-practices","content":"Keep titles short — they truncate with an ellipsis when space is tight."},"756":{"id":"/docs/components/progress-steps-43","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#best-practices","content":"Always give the container an `aria-label` that describes the flow (e.g. `\"Checkout progress\"`)."},"757":{"id":"/docs/components/progress-steps-44","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#troubleshooting","content":"**No step is highlighted:** `currentStep` is omitted, negative, or out of range. Set it to the active step's 0-based index."},"758":{"id":"/docs/components/progress-steps-45","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#troubleshooting","content":"**A step isn't clickable:** it has no `onPress`, so it's inert by design. Add `onPress` to make it interactive."},"759":{"id":"/docs/components/progress-steps-46","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#troubleshooting","content":"**Titles overflow:** that's expected — titles truncate. Shorten the title."},"760":{"id":"/docs/components/radio","page_id":"/docs/components/radio","type":"page","content":"Radio","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/radio"},"761":{"id":"/docs/components/radio-0","page_id":"/docs/components/radio","tags":[],"type":"text","url":"/docs/components/radio","content":"Accessible radio button component 