reater than 1, the number of pages (dots) is derived from `Math.ceil(total / limit)`. For example, 10 items with a limit of 3 produces 4 pages (dots)."},"706":{"id":"/docs/components/pagination-13","page_id":"/docs/components/pagination","tags":[],"type":"text","url":"/docs/components/pagination#onchange-event","content":"The `onChange` callback fires with the new page index whenever the user navigates."},"707":{"id":"/docs/components/popover","page_id":"/docs/components/popover","type":"page","content":"Popover","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/popover"},"708":{"id":"/docs/components/popover-0","page_id":"/docs/components/popover","tags":[],"type":"text","url":"/docs/components/popover","content":"The Popover component is an overlay element positioned relative to a trigger element."},"709":{"id":"/docs/components/popover-1","page_id":"/docs/components/popover","type":"heading","tags":[],"url":"/docs/components/popover#installation","content":"Installation"},"710":{"id":"/docs/components/popover-2","page_id":"/docs/components/popover","type":"heading","tags":[],"url":"/docs/components/popover#props","content":"Props"},"711":{"id":"/docs/components/popover-3","page_id":"/docs/components/popover","type":"heading","tags":[],"url":"/docs/components/popover#examples","content":"Examples"},"712":{"id":"/docs/components/popover-4","page_id":"/docs/components/popover","type":"heading","tags":[],"url":"/docs/components/popover#basic-usage","content":"Basic Usage"},"713":{"id":"/docs/components/popover-5","page_id":"/docs/components/popover","type":"heading","tags":[],"url":"/docs/components/popover#custom-anchor","content":"Custom Anchor"},"714":{"id":"/docs/components/popover-6","page_id":"/docs/components/popover","type":"heading","tags":[],"url":"/docs/components/popover#close-button-and-header","content":"Close Button and Header"},"715":{"id":"/docs/components/popover-7","page_id":"/docs/components/popover","type":"heading","tags":[],