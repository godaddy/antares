ts/drawer","tags":[],"type":"text","url":"/docs/components/drawer#drawerhandle","content":"Visual drag handle for touch gestures. Renders a grab bar with a 44px touch target (24px for pointer:fine). When inside a `<Drawer>` with `snapPoints`, the handle becomes interactive and drag-to-snap activates automatically. Without `snapPoints`, the handle renders as a decorative affordance only."},"299":{"id":"/docs/components/drawer-26","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#drawerhandle","content":"Prop"},"300":{"id":"/docs/components/drawer-27","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#drawerhandle","content":"Type"},"301":{"id":"/docs/components/drawer-28","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#drawerhandle","content":"Description"},"302":{"id":"/docs/components/drawer-29","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#drawerhandle","content":"`className`"},"303":{"id":"/docs/components/drawer-30","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#drawerhandle","content":"`string`"},"304":{"id":"/docs/components/drawer-31","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#drawerhandle","content":"Additional CSS class"},"305":{"id":"/docs/components/drawer-32","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#basic-usage","content":"Use `<DrawerTrigger>` to wrap a trigger button and a `<Drawer>`. The drawer opens when the trigger is pressed."},"306":{"id":"/docs/components/drawer-33","page_id":"/docs/components/drawer","tags":[],"type":"text","url":"/docs/components/drawer#bottom-sheet","content":"Use `placement=\"bottom\"` with controlled state for a bottom sheet pattern."},"307":{"id":"/docs/components/drawer-34","page_id":"/docs/components/drawer","tags":[