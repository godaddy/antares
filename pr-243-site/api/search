s/progress-steps#hide-step-numbers","content":"Hide step numbers"},"752":{"id":"/docs/components/progress-steps-13","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#customization","content":"Customization"},"753":{"id":"/docs/components/progress-steps-14","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#accessibility","content":"Accessibility"},"754":{"id":"/docs/components/progress-steps-15","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#best-practices","content":"Best Practices"},"755":{"id":"/docs/components/progress-steps-16","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#troubleshooting","content":"Troubleshooting"},"756":{"id":"/docs/components/progress-steps-17","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Horizontal and vertical orientations"},"757":{"id":"/docs/components/progress-steps-18","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Four completion statuses (`none`, `partial`, `complete`, `error`) with status icons"},"758":{"id":"/docs/components/progress-steps-19","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Timeline (past / current / future) derived from a single `currentStep` prop"},"759":{"id":"/docs/components/progress-steps-20","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Auto-generated step numbers (opt out with `hideStepNumbers`)"},"760":{"id":"/docs/components/progress-steps-21","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Interactive (navigable) and inert (display-only) steps"},"761":{"id":"/docs/components/progress-steps-22","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Title truncation and RTL support"},"762":{"id":"/docs/components/progress-steps-23","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Rendered as a `<nav>` landmark with an ordered list for assistive technology"},"763":{"id":"/docs/components/progress-steps-24","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#props","content":"`ProgressSteps` is the container; its direct children must be `ProgressStep` elements."},"764":{"id":"/docs/components/progress-steps-25","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#default","content":"A horizontal stepper. `currentStep` marks the active step; earlier steps are `past`, later are `future`. Each `status` sets the step's icon, and an `error` step turns its accent bar red."},"765":{"id":"/docs/components/progress-steps-26","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#not-started","content":"Omit `currentStep` for a flow that hasn't begun: every step is `future` and none is marked current."},"766":{"id":"/docs/components/progress-steps-27","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#vertical","content":"Use `orientation=\"vertical\"` to place the accent bar on the leading edge and stack steps in a column."},"767":{"id":"/docs/components/progress-steps-28","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#interactive","content":"Give a step an `onPress` handler to make it navigable. Steps without `onPress` are inert."},"768":{"id":"/docs/components/progress-steps-29","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#disabled","content":"A disabled interactive step is muted, removed from the tab order, and cannot be activated."},"769":{"id":"/docs/components/progress-steps-30","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#hide-step-numbers","content":"Step numbers are prepended automatically. Set `hideStepNumbers` to omit them."},"770":{"id":"/docs/components/progress-steps-31","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"Step numbers (`\"N. \"`) are prepended automatically — keep them where possible, as user testing shows people recognize the component better with them. Set `hideStepNumbers` to omit them."},"771":{"id":"/docs/components/progress-steps-32","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"`orientation` switches between `horizontal` (accent bar on top) and `vertical` (accent bar on the leading edge)."},"772":{"id":"/docs/components/progress-steps-33","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"`currentStep` is the single source of truth for the timeline. Omit it for a not-yet-started flow where every step is `future`; pass the step count for a fully completed flow where every step is `past`."},"773":{"id":"/docs/components/progress-steps-34","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#customization","content":"`status` is independent of timeline and only controls the status icon and (for `error`) the accent bar color."},"774":{"id":"/docs/components/progress-steps-35","page_id":"/docs/components/progress-steps","tag