","tags":[],"type":"text","url":"/docs/components/inline-drawer#features","content":"Animated by default; `animate={false}` disables the transition"},"546":{"id":"/docs/components/inline-drawer-15","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#features","content":"`placement` selects the collapse axis (`left`/`right` → width, `top`/`bottom` → height)"},"547":{"id":"/docs/components/inline-drawer-16","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#features","content":"Controlled and uncontrolled modes (`isExpanded` / `defaultExpanded` / `onExpandedChange`)"},"548":{"id":"/docs/components/inline-drawer-17","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#features","content":"Accordion collapse uses the browser's `hidden=\"until-found\"` for find-in-page"},"549":{"id":"/docs/components/inline-drawer-18","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#features","content":"`prefers-reduced-motion` support"},"550":{"id":"/docs/components/inline-drawer-19","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#props","content":"The `InlineDrawerPanel` component accepts the following props:"},"551":{"id":"/docs/components/inline-drawer-20","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#basic-usage","content":"Put a `<Button slot=\"trigger\">` and an `<InlineDrawerPanel>` inside `InlineDrawer`. The panel hides when collapsed and animates open."},"552":{"id":"/docs/components/inline-drawer-21","page_id":"/docs/components/inline-drawer","tags":[],"type":"text","url":"/docs/components/inline-drawer#controlled","content":"Use `isExpanded` and `onExpandedChange` to drive state externally."},"553":{"id":"/docs/components/inline-drawer-22","page_id":"