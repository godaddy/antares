inate progress of an operation over time"},"723":{"id":"/docs/components/progress-bar-1","page_id":"/docs/components/progress-bar","type":"heading","tags":[],"url":"/docs/components/progress-bar#installation","content":"Installation"},"724":{"id":"/docs/components/progress-bar-2","page_id":"/docs/components/progress-bar","type":"heading","tags":[],"url":"/docs/components/progress-bar#props","content":"Props"},"725":{"id":"/docs/components/progress-bar-3","page_id":"/docs/components/progress-bar","type":"heading","tags":[],"url":"/docs/components/progress-bar#examples","content":"Examples"},"726":{"id":"/docs/components/progress-bar-4","page_id":"/docs/components/progress-bar","type":"heading","tags":[],"url":"/docs/components/progress-bar#basic-usage","content":"Basic Usage"},"727":{"id":"/docs/components/progress-bar-5","page_id":"/docs/components/progress-bar","type":"heading","tags":[],"url":"/docs/components/progress-bar#sizes","content":"Sizes"},"728":{"id":"/docs/components/progress-bar-6","page_id":"/docs/components/progress-bar","type":"heading","tags":[],"url":"/docs/components/progress-bar#statuses","content":"Statuses"},"729":{"id":"/docs/components/progress-bar-7","page_id":"/docs/components/progress-bar","type":"heading","tags":[],"url":"/docs/components/progress-bar#accessibility","content":"Accessibility"},"730":{"id":"/docs/components/progress-bar-8","page_id":"/docs/components/progress-bar","type":"heading","tags":[],"url":"/docs/components/progress-bar#aria-support","content":"ARIA Support"},"731":{"id":"/docs/components/progress-bar-9","page_id":"/docs/components/progress-bar","tags":[],"type":"text","url":"/docs/components/progress-bar#sizes","content":"Three track heights are available: `xs` (6px), `sm` (12px), and `md` (24px)."},"732":{"id":"/docs/components/progress-bar-10","page_id":"/docs/components/progress-bar","tags":[],"type":"text","url":"/docs/components/progress-bar#statuses","content":"Use the `status` prop to communicate intent: `de