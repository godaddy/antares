ponents/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#basic","content":"Basic"},"1317":{"id":"/docs/components/chart/donut-chart-5","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#single-slice","content":"Single slice"},"1318":{"id":"/docs/components/chart/donut-chart-6","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#legend-placement","content":"Legend placement"},"1319":{"id":"/docs/components/chart/donut-chart-7","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#small-slices","content":"Small slices"},"1320":{"id":"/docs/components/chart/donut-chart-8","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#format-value","content":"Format value"},"1321":{"id":"/docs/components/chart/donut-chart-9","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#basic","content":"You give the chart a `data` array (`id`, `name`, `value`) and a `label` in the middle—this is the everyday setup when you want several categories on one ring and a headline number or title in the hole."},"1322":{"id":"/docs/components/chart/donut-chart-10","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#single-slice","content":"When there is only one slice, the ring is full. Add `subLabel` if you want a smaller second line under the main center text."},"1323":{"id":"/docs/components/chart/donut-chart-11","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#legend-placement","content":"Switch `legend` to `right` to sit the legend beside the donut, or `bottom` to stack it underneath. `legendLabel` is there when you want a 