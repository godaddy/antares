st-practices","content":"Best Practices"},"902":{"id":"/docs/components/tag-16","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#when-to-use","content":"When to Use"},"903":{"id":"/docs/components/tag-17","page_id":"/docs/components/tag","type":"heading","tags":[],"url":"/docs/components/tag#when-not-to-use","content":"When Not to Use"},"904":{"id":"/docs/components/tag-18","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#basic","content":"A minimal tag with the default emphasis and size."},"905":{"id":"/docs/components/tag-19","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#emphasis","content":"Nine emphasis options are available. Choose the one that fits the visual tone of your context."},"906":{"id":"/docs/components/tag-20","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#sizes","content":"Choose a size that fits the surrounding content. Smaller tags work well in compact layouts like tables; larger tags suit headings or hero sections."},"907":{"id":"/docs/components/tag-21","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#inline","content":"Use `design=\"inline\"` to embed a tag within a sentence. The background and border are removed so the tag blends into the text flow."},"908":{"id":"/docs/components/tag-22","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#high-contrast","content":"A bolder color treatment for when tags need to stand out more — for example, on colored backgrounds."},"909":{"id":"/docs/components/tag-23","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#with-icon","content":"Icons reinforce the tag's meaning at a glance. Add an `Icon` as a child — it inherits the tag's color and scales with its size."},"910":{"id":"/docs/components/tag-24","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#indicator","content":"A minimal style that pairs a small colored dot with a neutral background. Well suited for dense layouts like tables or dashboards where multiple tags in close proximity would otherwise compete for attention."},"911":{"id":"/docs/components/tag-25","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#screen-readers","content":"Tags are `<span>` elements with no special ARIA role. Screen readers announce the tag's text as part of normal page content — no extra markup is needed."},"912":{"id":"/docs/components/tag-26","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#decorative-icons","content":"Icons passed as children must include `aria-hidden=\"true\"` so they are skipped by screen readers. The text label is the sole carrier of meaning."},"913":{"id":"/docs/components/tag-27","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#indicator-dot","content":"The colored dot is decorative and invisible to screen readers. The text label must convey the status on its own — never rely on the dot alone to communicate meaning."},"914":{"id":"/docs/components/tag-28","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Use the indicator style in dense layouts like tables and dashboards. Use the filled style when the tag is a prominent, standalone element on a card or hero section."},"915":{"id":"/docs/components/tag-29","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Default to the small size in compact layouts like tables and lists. Use medium or large only when the tag needs to stand out as a primary piece of information."},"916":{"id":"/docs/components/tag-30","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Use the inline design only within running prose. In grouped or standalone contexts, the filled style provides better visual separation."},"917":{"id":"/docs/components/tag-31","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#best-practices","content":"Do not stack multiple tags of different emphasis on the same item. Choose the most important one — too many competing labels lose their meaning."},"918":{"id":"/docs/components/tag-32","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Showing the status of an item on a card, table row, or list entry (e.g. \"Active\", \"Expired\", \"Pending\")"},"919":{"id":"/docs/components/tag-33","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Categorizing or grouping content so users can scan and filter quickly (e.g. \"New\", \"Sale\", \"Beta\")"},"920":{"id":"/docs/components/tag-34","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Surfacing metadata about an item (e.g. \"Pro\", \"Free trial\", \"Internal\")"},"921":{"id":"/docs/components/tag-35","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-to-use","content":"Communicating priority or category in project management and collaboration tools (e.g. \"High priority\", \"In review\")"},"922":{"id":"/docs/components/tag-36","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-not-to-use","content":"If users need to click or dismiss it — use a **Button** instead."},"923":{"id":"/docs/components/tag-37","page_id":"/docs/components/tag","tags":[],"type":"text","url":"/docs/components/tag#when-not-to-use","content":"If the label is part of a sentence with no visual distinction — just use text."},"924":{"id":"/docs/components/text","page_id":"/docs/components/text","type":"page","content":"Text","breadcrumbs":["Docs","Components"],"ta