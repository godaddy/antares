ontent":"Multiline"},"1087":{"id":"/docs/components/text-field-11","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Label, description, error**: Optional label, helper text, and error message with proper accessibility"},"1088":{"id":"/docs/components/text-field-12","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Adornments**: Optional `leadingText` and `trailingText` for fixed text before or after the input (e.g. `$`, `.00`, `px`)"},"1089":{"id":"/docs/components/text-field-13","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Controlled or uncontrolled**: Use `value` and `onChange` for controlled state, or `defaultValue` for uncontrolled"},"1090":{"id":"/docs/components/text-field-14","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Multiline**: Set `multiline` to render a textarea instead of a single-line input"},"1091":{"id":"/docs/components/text-field-15","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Validation states**: Use `isInvalid` with `errorMessage` and `isDisabled` for validation and disabled state"},"1092":{"id":"/docs/components/text-field-16","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**React Aria integration**: Built on React Aria TextField for accessibility and behavior"},"1093":{"id":"/docs/components/text-field-17","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#props","content":"The `TextField` component accepts the following props:"},"1094":{"id":"/docs/components/text-field-18","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#basic","content":"Minimal usage with label and placeholder."},"1095":{"id":"/docs/components/text-field-19","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#controlled","content":"Use `value` and `onChange` for controlled state."},"1096":{"id":"/docs/components/text-field-20","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#invalid","content":"Use `isInvalid` with `errorMessage` for validation feedback."},"1097":{"id":"/docs/components/text-field-21","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#disabled","content":"Use `isDisabled` to prevent input."},"1098":{"id":"/docs/components/text-field-22","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#adornments","content":"Use `leadingText` and `trailingText` for fixed text before and after the input (e.g. currency)."},"1099":{"id":"/docs/components/text-field-23","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#multiline","content":"Use `multiline` to render a textarea."},"1100":{"id":"/docs/components/tooltip","page_id":"/docs/components/tooltip","type":"page","content":"Tooltip","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/tooltip"},"1101":{"id":"/docs/components/tooltip-0","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip","content":"The Tooltip component displays a description of an element on hover or focus."},"1102":{"id":"/docs/components/tooltip-1","page_id":"/docs/components/tooltip","type":"heading","tags":[],"url":"/docs/components/tooltip#installation","content":"Installation"},"1103":{"id":"/docs/components/tooltip-2","page_id":"/docs/components/tooltip","type":"heading","tags":[],"url":"/docs/components/tooltip#props","content":"Props"},"1104":{"id":"/docs/components/toolt