 Out of Range"},"1347":{"id":"/docs/components/chart/gauge-chart-13","page_id":"/docs/components/chart/gauge-chart","tags":[],"type":"text","url":"/docs/components/chart/gauge-chart#basic","content":"A continuous gauge with a single label."},"1348":{"id":"/docs/components/chart/gauge-chart-14","page_id":"/docs/components/chart/gauge-chart","tags":[],"type":"text","url":"/docs/components/chart/gauge-chart#continuous-values","content":"Multiple continuous gauges showing different fill percentages."},"1349":{"id":"/docs/components/chart/gauge-chart-15","page_id":"/docs/components/chart/gauge-chart","tags":[],"type":"text","url":"/docs/components/chart/gauge-chart#segmented","content":"Segmented gauges divide the arc into discrete sections (1–5). The `value` prop selects how many segments are filled."},"1350":{"id":"/docs/components/chart/gauge-chart-16","page_id":"/docs/components/chart/gauge-chart","tags":[],"type":"text","url":"/docs/components/chart/gauge-chart#with-range-labels","content":"Min/max labels positioned below the gauge arc at the left and right edges. Both `min` and `max` must be provided."},"1351":{"id":"/docs/components/chart/gauge-chart-17","page_id":"/docs/components/chart/gauge-chart","tags":[],"type":"text","url":"/docs/components/chart/gauge-chart#variants","content":"Color variants convey meaning at a glance — use `success`, `warning`, or `critical` alongside descriptive text."},"1352":{"id":"/docs/components/chart/gauge-chart-18","page_id":"/docs/components/chart/gauge-chart","tags":[],"type":"text","url":"/docs/components/chart/gauge-chart#label-type","content":"Control the font size of the primary label using `labelType`. Use `'value'` for numeric or percentage values and `'text'` for short descriptive strings."},"1353":{"id":"/docs/components/chart/gauge-chart-19","page_id":"/docs/components/chart/gauge-chart","tags":[],"type":"text","url":"/docs/components/chart/gauge-chart#gauge-not-sizing-correctly","content":"The component uses `containe