nstead"},"1013":{"id":"/docs/components/toggle-button-67","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keep-variants-consistent","content":"Avoid mixing different content types (text-only, icon-only, icon+text) within the same group. Mixing styles creates visual noise and makes the set feel fragmented rather than unified."},"1014":{"id":"/docs/components/toggle-button-68","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#balance-label-lengths","content":"Keep button labels of similar length. Large differences in text length cause irregular button widths and make the group appear uneven. Prefer short, concise wording."},"1015":{"id":"/docs/components/toggle-button-69","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"Align the group to reflect its relationship to surrounding content:"},"1016":{"id":"/docs/components/toggle-button-70","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Left** — when the group controls content directly below or within the same column (dashboards, tables)."},"1017":{"id":"/docs/components/toggle-button-71","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Center** — when the group acts as a prominent toggle affecting an entire section or page."},"1018":{"id":"/docs/components/toggle-button-72","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Right** — when the group represents utility or contextual controls (e.g. grid/list view toggle)."},"1019":{"id":"/docs/components/toggle-button-73","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#label-guidelines","content"