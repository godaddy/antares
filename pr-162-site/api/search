nts/chart/tooltip","content":"An internal component used for displaying tooltip information in chart components."},"894":{"id":"/docs/components/chart/tooltip-1","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#features","content":"Features"},"895":{"id":"/docs/components/chart/tooltip-2","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#internal-component","content":"Internal Component"},"896":{"id":"/docs/components/chart/tooltip-3","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#props","content":"Props"},"897":{"id":"/docs/components/chart/tooltip-4","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#value-formatting","content":"Value formatting"},"898":{"id":"/docs/components/chart/tooltip-5","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#examples","content":"Examples"},"899":{"id":"/docs/components/chart/tooltip-6","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#single-series","content":"Single Series"},"900":{"id":"/docs/components/chart/tooltip-7","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#multiple-series","content":"Multiple Series"},"901":{"id":"/docs/components/chart/tooltip-8","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#arrow","content":"Arrow"},"902":{"id":"/docs/components/chart/tooltip-9","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#features","content":"**Multiple series**: Shows all series that have a datum at the hovered X position in a single tooltip."},"903":{"id":"/docs/components/chart/tooltip-10","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#features","content":"**Series matching**: Rows are built from `series` by matching `series[].id` to keys in `tooltipData.datumByKey` (from visx at the hovered X)."},"904":{"id":"/docs/components/chart/tooltip-11","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#features","content":"**Value formatting**: You can supply a function to format each value; if you don't, the tooltip shows the point's `y` (or nothing when null). Use the formatter for custom data shapes."},"905":{"id":"/docs/components/chart/tooltip-12","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#internal-component","content":"This component is **internal-only** and not exported from the package. It is intended for use inside chart components."},"906":{"id":"/docs/components/chart/tooltip-13","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#props","content":"The `Tooltip` component accepts the following props:"},"907":{"id":"/docs/components/chart/tooltip-14","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#value-formatting","content":"**Default:** When `formatValue` is not provided, the tooltip uses a formatter that reads the data point’s `y` property (same as the chart's default Y accessor), converts it to a string, and returns an empty string for null. This is correct for the default `DataPoint` shape (`{ x, y }`)."},"908":{"id":"/docs/components/chart/tooltip-15","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#value-formatting","content":"**Custom:** Pass `formatValue` to control display. The function receives the datum and returns a string. Use it to both extract and format (e.g. currency, percentage, custom units). For custom data point shapes (generic `TooltipProps<YourDatum>`), you must pass `formatValue` because the default only reads `y`."},"909":{"id":"/docs/components/chart/tooltip-16","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#single-series","content":"Basic tooltip with a single series and default formatting."},"910":{"id":"/docs/components/chart/tooltip-17","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#multiple-series","content":"Tooltip with multiple series; all series at the same X position are shown together."},"911":{"id":"/docs/components/chart/tooltip-18","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#arrow","content":"Use the `showArrow` prop to set whether the tooltip arrow is visible or not."},"912":{"id":"/docs/components/chart/line-chart","page_id":"/docs/components/chart/line-chart","type":"page","content":"LineChart","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/line-chart"},"913":{"id":"/docs/components/chart/line-chart-0","page_id":"/docs/components/chart/line-chart","tags":[],"type":"text","url":"/docs/components/chart/line-chart","content":"Line Chart shows how something changes over time or along a continuous scale. It connects data points with lines so people can quickly spot trends, peaks, dips, and patterns."},"914":{"id":"/docs/components/chart/line-chart-1","page_id":"/docs/components/chart/line-chart","type":"heading","tags":[],"url":"/docs/components/chart/line-chart#installation","content":"Installation"},"915":{"id":"/docs/components/chart/line-chart-2","page_id":"/docs/components/chart/line-chart","type":"heading","tags":[],"url":"/docs/components/chart/line-chart#props","content":"Props"},"916":{"id":"/docs/components/chart/line-chart-3","page_id":"/docs/components/chart/line-chart","type":"heading","tags":[],"url":"/docs/components/chart/line-