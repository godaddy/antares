ller-22","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#sizes","content":"Three sizes are available: `sm`, `md` (default), and `lg`."},"735":{"id":"/docs/components/segmented-controller-23","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#icon--text","content":"Segments can include an `Icon` alongside text for added visual context."},"736":{"id":"/docs/components/segmented-controller-24","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#icon-only","content":"For compact layouts, segments can contain only icons. Provide an `aria-label` on each item so screen readers can identify the action."},"737":{"id":"/docs/components/segmented-controller-25","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#overflow","content":"When the number of options exceeds the width of the container, the component automatically shows scroll buttons to let users navigate. Users can also scroll horizontally to navigate the options."},"738":{"id":"/docs/components/segmented-controller-26","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#rtl-direction","content":"The segmented controller follows the current **layout direction** (LTR or RTL). By default, that direction is detected automatically from the browser or system settings."},"739":{"id":"/docs/components/segmented-controller-27","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#disabled-states","content":"Disable the entire group with `isDisabled` on the container, or disable individual segments with `isDisabled` on specific items."},"740":{"id":"/docs/components/segmented-controller-28","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#data-attributes","content":"Components automatically add data attributes for styling different states:"},"741":{"id":"/docs/components/segmented-controller-29","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#data-attributes","content":"**SegmentedController Container:** `data-disabled`"},"742":{"id":"/docs/components/segmented-controller-30","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#data-attributes","content":"**SegmentedControllerItem:** `data-selected`, `data-hovered`, `data-pressed`, `data-focus-visible`, `data-disabled`"},"743":{"id":"/docs/components/segmented-controller-31","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#keyboard-navigation","content":"**Tab**: Moves focus to/from the segmented controller"},"744":{"id":"/docs/components/segmented-controller-32","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#keyboard-navigation","content":"**Arrow Left/Right**: Move to next/previous segment"},"745":{"id":"/docs/components/segmented-controller-33","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#keyboard-navigation","content":"**Space/Enter**: Select the focused segment"},"746":{"id":"/docs/components/segmented-controller-34","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#aria-support","content":"`role=\"radiogroup\"` on the container"},"747":{"id":"/docs/components/segmented-controller-35","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#aria-support","content":"`role=\"radio\"` on each segment"},"748":{"id":"/docs/components/segmented-controller-36","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#aria-support","content":"`aria-checked` indicates selection state"},"749":{"id":"/docs/components/segmented-controller-37","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#aria-support","content":"`aria-disabled` for disabled segments"},"750":{"id":"/docs/components/segmented-controller-38","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#aria-support","content":"`aria-label` required on the container for screen readers"},"751":{"id":"/docs/components/segmented-controller-39","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#when-to-use-a-segmented-controller","content":"When switching between 2-5 related views within the same context"},"752":{"id":"/docs/components/segmented-controller-40","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#when-to-use-a-segmented-controller","content":"When all options should be visible at once"},"753":{"id":"/docs/components/segmented-controller-41","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#when-to-use-a-segmented-controller","content":"When the selection immediately changes the displayed content"},"754":{"id":"/docs/components/segmented-controller-42","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#when-not-to-use","content":"For more than 5 options (use Tabs or Select instead)"},"755":{"id":"/docs/components/segmented-controller-43","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller#when-not-to-use","content":"For form input (use RadioGroup instead)"},"756":{"id":"/docs/components/select","page_id":"/docs/components/select","type":"page","content":"Select","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/select"},"757":{"id":"/docs/components/select-0","page_id":"/docs/components/select","tags":[],"type":"text","url":"/docs/components/select","content":"Select is a dropdown for picking one or more values from a list of options. It renders a labeled trigger and a popover listbox, supports single and multiple selection, and submits naturally inside a form."},"758":{"id":"/docs/components/select-1","page_id":"/docs/components/select","type":"heading","tags":[],"url":"/docs/components/select#features","content":"Features"},"759":{"id":"/docs/components/select-2","page_id":"/docs/components/select","type":"heading","tags":[],"url":"/docs/components/select#installation","content":"Installation"},"760":{"id":"/docs/components/select-3","page_id":"/docs/components/select","type":"heading","tags":[],"url":"/docs/components/select#props","content":"Props"},"761":{"id":"/docs/components/select-4","page_id":"/docs/components/select","type":"heading","tags":[],"url":"/docs/components/select#examples","content":"Examples"},"762":{"id":"/docs/components/select-5","page_id":"/docs/components/select","type":"heading","tags":[],"url":"/docs/components/select#basic","content":"Basic"},"763":{"id":"/docs/components/select-6","page_id":"/docs/components/select","type":"heading","tags":[],"url":"/docs/components/select#controlled","content":"Controlled"},"764":{"id":"/docs/components/select-7","page_id":"/docs/components/select","type":"heading","tags":[],"url":"/docs/components/select#multiple","content":"Multiple"},"765":{"id":"/docs/components/select-8","page_id":"/docs/components/select","type":"heading","tags":[],"url":"/docs/components/select#invalid","content":"Invalid"},"766":{"id":"/docs/components/select-9","page_id":