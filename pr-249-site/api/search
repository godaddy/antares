hout being verbose"},"759":{"id":"/docs/components/radio-51","page_id":"/docs/components/radio","tags":[],"type":"text","url":"/docs/components/radio#validation","content":"Always provide clear error messages:"},"760":{"id":"/docs/components/segmented-controller","page_id":"/docs/components/segmented-controller","type":"page","content":"SegmentedController","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/segmented-controller"},"761":{"id":"/docs/components/segmented-controller-0","page_id":"/docs/components/segmented-controller","tags":[],"type":"text","url":"/docs/components/segmented-controller","content":"A segmented controller is a linear set of two or more segments, each of which functions as a button. A segmented controller allows users to select options, switch views, or sort elements."},"762":{"id":"/docs/components/segmented-controller-1","page_id":"/docs/components/segmented-controller","type":"heading","tags":[],"url":"/docs/components/segmented-controller#installation","content":"Installation"},"763":{"id":"/docs/components/segmented-controller-2","page_id":"/docs/components/segmented-controller","type":"heading","tags":[],"url":"/docs/components/segmented-controller#props","content":"Props"},"764":{"id":"/docs/components/segmented-controller-3","page_id":"/docs/components/segmented-controller","type":"heading","tags":[],"url":"/docs/components/segmented-controller#examples","content":"Examples"},"765":{"id":"/docs/components/segmented-controller-4","page_id":"/docs/components/segmented-controller","type":"heading","tags":[],"url":"/docs/components/segmented-controller#basic","content":"Basic"},"766":{"id":"/docs/components/segmented-controller-5","page_id":"/docs/components/segmented-controller","type":"heading","tags":[],"url":"/docs/components/segmented-controller#controlled","content":"Controlled"},"767":{"id":"/docs/components/segmented-controller-6","page_id":"/docs/components/segmented-controller","type":"heading","tags":[],"