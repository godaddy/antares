cs/components/chart/donut-chart-6","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#legend-placement","content":"Legend placement"},"1162":{"id":"/docs/components/chart/donut-chart-7","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#small-slices","content":"Small slices"},"1163":{"id":"/docs/components/chart/donut-chart-8","page_id":"/docs/components/chart/donut-chart","type":"heading","tags":[],"url":"/docs/components/chart/donut-chart#format-value","content":"Format value"},"1164":{"id":"/docs/components/chart/donut-chart-9","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#basic","content":"You give the chart a `data` array (`id`, `name`, `value`) and a `label` in the middle—this is the everyday setup when you want several categories on one ring and a headline number or title in the hole."},"1165":{"id":"/docs/components/chart/donut-chart-10","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#single-slice","content":"When there is only one slice, the ring is full. Add `subLabel` if you want a smaller second line under the main center text."},"1166":{"id":"/docs/components/chart/donut-chart-11","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#legend-placement","content":"Switch `legend` to `right` to sit the legend beside the donut, or `bottom` to stack it underneath. `legendLabel` is there when you want a title above the legend items."},"1167":{"id":"/docs/components/chart/donut-chart-12","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#small-slices","content":"Very thin slices can be noisy to hover. Anything at or below `smallSliceThreshold` (default `0.05` of the total) is treated as “small,” and if those slices sit next to each other on the ring, one hover opens a single tooltip that lists the whole group."},"1168":{"id":"/docs/components/chart/donut-chart-13","page_id":"/docs/components/chart/donut-chart","tags":[],"type":"text","url":"/docs/components/chart/donut-chart#format-value","content":"Use `formatValue` when the raw numbers in the tooltip should read like money, counts with separators, or whatever your product expects. The percentage of the total still formats on its own; your function only shapes the value column."},"1169":{"id":"/docs/components/chart/gauge-chart","page_id":"/docs/components/chart/gauge-chart","type":"page","content":"Gauge Chart","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/gauge-chart"},"1170":{"id":"/docs/components/chart/gauge-chart-0","page_id":"/docs/components/chart/gauge-chart","tags":[],"type":"text","url":"/docs/components/chart/gauge-chart","content":"A visual indicator for representing a single quantitative value within a known range, rendered as a semicircle arc in continuous or segmented mode."},"1171":{"id":"/docs/components/chart/gauge-chart-1","page_id":"/docs/components/chart/gauge-chart","type":"heading","tags":[],"url":"/docs/components/chart/gauge-chart#installation","content":"Installation"},"1172":{"id":"/docs/components/chart/gauge-chart-2","page_id":"/docs/components/chart/gauge-chart","type":"heading","tags":[],"url":"/docs/components/chart/gauge-chart#props","content":"Props"},"1173":{"id":"/docs/components/chart/gauge-chart-3","page_id":"/docs/components/chart/gauge-chart","type":"heading","tags":[],"url":"/docs/components/chart/gauge-chart#examples","content":"Examples"},"1174":{"id":"/docs/components/chart/gauge-chart-4","page_id":"/docs/components/chart/gauge-chart","type":"heading","tags":[],"url":"/docs/components/chart/gauge-chart#basic","content":"Basic"},"1175":{"id":"/docs/components/chart/gauge-chart-5","page_id":"/docs/components/chart/