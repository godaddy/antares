mponents/number-field-11","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#accessibility","content":"Accessibility"},"791":{"id":"/docs/components/number-field-12","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#keyboard","content":"Keyboard"},"792":{"id":"/docs/components/number-field-13","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#aria-and-labeling","content":"ARIA and labeling"},"793":{"id":"/docs/components/number-field-14","page_id":"/docs/components/number-field","type":"heading","tags":[],"url":"/docs/components/number-field#best-practices","content":"Best practices"},"794":{"id":"/docs/components/number-field-15","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#props","content":"The `NumberField` component accepts the following props:"},"795":{"id":"/docs/components/number-field-16","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#basic","content":"Minimal usage with label, placeholder, and min/max."},"796":{"id":"/docs/components/number-field-17","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#controlled","content":"Use `value` and `onChange` for controlled state."},"797":{"id":"/docs/components/number-field-18","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#invalid","content":"Use `isInvalid` with `errorMessage` for validation feedback."},"798":{"id":"/docs/components/number-field-19","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#disabled","content":"Use `isDisabled` to prevent input."},"799":{"id":"/docs/components/number-field-20","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#hide-stepper","content":"Use `hideStepper` to show only the input without +/- buttons."},"800":{"id":"/docs/components/number-field-21","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#value-scale","content":"Use `minValue`, `maxValue`, and `step` to set the allowed values. Steps are calculated from the minimum value."},"801":{"id":"/docs/components/number-field-22","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#format-options-numbering-system","content":"By default, NumberField displays the value using the numbering system for the user's locale. Use the `formatOptions` prop to override the numbering system by setting the Unicode numbering system locale extension."},"802":{"id":"/docs/components/number-field-23","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#keyboard","content":"When focus is in the input (and the field is not read-only), keyboard behavior follows common spinbutton-style conventions:"},"803":{"id":"/docs/components/number-field-24","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#keyboard","content":"**Arrow Up** / **Arrow Down** (or **Up** / **Down**): increase or decrease by `step`"},"804":{"id":"/docs/components/number-field-25","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#keyboard","content":"**Page Up** / **Page Down**: larger increase or decrease when supported"},"805":{"id":"/docs/components/number-field-26","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/number-field#keyboard","content":"**Home** / **End**: jump to `minValue` or `maxValue` when those props are set"},"806":{"id":"/docs/components/number-field-27","page_id":"/docs/components/number-field","tags":[],"type":"text","url":"/docs/components/numb