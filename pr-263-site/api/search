onents/layout/box#scale-sizes","content":"Scale Sizes"},"1438":{"id":"/docs/components/layout/box-4","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#examples","content":"Examples"},"1439":{"id":"/docs/components/layout/box-5","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#padding","content":"Padding"},"1440":{"id":"/docs/components/layout/box-6","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#elevation","content":"Elevation"},"1441":{"id":"/docs/components/layout/box-7","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#rounding","content":"Rounding"},"1442":{"id":"/docs/components/layout/box-8","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#polymorphic-as-prop","content":"Polymorphic `as` Prop"},"1443":{"id":"/docs/components/layout/box-9","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#alignment","content":"Alignment"},"1444":{"id":"/docs/components/layout/box-10","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#rtl-support","content":"RTL Support"},"1445":{"id":"/docs/components/layout/box-11","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#design-tokens","content":"Design Tokens"},"1446":{"id":"/docs/components/layout/box-12","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box","content":"`Box` is a polymorphic layout component that renders as any HTML element or custom component via the `as` prop. It provides consistent spacing, elevation, rounding, and self-alignment within flex or grid containers."},"1447":{"id":"/docs/components/layout/box-13","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box","content":"**Important**: Since `Flex` and `Grid` extend `Box`, prefer them for layouts. Use `Box` only when you need a non-flex, non-grid container."},"1448":{"id":"/docs/components/layout/box-14","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#props","content":"The `Box` component accepts the following props:"},"1449":{"id":"/docs/components/layout/box-15","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"The spacing props use semantic t-shirt sizes for padding, gap, and other spacing properties:"},"1450":{"id":"/docs/components/layout/box-16","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xs` - Extra small spacing"},"1451":{"id":"/docs/components/layout/box-17","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`sm` - Small spacing"},"1452":{"id":"/docs/components/layout/box-18","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`md` - Medium spacing"},"1453":{"id":"/docs/components/layout/box-19","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`lg` - Large spacing"},"1454":{"id":"/docs/components/layout/box-20","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xl` - Extra large spacing"},"1455":{"id":"/docs/components/layout/box-21","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`2xl` - 2x extra large spacing"},"1456":{"id":"/docs/components/layout/box-22","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"Custom CSS values are also supported for edge cases."},"1457":{"id":"/docs/components/layout/box-23","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#padding","content":"The padding props support t-shirt sizes and CSS logical properties for RTL support."},"1458":{"id":"/docs/components/layout/box-24","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#elevation","content":"The elevation prop adds visual depth using box-shadow."},"1459":{"id":"/docs/components/layout/box-25","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#rounding","content":"The rounding prop sets border-radius. Use `full` for fully rounded corners."},"1460":{"id":"/docs/components/layout/box-26","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"Box is fully polymorphic - the `as` prop allows rendering as any HTML element or custom component while preserving type-safe props."},"1461":{"id":"/docs/components/layout/box-27","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**HTML Elements:** When using `as=\"button\"`, TypeScript enforces button-specific props like `type`, `disabled`, and `onClick`."},"1462":{"id":"/docs/components/layout/box-28","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**Custom Components:** When using `as={MyComponent}`, Box accepts that component's props. If there's a prop name conflict, Box's props take priority."},"1463":{"id":"/docs/components/layout/box-29","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**Typed Refs:** Refs are correctly typed based on the `as` value - `useRef