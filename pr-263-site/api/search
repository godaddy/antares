s/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#best-practices","content":"Best Practices"},"1023":{"id":"/docs/components/toggle-button-24","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#when-to-use","content":"When to Use"},"1024":{"id":"/docs/components/toggle-button-25","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#keep-variants-consistent","content":"Keep Variants Consistent"},"1025":{"id":"/docs/components/toggle-button-26","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#balance-label-lengths","content":"Balance Label Lengths"},"1026":{"id":"/docs/components/toggle-button-27","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#alignment","content":"Alignment"},"1027":{"id":"/docs/components/toggle-button-28","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#label-guidelines","content":"Label Guidelines"},"1028":{"id":"/docs/components/toggle-button-29","page_id":"/docs/components/toggle-button","type":"heading","tags":[],"url":"/docs/components/toggle-button#icon-only-items","content":"Icon-Only Items"},"1029":{"id":"/docs/components/toggle-button-30","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#default-single-selection","content":"A `ToggleButton` toggles between selected and unselected. Wrap multiple inside a `ToggleButtonGroup` to link them with shared selection and keyboard navigation — `defaultSelectedKeys` sets the initial selection."},"1030":{"id":"/docs/components/toggle-button-31","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#multiple-selection","content":"Use `selectionMode=\"multiple\"` to allow more than one item to be active at a time."},"1031":{"id":"/docs/components/toggle-button-32","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#controlled","content":"Use `selectedKeys` and `onSelectionChange` to control selection from parent state — `onSelectionChange` receives a `Set<string>` of the selected item `id` values."},"1032":{"id":"/docs/components/toggle-button-33","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#disabled-states","content":"Disable the entire group with `isDisabled` on the container, or disable individual items with `isDisabled` on specific `ToggleButton` elements."},"1033":{"id":"/docs/components/toggle-button-34","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#sizes","content":"Two sizes are available: `sm` and `md` (default)."},"1034":{"id":"/docs/components/toggle-button-35","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#icon--text","content":"Items can include an `Icon` alongside text for added visual context."},"1035":{"id":"/docs/components/toggle-button-36","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#icon-only","content":"For compact layouts, items can contain only icons. Padding adjusts automatically to keep the button square — no extra prop required. Always provide an `aria-label` on each icon-only item so screen readers can identify the action."},"1036":{"id":"/docs/components/toggle-button-37","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#with-dropdown","content":"Wrap a `ToggleButton` in a `MenuTrigger` to add sub-options to a group item."},"1037":{"id":"/docs/components/toggle-button-38","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#rtl-direction","content":"The group follows the document's layout direction, detected automatically from the browser locale."},"1038":{"id":"/docs/components/toggle-button-39","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#data-attributes","content":"Components automatically add data attributes for styling different states:"},"1039":{"id":"/docs/components/toggle-button-40","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#data-attributes","content":"**ToggleButtonGroup Container:** `data-size`"},"1040":{"id":"/docs/components/toggle-button-41","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#data-attributes","content":"**ToggleButton Item:** `data-selected`, `data-hovered`, `data-pressed`, `data-focus-visible`, `data-disabled`"},"1041":{"id":"/docs/components/toggle-button-42","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#component-customization","content":"Individual components can be styled by passing `className` props:"},"1042":{"id":"/docs/components/toggle-button-43","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Key"},"1043":{"id":"/docs/components/toggle-button-44","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Action"},"1044":{"id":"/docs/components/toggle-button-45","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Tab**"},"1045":{"id":"/docs/components/toggle-button-46","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Moves focus to/from the button group (single tab stop)"},"1046":{"id":"/docs/components/toggle-button-47","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Arrow Left / Right**"},"1047":{"id":"/docs/components/toggle-button-48","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Move focus between items (RAC automatically reverses in RTL)"},"1048":{"id":"/docs/components/toggle-button-49","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Space / Enter**"},"1049":{"id":"/docs/components/toggle-button-50","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Toggle the focused item"},"1050":{"id":"/docs/components/toggle-button-51","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**Home**"},"1051":{"id":"/docs/components/toggle-button-52","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Move focus to the first item"},"1052":{"id":"/docs/components/toggle-button-53","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"**End**"},"1053":{"id":"/docs/components/toggle-button-54","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keyboard-navigation","content":"Move focus to the last item"},"1054":{"id":"/docs/components/toggle-button-55","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"`selectionMode=\"single\"` → `role=\"radiogroup\"` on container, `role=\"radio\"` + `aria-checked` per item"},"1055":{"id":"/docs/components/toggle-button-56","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"`selectionMode=\"multiple\"` → `role=\"toolbar\"` on container, `role=\"button\"` + `aria-pressed` per item"},"1056":{"id":"/docs/components/toggle-button-57","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"`aria-label` (or `aria-labelledby`) is required on the group container"},"1057":{"id":"/docs/components/toggle-button-58","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#aria-support","content":"Icon-only items require `aria-label` on each `ToggleButton`"},"1058":{"id":"/docs/components/toggle-button-59","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"✅ For grouped contextual actions — two or more closely related actions that belong together (e.g. Bold / Italic / Underline, Align Left / Center / Right)"},"1059":{"id":"/docs/components/toggle-button-60","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"✅ For compact action grouping — related actions in space-constrained layouts (e.g. Undo / Redo, Zoom In / Out / Reset)"},"1060":{"id":"/docs/components/toggle-button-61","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"✅ For multi-select scenarios — when users need to select multiple options simultaneously"},"1061":{"id":"/docs/components/toggle-button-62","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ For unrelated actions that perform disconnected tasks without shared context"},"1062":{"id":"/docs/components/toggle-button-63","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ For more than 5 choices — cognitive overload; consider a **Select** instead"},"1063":{"id":"/docs/components/toggle-button-64","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ When actions require strong visual distinction (e.g. Save vs. Delete)"},"1064":{"id":"/docs/components/toggle-button-65","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ When selecting an option leads to a different page or workflow — use navigation instead"},"1065":{"id":"/docs/components/toggle-button-66","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#when-to-use","content":"❌ For mutually exclusive content views (e.g. Monthly / Yearly) — use **SegmentedController** instead"},"1066":{"id":"/docs/components/toggle-button-67","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#keep-variants-consistent","content":"Avoid mixing different content types (text-only, icon-only, icon+text) within the same group. Mixing styles creates visual noise and makes the set feel fragmented rather than unified."},"1067":{"id":"/docs/components/toggle-button-68","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#balance-label-lengths","content":"Keep button labels of similar length. Large differences in text length cause irregular button widths and make the group appear uneven. Prefer short, concise wording."},"1068":{"id":"/docs/components/toggle-button-69","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"Align the group to reflect its relationship to surrounding content:"},"1069":{"id":"/docs/components/toggle-button-70","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Left** — when the group controls content directly below or within the same column (dashboards, tables)."},"1070":{"id":"/docs/components/toggle-button-71","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Center** — when the group acts as a prominent toggle affecting an entire section or page."},"1071":{"id":"/docs/components/toggle-button-72","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#alignment","content":"**Right** — when the group represents utility or contextual controls (e.g. grid/list view toggle)."},"1072":{"id":"/docs/components/toggle-button-73","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#label-guidelines","content":"Use **title case**: capitalize the first letter of each word, except short prepositions."},"1073":{"id":"/docs/components/toggle-button-74","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#label-guidelines","content":"Keep labels to one or two words. Omit articles (a, an, the) and filler words."},"1074":{"id":"/docs/components/toggle-button-75","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#label-guidelines","content":"Prefer action-focused or descriptive language that communicates the option instantly."},"1075":{"id":"/docs/components/toggle-button-76","page_id":"/docs/components/toggle-button","tags":[],"type":"text","url":"/docs/components/toggle-button#icon-only-items","content":"Use icon-only items only when the icon's meaning is universally recognized. Always provide an `aria-label` on each icon-only `ToggleButton`:"},"1076":{"id":"/docs/components/text-field","page_id":"/docs/components/text-field","type":"page","content":"TextField","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/text-field"},"1077":{"id":"/docs/components/text-field-0","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field","content":"TextField is a single-line or multiline text input with optional label, description, and error message. Use it in forms for short answers (email, search, name) or longer content (comments). It supports optional leading and trailing text adornments (e.g. currency or units)."},"1078":{"id":"/docs/components/text-field-1","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#features","content":"Features"},"1079":{"id":"/docs/components/text-field-2","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#installation","content":"Installation"},"1080":{"id":"/docs/components/text-field-3","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#props","content":"Props"},"1081":{"id":"/docs/components/text-field-4","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#examples","content":"Examples"},"1082":{"id":"/docs/components/text-field-5","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#basic","content":"Basic"},"1083":{"id":"/docs/components/text-field-6","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#controlled","content":"Controlled"},"1084":{"id":"/docs/components/text-field-7","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#invalid","content":"Invalid"},"1085":{"id":"/docs/components/text-field-8","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#disabled","content":"Disabled"},"1086":{"id":"/docs/components/text-field-9","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#adornments","content":"Adornments"},"1087":{"id":"/docs/components/text-field-10","page_id":"/docs/components/text-field","type":"heading","tags":[],"url":"/docs/components/text-field#multiline","content":"Multiline"},"1088":{"id":"/docs/components/text-field-11","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Label, description, error**: Optional label, helper text, and error message with proper accessibility"},"1089":{"id":"/docs/components/text-field-12","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Adornments**: Optional `leadingText` and `trailingText` for fixed text before or after the input (e.g. `$`, `.00`, `px`)"},"1090":{"id":"/docs/components/text-field-13","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Controlled or uncontrolled**: Use `value` and `onChange` for controlled state, or `defaultValue` for uncontrolled"},"1091":{"id":"/docs/components/text-field-14","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Multiline**: Set `multiline` to render a textarea instead of a single-line input"},"1092":{"id":"/docs/components/text-field-15","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**Validation states**: Use `isInvalid` with `errorMessage` and `isDisabled` for validation and disabled state"},"1093":{"id":"/docs/components/text-field-16","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#features","content":"**React Aria integration**: Built on React Aria TextField for accessibility and behavior"},"1094":{"id":"/docs/components/text-field-17","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#props","content":"The `TextField` component accepts the following props:"},"1095":{"id":"/docs/components/text-field-18","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#basic","content":"Minimal usage with label and placeholder."},"1096":{"id":"/docs/components/text-field-19","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#controlled","content":"Use `value` and `onChange` for controlled state."},"1097":{"id":"/docs/components/text-field-20","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#invalid","content":"Use `isInvalid` with `errorMessage` for validation feedback."},"1098":{"id":"/docs/components/text-field-21","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#disabled","content":"Use `isDisabled` to prevent input."},"1099":{"id":"/docs/components/text-field-22","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#adornments","content":"Use `leadingText` and `trailingText` for fixed text before and after the input (e.g. currency)."},"1100":{"id":"/docs/components/text-field-23","page_id":"/docs/components/text-field","tags":[],"type":"text","url":"/docs/components/text-field#multiline","content":"Use `multiline` to render a textarea."},"1101":{"id":"/docs/components/tooltip","page_id":"/docs/components/tooltip","type":"page","content":"Tooltip","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/tooltip"},"1102":{"id":"/docs/components/tooltip-0","page_id":"/docs/components/tooltip","tags":[],"type":"text","url":"/docs/components/tooltip","content":"The Tooltip component displays a description of an element on hover or focus."},"1103":{"id":"/docs/components