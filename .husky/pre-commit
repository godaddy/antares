#!/bin/sh
set -e

npx lint-staged

# Run dependency checks to prevent circular deps and version mismatches
echo "🔍 Checking dependencies..."
npm run deps:check

echo "🔍 Checking package.json formatting..."
npm run format:packageJson

echo "🔍 Typechecking..."
npm run typecheck

echo "🧪 Running tests (no cache)..."
npm test -- --skip-nx-cache


echo "✅ All pre-commit checks passed!"
