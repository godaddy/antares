ontent":"Internal Component"},"961":{"id":"/docs/components/chart/tooltip-3","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#props","content":"Props"},"962":{"id":"/docs/components/chart/tooltip-4","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#value-formatting","content":"Value formatting"},"963":{"id":"/docs/components/chart/tooltip-5","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#examples","content":"Examples"},"964":{"id":"/docs/components/chart/tooltip-6","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#single-series","content":"Single Series"},"965":{"id":"/docs/components/chart/tooltip-7","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#multiple-series","content":"Multiple Series"},"966":{"id":"/docs/components/chart/tooltip-8","page_id":"/docs/components/chart/tooltip","type":"heading","tags":[],"url":"/docs/components/chart/tooltip#arrow","content":"Arrow"},"967":{"id":"/docs/components/chart/tooltip-9","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#features","content":"**Multiple series**: Shows all series that have a datum at the hovered X position in a single tooltip."},"968":{"id":"/docs/components/chart/tooltip-10","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#features","content":"**Series matching**: Rows are built from `series` by matching `series[].id` to keys in `tooltipData.datumByKey` (from visx at the hovered X)."},"969":{"id":"/docs/components/chart/tooltip-11","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#features","content":"**Value formatting**: You can supply a function to format each value; if you don't, the tooltip shows the point's `y` (or nothing when null). Use the formatter for custom data shapes."},"970":{"id":"/docs/components/chart/tooltip-12","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#internal-component","content":"This component is **internal-only** and not exported from the package. It is intended for use inside chart components."},"971":{"id":"/docs/components/chart/tooltip-13","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#props","content":"The `Tooltip` component accepts the following props:"},"972":{"id":"/docs/components/chart/tooltip-14","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#value-formatting","content":"**Default:** When `formatValue` is not provided, the tooltip uses a formatter that reads the data point’s `y` property (same as the chart's default Y accessor), converts it to a string, and returns an empty string for null. This is correct for the default `DataPoint` shape (`{ x, y }`)."},"973":{"id":"/docs/components/chart/tooltip-15","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#value-formatting","content":"**Custom:** Pass `formatValue` to control display. The function receives the datum and returns a string. Use it to both extract and format (e.g. currency, percentage, custom units). For custom data point shapes (generic `TooltipProps<YourDatum>`), you must pass `formatValue` because the default only reads `y`."},"974":{"id":"/docs/components/chart/tooltip-16","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#single-series","content":"Basic tooltip with a single series and default formatting."},"975":{"id":"/docs/components/chart/tooltip-17","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#multiple-series","content":"Tooltip with multiple series; all series at the same X position are shown together."},"976":{"id":"/docs/components/chart/tooltip-18","page_id":"/docs/components/chart/tooltip","tags":[],"type":"text","url":"/docs/components/chart/tooltip#arrow","content":"Use the `showArrow` prop to set whether the tooltip arrow is visible or not."},"977":{"id":"/docs/components/chart/use-chart-color","page_id":"/docs/components/chart/use-chart-color","type":"page","content":"useChartColor","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/use-chart-color"},"978":{"id":"/docs/components/chart/use-chart-color-0","page_id":"/docs/components/chart/use-chart-color","tags":[],"type":"text","url":"/docs/components/chart/use-chart-color","content":"A hook for assigning deterministic, index-based colors to chart series using design token CSS variables. Safe under React concurrent rendering."},"979":{"id":"/docs/components/chart/use-chart-color-1","page_id":"/docs/components/chart/use-chart-color","type":"heading","tags":[],"url":"/docs/components/chart/use-chart-color#for-use-with-chart-components-not-exported","content":"For use with chart components (not exported)"},"980":{"id":"/docs/components/chart/use-chart-color-2","page_id":"/docs/components/chart/use-chart-color","type":"heading","tags":[],"url":"/docs/components/chart/use-chart-color#props","content":"Props"},"981":{"id":"/docs/components/chart/use-chart-color-3","page_id":"/docs/components/chart/use-chart-color","type":"heading","tags":[],"url":"/docs/components/chart/use-chart-color#examples","content":"Examples"},"982":{"id":"/docs/components/chart/use-chart-color-4","page_id":"/docs/components/chart/use-chart-color","type":"heading","tags":[],"url":"/docs/components/chart/use-chart-color#single-series","content":"Single series"},"983":{"id":"/docs/components/chart/use-chart-color-5","page_id":"/docs/components/chart/use-chart-color","type":"heading","tags":[],"url":"/docs/components/chart/use-chart-color#multiple-series","content":"Multiple series"},"984":{"id":"/docs/components/chart/use-chart-color-6","page_id":"/docs/components/chart/use-chart-color","tags":[],"type":"text","url":"/docs/components/chart/use-chart-color#for-use-with-chart-components-not-exported","content":"Wrap your chart (or list) with `ChartColorProvider`; each component that calls `useChartColor()` receives a CSS variable reference. Indices are assigned in an effect at mount, so allocation is safe under React concurrent rendering and StrictMode. Same component instance keeps the same color; colors cycle after the ninth consumer. No need to pass an index—order in the tree determines assignment."},"985":{"id":"/docs/components/chart/use-chart-color-7","page_id":"/docs/components/chart/use-chart-color","tags":[],"type":"text","url":"/docs/components/chart/use-chart-color#single-series","content":"One series using the first chart color."},"986":{"id":"/docs/components/chart/use-chart-color-8","page_id":"/docs/components/chart/use-chart-color","tags":[],"type":"text","url":"/docs/components/chart/use-chart-color#multiple-series","content":"Multiple series each receiving the next color in sequence."},"987":{"id":"/docs/components/chart/use-normalized-series","page_id":"/docs/components/chart/use-normalized-series","type":"page","content":"useNormalizedSeries","breadcrumbs":["Docs","Components","Chart"],"tags":[],"url":"/docs/components/chart/use-normalized-series"},"988":{"id":"/docs/components/chart/use-normalized-series-0","page_id":"/docs/components/chart/use-normalized-series","tags":[],"type":"text","url":"/docs/components/chart/use-normalized-series","content":"A hook that ensures every series config has a stable unique id, generating one from useId when omitted."},"989":{"id":"/docs/components/chart/use-normalized-series-1","page_id":"/docs/components/chart/use-normalized-series","type":"heading","tags":[],"url":"/docs/components/chart/use-normalized-series#for-use-with-chart-components-not-exported","content":"For use with chart components (not exported)"},"990":{"id":"/docs/components/chart/use-normalized-series-2","page_id":"/docs/components/chart/use-normalized-series","tags":[],"type":"text","url":"/docs/components/chart/use-normalized-series#for-use-with-chart-components-not-exported","content":"Accepts a `SeriesConfig[]` array and returns a memoized copy where each item is guaranteed to have an `id`. When an item has no `id`, one is generated using a component-scoped prefix from React's `useId`, ensuring IDs are unique across multiple chart instances on the same page. Existing `id` values are preserved as-is."},"991":{"id":"/docs/components/layout/box","page_id":"/docs/components/layout/box","type":"page","content":"Box","breadcrumbs":["Docs","Components","Layout"],"tags":[],"url":"/docs/components/layout/box"},"992":{"id":"/docs/components/layout/box-0","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box","content":"Polymorphic layout component providing consistent spacing, elevation, rounding, and self-alignment"},"993":{"id":"/docs/components/layout/box-1","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#installation","content":"Installation"},"994":{"id":"/docs/components/layout/box-2","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#props","content":"Props"},"995":{"id":"/docs/components/layout/box-3","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#scale-sizes","content":"Scale Sizes"},"996":{"id":"/docs/components/layout/box-4","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#examples","content":"Examples"},"997":{"id":"/docs/components/layout/box-5","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#padding","content":"Padding"},"998":{"id":"/docs/components/layout/box-6","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#elevation","content":"Elevation"},"999":{"id":"/docs/components/layout/box-7","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#rounding","content":"Rounding"},"1000":{"id":"/docs/components/layout/box-8","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#polymorphic-as-prop","content":"Polymorphic `as` Prop"},"1001":{"id":"/docs/components/layout/box-9","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#alignment","content":"Alignment"},"1002":{"id":"/docs/components/layout/box-10","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#rtl-support","content":"RTL Support"},"1003":{"id":"/docs/components/layout/box-11","page_id":"/docs/components/layout/box","type":"heading","tags":[],"url":"/docs/components/layout/box#design-tokens","content":"Design Tokens"},"1004":{"id":"/docs/components/layout/box-12","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box","content":"Box is a polymorphic layout component that renders as any HTML element or custom component via the `as` prop. It provides consistent spacing, elevation, rounding, and self-alignment within flex or grid containers."},"1005":{"id":"/docs/components/layout/box-13","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box","content":"**Important**: Since `Flex` and `Grid` extend `Box`, prefer them for layouts. Use `Box` only when you need a non-flex, non-grid container."},"1006":{"id":"/docs/components/layout/box-14","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#props","content":"The `Box` component accepts the following props:"},"1007":{"id":"/docs/components/layout/box-15","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"The spacing props use semantic t-shirt sizes for padding, gap, and other spacing properties:"},"1008":{"id":"/docs/components/layout/box-16","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xs` - Extra small spacing"},"1009":{"id":"/docs/components/layout/box-17","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`sm` - Small spacing"},"1010":{"id":"/docs/components/layout/box-18","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`md` - Medium spacing"},"1011":{"id":"/docs/components/layout/box-19","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`lg` - Large spacing"},"1012":{"id":"/docs/components/layout/box-20","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xl` - Extra large spacing"},"1013":{"id":"/docs/components/layout/box-21","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`2xl` - 2x extra large spacing"},"1014":{"id":"/docs/components/layout/box-22","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"Custom CSS values are also supported for edge cases."},"1015":{"id":"/docs/components/layout/box-23","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#padding","content":"The padding props support t-shirt sizes and CSS logical properties for RTL support."},"1016":{"id":"/docs/components/layout/box-24","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#elevation","content":"The elevation prop adds visual depth using box-shadow."},"1017":{"id":"/docs/components/layout/box-25","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#rounding","content":"The rounding prop sets border-radius. Use `full` for fully rounded corners."},"1018":{"id":"/docs/components/layout/box-26","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"Box is fully polymorphic - the `as` prop allows rendering as any HTML element or custom component while preserving type-safe props."},"1019":{"id":"/docs/components/layout/box-27","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**HTML Elements:** When using `as=\"button\"`, TypeScript enforces button-specific props like `type`, `disabled`, and `onClick`."},"1020":{"id":"/docs/components/layout/box-28","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**Custom Components:** When using `as={MyComponent}`, Box accepts that component's props. If there's a prop name conflict, Box's props take priority."},"1021":{"id":"/docs/components/layout/box-29","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**Typed Refs:** Refs are correctly typed based on the `as` value - `useRef<HTMLButtonElement>` works with `as=\"button\"`."},"1022":{"id":"/docs/components/layout/box-30","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#alignment","content":"Self-alignment props allow Box to position itself within flex or grid containers."},"1023":{"id":"/docs/components/layout/box-31","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#rtl-support","content":"Box uses CSS logical properties (`padding-inline-start`, `padding-block-end`, etc.) which automatically adapt to RTL layouts. No additional configuration is needed."},"1024":{"id":"/docs/components/layout/box-32","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#design-tokens","content":"All spacing, elevation, and rounding values are derived from the theme. If no theme is provided, default values are used. This ensures consistency across the design system."},"1025":{"id":"/docs/components/layout/flex","page_id":"/docs/components/layout/flex","type":"page","content":"Flex","breadcrumbs":["Docs","Components","Layout"],"tags":[],"url":"/docs/components/layout/flex"},"1026":{"id":"/docs/components/layout/flex-0","page_id":"/docs/components/layout/flex","tags":[],"type":"text","url":"/docs/components/layout/flex","content":"One-dimensional layout component for arranging children in rows or columns with alignment and spacing control"},"1027":{"id":"/docs/components/layout/flex-1","page_id":"/docs/components/layout/flex","type":"heading","tags":[],"url":"/docs/components/layout/flex#installation","content":"Installation"},"1028":{"id":"/docs/components/layout/flex-2","page_id":"/docs/components/layout/flex","type":"heading","tags":[],"url":"/docs/components/layout/flex#props","content":"Props"},"1029":{"id":"/docs/components/layout/flex-3","page_id":"/docs/components/layout/flex","type":"heading","tags":[],"url":"/docs/components/layout/flex#scale-sizes","content":"Scale Sizes"},"1030":{"id":"/docs/components/layout/flex-4","page_id":"/docs/components/layout/flex","type":"heading","tags":[],"url":"/docs/components/layout/flex#examples","content":"Examples"},"1031":{"id":"/docs/components/layout/flex-5","page_id":"/docs/components/layout/flex","type":"heading","tags":[],"url":"/docs/components/layout/flex#de