HTML element or custom component via the `as` prop. It provides consistent spacing, elevation, rounding, and self-alignment within flex or grid containers."},"918":{"id":"/docs/components/layout/box-13","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box","content":"**Important**: Since `Flex` and `Grid` extend `Box`, prefer them for layouts. Use `Box` only when you need a non-flex, non-grid container."},"919":{"id":"/docs/components/layout/box-14","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#props","content":"The `Box` component accepts the following props:"},"920":{"id":"/docs/components/layout/box-15","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"The spacing props use semantic t-shirt sizes for padding, gap, and other spacing properties:"},"921":{"id":"/docs/components/layout/box-16","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xs` - Extra small spacing"},"922":{"id":"/docs/components/layout/box-17","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`sm` - Small spacing"},"923":{"id":"/docs/components/layout/box-18","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`md` - Medium spacing"},"924":{"id":"/docs/components/layout/box-19","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`lg` - Large spacing"},"925":{"id":"/docs/components/layout/box-20","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xl` - Extra large spacing"},"926":{"id":"/docs/components/layout/box-21","page_id":"/docs/components/layout/box","tags":[],"type"