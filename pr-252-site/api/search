-step-numbers","content":"Hide step numbers"},"644":{"id":"/docs/components/progress-steps-11","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#customization","content":"Customization"},"645":{"id":"/docs/components/progress-steps-12","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#accessibility","content":"Accessibility"},"646":{"id":"/docs/components/progress-steps-13","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#best-practices","content":"Best Practices"},"647":{"id":"/docs/components/progress-steps-14","page_id":"/docs/components/progress-steps","type":"heading","tags":[],"url":"/docs/components/progress-steps#troubleshooting","content":"Troubleshooting"},"648":{"id":"/docs/components/progress-steps-15","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Horizontal and vertical orientations"},"649":{"id":"/docs/components/progress-steps-16","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Four completion statuses (`none`, `partial`, `complete`, `error`) with status icons"},"650":{"id":"/docs/components/progress-steps-17","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Timeline (past / current / future) derived from a single `currentStep` prop"},"651":{"id":"/docs/components/progress-steps-18","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","content":"Auto-generated step numbers (opt out with `hideStepNumbers`)"},"652":{"id":"/docs/components/progress-steps-19","page_id":"/docs/components/progress-steps","tags":[],"type":"text","url":"/docs/components/progress-steps#features","con