age_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#usage","content":"Usage"},"239":{"id":"/docs/components/field-2","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#basic-example","content":"Basic example"},"240":{"id":"/docs/components/field-3","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#composition","content":"Composition"},"241":{"id":"/docs/components/field-4","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#positioning-controls-inside-the-group","content":"Positioning controls inside the group"},"242":{"id":"/docs/components/field-5","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#states","content":"States"},"243":{"id":"/docs/components/field-6","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#examples","content":"Examples"},"244":{"id":"/docs/components/field-7","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#leading-control","content":"Leading control"},"245":{"id":"/docs/components/field-8","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#trailing-control","content":"Trailing control"},"246":{"id":"/docs/components/field-9","page_id":"/docs/components/field","type":"heading","tags":[],"url":"/docs/components/field#icon-accessories","content":"Icon accessories"},"247":{"id":"/docs/components/field-10","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**Composition primitives.** The field components (TextField, NumberField, DateField, Select, RadioGroup, CheckboxGroup) compose these internally — reach for those first. These primitives are also the building blocks for custom composite fields, e.g. an input and a select sharing one bordered box."},"248":{"id":"/docs/components/field-11","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"The field decoration is split into granular, composable pieces so the same structure is shared across every field:"},"249":{"id":"/docs/components/field-12","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`Field`** — stacks a field's label, control, description, and error in one consistently spaced column (pure layout — a `Flex` column with the standard field gap)."},"250":{"id":"/docs/components/field-13","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldLabel`** — names the field and flags whether it's required (wraps React Aria `Label`, rendering an optional `*` indicator)."},"251":{"id":"/docs/components/field-14","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldGroup`** — the bordered box that visually unites a field's controls and reflects their shared focus, disabled, and invalid state. Used only by \"boxed\" fields (TextField, NumberField, Select, DateField); presentationally it is a React Aria `Group`."},"252":{"id":"/docs/components/field-15","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldInput`*&#x2A; / &#x2A;*`FieldTextArea`** — the control the user types into (normalized React Aria `Input`/`TextArea` given antares spacing via `Box`)."},"253":{"id":"/docs/components/field-16","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldButton`** — an actionable control placed inside the box, such as the NumberField steppers or a search submit (a click target within the group)."},"254":{"id":"/docs/components/field-17","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldDescription`** — helper text that explains the field; renders nothing when empty (wraps the antares `Text` with `slot=\"description\"`)."},"255":{"id":"/docs/components/field-18","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"**`FieldError`** — surfaces the field's validation messages when it is invalid, and nothing when valid (a thin wrapper over React Aria `FieldError`)."},"256":{"id":"/docs/components/field-19","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field","content":"`FieldLabel`, `FieldDescription`, and `FieldError` each render `null` when they have no content, so callers pass `label` / `description` / `errorMessage` straight through without guarding."},"257":{"id":"/docs/components/field-20","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#usage","content":"The `FieldGroup` component has the following props:"},"258":{"id":"/docs/components/field-21","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"A boxed field composes the primitives inside its React Aria field wrapper. Use\n`Field as={...}` to merge the field wrapper and the layout column into a single\nelement:"},"259":{"id":"/docs/components/field-22","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"A field without a box (RadioGroup / CheckboxGroup) composes `Field` + `FieldLabel` + `FieldError` and omits `FieldGroup`."},"260":{"id":"/docs/components/field-23","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#composition","content":"`FieldGroup` is purely presentational — it renders the styled `Group` and holds no React Aria context. The surrounding field wires value, disabled, and validation state into its controls."},"261":{"id":"/docs/components/field-24","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#positioning-controls-inside-the-group","content":"`FieldGroup` rounds its outer corners from DOM order: the group's CSS rounds the start corners of its **first child** and the end corners of its **last child**, so controls are seamless inside and rounded only at the box edges. Author children in visual order and the rounding follows — no per-control positioning prop. A lone control (a TextField input, a Select trigger) is both first and last, so it rounds both edges. The rules are RTL-safe (they use logical `start`/`end` corners)."},"262":{"id":"/docs/components/field-25","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"The states **disabled**, **readonly**, and **invalid** are applied by the field wrapper (e.g. TextField, NumberField, Select). The group reflects them via data attributes on the group."},"263":{"id":"/docs/components/field-26","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"State"},"264":{"id":"/docs/components/field-27","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"CSS Selector"},"265":{"id":"/docs/components/field-28","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"disabled — Applied when the field wrapper is disabled."},"266":{"id":"/docs/components/field-29","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-disabled]`"},"267":{"id":"/docs/components/field-30","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"invalid — Applied when the field wrapper is invalid (e.g. validation failed)."},"268":{"id":"/docs/components/field-31","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-invalid]`"},"269":{"id":"/docs/components/field-32","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"focus — Whether an element within the group has keyboard focus (for focus-ring styling)."},"270":{"id":"/docs/components/field-33","page_id":"/docs/components/field","tags":[],"type":"text","url":"/docs/components/field#states","content":"`[data-focused]`"},"271":{"id":"/docs/components/icon","page_id":"/docs/components/icon","type":"page","content":"Icon","breadcrumbs":["Docs","Components"],"tags":[],"url":"/docs/components/icon"},"272":{"id":"/docs/components/icon-0","page_id":"/docs/components/icon","tags":[],"type":"text","url":"/docs/components/icon","content":"Flexible SVG icon component with on-demand loading, automatic caching, and extensive customization options"},"273":{"id":"/docs/components/icon-1","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#features","content":"Features"},"274":{"id":"/docs/components/icon-2","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#installation","content":"Installation"},"275":{"id":"/docs/components/icon-3","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#props","content":"Props"},"276":{"id":"/docs/components/icon-4","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#prop-inheritance","content":"Prop Inheritance"},"277":{"id":"/docs/components/icon-5","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#basic-usage","content":"Basic Usage"},"278":{"id":"/docs/components/icon-6","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#size-variants","content":"Size Variants"},"279":{"id":"/docs/components/icon-7","page_id":"/docs/components/icon","type":"heading","tags":[],"url":"/docs/components/icon#customization","content":"Customization"},"280":{"id":"/docs/components/icon-8","pa