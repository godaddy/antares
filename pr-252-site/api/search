":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xs` - Extra small spacing"},"1317":{"id":"/docs/components/layout/box-17","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`sm` - Small spacing"},"1318":{"id":"/docs/components/layout/box-18","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`md` - Medium spacing"},"1319":{"id":"/docs/components/layout/box-19","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`lg` - Large spacing"},"1320":{"id":"/docs/components/layout/box-20","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`xl` - Extra large spacing"},"1321":{"id":"/docs/components/layout/box-21","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"`2xl` - 2x extra large spacing"},"1322":{"id":"/docs/components/layout/box-22","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#scale-sizes","content":"Custom CSS values are also supported for edge cases."},"1323":{"id":"/docs/components/layout/box-23","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#padding","content":"The padding props support t-shirt sizes and CSS logical properties for RTL support."},"1324":{"id":"/docs/components/layout/box-24","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#elevation","content":"The elevation prop adds visual depth using box-shadow."},"1325":{"id":"/docs/components/layout/box-25","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#rounding","content":"The rounding prop sets border-radius. Use `full` for fully rounded corners."},"1326":{"id":"/docs/components/layout/box-26","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"Box is fully polymorphic - the `as` prop allows rendering as any HTML element or custom component while preserving type-safe props."},"1327":{"id":"/docs/components/layout/box-27","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**HTML Elements:** When using `as=\"button\"`, TypeScript enforces button-specific props like `type`, `disabled`, and `onClick`."},"1328":{"id":"/docs/components/layout/box-28","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**Custom Components:** When using `as={MyComponent}`, Box accepts that component's props. If there's a prop name conflict, Box's props take priority."},"1329":{"id":"/docs/components/layout/box-29","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#polymorphic-as-prop","content":"**Typed Refs:** Refs are correctly typed based on the `as` value - `useRef<HTMLButtonElement>` works with `as=\"button\"`."},"1330":{"id":"/docs/components/layout/box-30","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#alignment","content":"Self-alignment props allow Box to position itself within flex or grid containers."},"1331":{"id":"/docs/components/layout/box-31","page_id":"/docs/components/layout/box","tags":[],"type":"text","url":"/docs/components/layout/box#rtl-support","content":"Box uses CSS logical properties (`padding-inline-start`, `padding-block-end`, etc.) which automatically adapt to RTL layouts. No additional configuration is needed."},"1332":{"id":"/docs/components/layout/box-32","page_id":"/docs/components/layout/box","tags":[],"ty